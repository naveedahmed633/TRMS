@{
    ViewBag.Title = "TRMS - My Team";
    Layout = "~/Areas/LM/Views/Shared/_Layout.cshtml";

    var isDataFound = false;

    string LM_LEC_STF_LoginUserType = "";
    if (MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeFunctionSLSID.ToString().Contains("lecturer"))
    {
        LM_LEC_STF_LoginUserType = "LEC";
    }
    else if (MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeFunctionSLSID.ToString().Contains("staff"))
    {
        LM_LEC_STF_LoginUserType = "STF";
    }
    else
    {
        LM_LEC_STF_LoginUserType = "LM";
    }
}

@model TimeTune.Dashboard.LMAttendanceCount

@{
    //Present - Leave - Absent
    string pr_chart_color_a = "#66bb6a ", pr_chart_color_b = "#7266ba", pr_chart_color_c = "#ee6e73";
    //Ontime - Late - Earlyout
    string pn_chart_color_d = "#29b6f6", pn_chart_color_e = "#ffc107", pn_chart_color_f = "#f76397";
}
<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.welcome") <span class="text-danger">'@LM_LEC_STF_LoginUserType'</span>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.LoginID") <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.Campus") <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/LM/LM/Dashboard">@LM_LEC_STF_LoginUserType</a></li>
                    <li class="breadcrumb-item active">My Team</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->


    <div class="row">
        <div class="col-lg-4 col-md-3">
            <div class="widget-simple text-center card-box">
                <h3 class="text-success counter font-bold mt-0">@Model.data.todayPresent</h3>
                <p class="text-muted mb-0">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("lblptoday")</p>
            </div>
        </div>

        <div class="col-lg-4 col-md-3">
            <div class="widget-simple text-center card-box">
                <h3 class="text-danger counter font-bold mt-0">@Model.data.todayLeave</h3>
                <p class="text-muted mb-0">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("lblltoday")</p>
            </div>
        </div>

        <div class="col-lg-4 col-md-3">
            <div class="widget-simple text-center card-box">
                <h3 class="text-pink counter font-bold mt-0">@Model.data.todayAbsent</h3>
                <p class="text-muted mb-0">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("lblabtoday")</p>
            </div>
        </div>

        @*<div class="col-lg-3 col-md-6">
            <div class="widget-simple text-center card-box">
                <h3 class="text-primary counter font-bold mt-0">62</h3>
                <p class="text-muted mb-0">OnTime - Today</p>
            </div>
        </div>*@
    </div>
    

    <div class="row">
        <div class="col-md-6">

            <div id="chartPresence" class="card-box">

                <h4 class="m-t-0 header-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("Menu.emp.presnce") @DateTime.Now.ToString("MMM yyyy")</h4>
                @if (Model.data.todayPresent != 0)
                {
                    <svg id="svgChartPresence" style="height:350px;width:100%"></svg>
                }
                else
                {
                    <p class="text-danger mb-0" style="height:350px;width:100%">N/A</p>
                }

            </div>



        </div>


        <div class="col-md-6">

            <div id="chartPunctuality" class="card-box">
                <h4 class="m-t-0 header-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("Menu.emp.presnce.punctuality") @DateTime.Now.ToString("MMM yyyy")</h4>
                @if (Model.data.todayOnTime.ToString() != "")
                {
                    <svg id="svgChartPunctuality" style="height:350px;width:100%"></svg>
                }
                else
                {
                    <p class="text-danger mb-0" style="height:350px;width:100%">N/A</p>
                }

            </div>

        </div>

    </div>

    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="mdi mdi-account-box"></i> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("MyTeam.title") </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>

                    </div>

                    <hr>





                    <div class="row">
                        <div class="col-12">
                            <h4>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("MyTeam.attendance.supervisor")</h4>

                            <div class="list-group">

                                @foreach (var item in Model.getSupervisorData)
                                {
                                    isDataFound = true;

                                    <span class="list-group-item">
                                        <i class="mdi mdi-account"></i> @item
                                    </span>

                                }

                                @if (!isDataFound)
                                {
                                    <span class="list-group-item text-danger">
                                        <i class="mdi mdi-information"></i> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("MyTeam.nodata")
                                    </span>
                                }

                            </div>
                        </div>
                    </div>

                </div>




            </div>
        </div>
    </div>
    <div class="card-box">

        <div class="row">
            <div class="col-12">
                <h3>Tagged Employees</h3>

                <hr />

                <table id="emp_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%">
                    <thead>
                        <tr>
                            <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("monthly.fn")</th>
                            <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("monthly.ln")</th>
                            <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("monthly.epcode")</th>
                            <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("lblfunction")</th>
                            <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("lblDepartment")</th>
                            <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("lbllocations")</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>

        <div class="row m-t-10">
            <div class="col-2">
                <button type="submit" id="btnExport" class="btn btn-primary waves-effect waves-light">Export Grid Data</button>
            </div>
            <div class="col-10">
                <form action="/LM/LM/SupervisorTeamPDF" method="post">
                    <button type="submit" id="btnPDFDownload" style="display: @if (!isDataFound) { <text>none;</text> } else { <text>block;</text> }" class="btn btn-primary waves-effect waves-light">Export PDF</button>
                </form>
            </div>
        </div>
    </div>

</div>
<!-- End content -->
@section JS {

    <script type="text/javascript" src="@Href("~/Scripts/chosen.ajaxaddition.jquery.js")"></script>
    <script src="/plugins/waypoints/lib/jquery.waypoints.min.js"></script>
    <script src="/plugins/counterup/jquery.counterup.min.js"></script>

    <!-- Sparkline -->
    <script src="/plugins/jquery-sparkline/jquery.sparkline.min.js"></script>
    <script>
        $(document).ready(function () {
            //$('#accordion').accordion("option", "active", 0);
            //setActiveLink("My Team");
            //            $(".chzn-select").chosen();
            $(".datepicker").datepicker({ dateFormat: 'yy-mm-dd' });
            //$("input[type=submit], button").button();

            $("#btnExport").click(function (e) {
                setupTableExportButton('#emp_table', 'Tagged_Employee');
                e.preventDefault();
            });

            var url = '@Url.Action("DataHandler", "LM", null, Request.Url.Scheme)';

            var columns = [
                           { "data": "first_name" },
                           { "data": "last_name" },
                           { "data": "employee_code" },
                           { "data": "function_name" },
                           { "data": "department_name" },
                           { "data": "location_name" }
            ];

            @*
               I did this so that like initDataTables the JS
            for serverside processing can be used for other tables.
                NOTE: The names of the columns correspond to the View Model.
            For example in this example the column names, first_name, last_name
            etc are taken from ViewModels.Employee
        *@

            initServerSideTable('#emp_table', url, columns, 1000);
        });
    </script>

    <script>

        function loadChart(a, b, c, d, e, f) {

            (function ($) {
                'use strict';

                //Donut chart2
                nv.addGraph(function () {
                    var chart = nv.models.pieChart()
                        .x(function (d) { return d.label })
                        .y(function (d) { return d.value })
                        .showLabels(true)     //Display pie labels
                        .labelThreshold(.05)  //Configure the minimum slice size for labels to show up
                        .labelType("percent") //Configure what type of data to show in the label. Can be "key", "value" or "percent"
                        .donut(true)          //Turn on Donut mode. Makes pie chart look tasty!
                        .donutRatio(0.35)     //Configure how big you want the donut hole size to be.

                    ;

                    d3.select("#chartPunctuality svg")
                        .datum(PunctualityChartData())
                        .transition().duration(350)
                        .call(chart);

                    return chart;
                });
                //Donut chart3
                nv.addGraph(function () {
                    var chart = nv.models.pieChart()
                        .x(function (d) { return d.label })
                        .y(function (d) { return d.value })
                        .showLabels(true)     //Display pie labels
                        .labelThreshold(.05)  //Configure the minimum slice size for labels to show up
                        .labelType("percent") //Configure what type of data to show in the label. Can be "key", "value" or "percent"
                        .donut(true)          //Turn on Donut mode. Makes pie chart look tasty!
                        .donutRatio(0.35)     //Configure how big you want the donut hole size to be.

                    ;

                    d3.select("#chartPresence svg")
                        .datum(PresenceChartData())
                        .transition().duration(350)
                        .call(chart);

                    return chart;
                });

                //Pie chart data
                function PunctualityChartData() {
                    return [
                         {
                             "label": "On Time",
                             "value": d,
                             "color": "@pn_chart_color_d" //"#29b6f6"
                         },
                        {
                            "label": "Late",
                            "value": e,
                            'color': "@pn_chart_color_e" //'#ffc107'
                        },
                        {
                            "label": "Early Out",
                            "value": f,
                            'color': "@pn_chart_color_f" //'#f76397'
                        }


                    ];
                }
                function PresenceChartData() {
                    return [
                        {
                            "label": "Present",
                            "value": a,
                            "color": "@pr_chart_color_a" //"#66bb6a"
                        },
                        {
                            "label": "Leave",
                            "value": b,
                            'color': "@pr_chart_color_b" //'#7266ba'
                        },
                        {
                            "label": "Absent",
                            "value": c,
                            'color': "@pr_chart_color_c" //'#ee6e73'
                        }


                    ];
                }
            })(jQuery);
        }

        $(document).ready(function () {

            var empCode2= @Html.Raw(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId);

            $.ajax({
                url: '/LM/LM/VerfiyDataHandler',
                type: "POST",
                data: { empId: empCode2 },
                dataType: "json",

                success: function (data) {
                    if (data.LMExportGridData == false) {
                        $("#btnExport").hide();
                    }if (data.LMExportPDF == false) {
                        $("#btnPDFDownload").hide();
                    }
                    
                },
                error: function () {
                    alert("error");
                }
            });

            $.post("/LM/LM/DashboardPALChartDataMyTeam", //Present Absent Chart
                  function (data) {

                      console.log(data);

                      if (data.length > 0) {
                          var strMain = data.split(',');

                          var strInner0 = strMain[0].split('=');
                          var strInner1 = strMain[1].split('=');
                          var strInner2 = strMain[2].split('=');
                          var strInner3 = strMain[3].split('=');
                          var strInner4 = strMain[4].split('=');
                          var strInner5 = strMain[5].split('=');

                          var present = strInner0[1];
                          var leave = strInner1[1];
                          var absent = strInner2[1];
                          var ontime = strInner3[1];
                          var late = strInner4[1];
                          var early = strInner5[1];
                          console.log("2: " + present + " : " + leave + " : " + absent + " : " + ontime + " : " + late + " : " + early);

                          //loadChart(20, 30, 50, 10, 90, 0);

                          //alert("2: " + present + " : " + leave + " : " + absent + " : " + ontime + " : " + late + " : " + early);
                          loadChart(present, leave, absent, ontime, late, early);
                      }
                  });

        });

        function HideMessage() {
            setTimeout(function () {
                document.getElementById('chart_wait_1').innerHTML = "";
                document.getElementById('chart_wait_2').innerHTML = "";
            }, 22000);
        }

    </script>
}