        <script type="text/javascript" src="@Href("~/Scripts/chosen.ajaxaddition.jquery.js")"></script>

        <script src="@Url.Content("/Scripts/employeeCRUD.js")" type="text/javascript"></script>


        <script type="text/javascript">

            function setChosenSelectList(selector,URL) {


                $(selector).ajaxChosen({
                    dataType: 'json',
                    type: 'POST',
                    url: URL
                }, {
                    loadingImg: '@Href("~/Content/ChosenAutoComplete/loading.gif")'
                });



            }
            function alertFilename() {
                var thefile = document.getElementById('my-file-selector');
                document.getElementById('file-name').innerHTML=thefile.value;
            }
            function checkSubmit(id) {

                jDate = $(id).find('[name*="date_of_joining"]').val().split("-").reverse();
                lDate = $(id).find('[name*="date_of_leaving"]').val().split("-").reverse();
                var numbers = /^[0-9]+$/;
                empcode = $(id).find('[name*="employee_code"]').val();

                jDate = new Date(parseInt(jDate[0]), parseInt(jDate[1]) - 1, parseInt(jDate[2]));
                lDate = new Date(parseInt(lDate[0]), parseInt(lDate[1]) - 1, parseInt(lDate[2]));

                if (jDate >= lDate) {
                    alert("Joining Date must be before of Leaving Date");
                    return false;
                } else {


                    var number = parseInt(empcode);

                    if (isNaN(number)) {
                        alert('Please input numeric characters only');
                        return false;
                    }
                    else {
                        return true;

                    }

                }


                    


                return true;
            }


            $(document).ready(function () {
                $('#accordion').accordion("option", "active", 1);
                $(".datepicker").datepicker({ dateFormat: 'dd-mm-yy' });



                setupTableExportButton('#emp_table', '#btnExport', 'Employees');
                /*
                $('#btnExport').button();
                $("#btnExport").click(function (e) {
                    $('#emp_table').tableExport({ type: 'excel', escape: 'false' });
                    e.preventDefault();
                });
                */

                $('.hasDatepicker').keydown(function (e) {
                    var unicode = e.keyCode ? e.keyCode : e.charCode;
                    if (unicode != 13 && unicode != 8 && unicode != 9) {



                        e.preventDefault();
                    }


                    // for backspace clear field.
                    if (unicode == 8) {
                        $(this).val("");
                    }
                });


                setChosenSelectList('#employee-function-select', '@Url.Action("functions", "EmployeeManagement", null, Request.Url.Scheme)');
                setChosenSelectList('#employee-designation-select', '@Url.Action("designations", "EmployeeManagement", null, Request.Url.Scheme)');
                setChosenSelectList('#employee-department-select', '@Url.Action("departments", "EmployeeManagement", null, Request.Url.Scheme)');
                setChosenSelectList('#employee-toe-select', '@Url.Action("typeOfEmployments", "EmployeeManagement", null, Request.Url.Scheme)');
                setChosenSelectList('#employee-grade-select', '@Url.Action("grades", "EmployeeManagement", null, Request.Url.Scheme)');
                setChosenSelectList('#employee-region-select', '@Url.Action("regions", "EmployeeManagement", null, Request.Url.Scheme)');
                setChosenSelectList('#employee-location-select', '@Url.Action("locations", "EmployeeManagement", null, Request.Url.Scheme)');

                setChosenSelectList('.employee-function-select', '@Url.Action("functions", "EmployeeManagement", null, Request.Url.Scheme)');
                setChosenSelectList('.employee-designation-select', '@Url.Action("designations", "EmployeeManagement", null, Request.Url.Scheme)');
                setChosenSelectList('.employee-department-select', '@Url.Action("departments", "EmployeeManagement", null, Request.Url.Scheme)');
                setChosenSelectList('.employee-toe-select', '@Url.Action("typeOfEmployments", "EmployeeManagement", null, Request.Url.Scheme)');
                setChosenSelectList('.employee-grade-select', '@Url.Action("grades", "EmployeeManagement", null, Request.Url.Scheme)');
                setChosenSelectList('.employee-region-select', '@Url.Action("regions", "EmployeeManagement", null, Request.Url.Scheme)');
                setChosenSelectList('.employee-location-select', '@Url.Action("locations", "EmployeeManagement", null, Request.Url.Scheme)');

                $('#access_group_drop_down').chosen();
                $('#time_tune_status_drop_down').chosen();
                $("input[type=submit], button").button();
                setActiveLink("Manage Employees");




                var url = '@Url.Action("DataHandler", "EmployeeManagement", null, Request.Url.Scheme)';

                var columns = [
               { "data": "first_name" },
               { "data": "last_name" },
               { "data": "employee_code" },
               { "data": "function_name" },
               { "data": "department_name" },
               { "data": "line_manager_code" },
               {"data":"time_tune_status"},
                { "data": "actions" }

                ];

                @*
                    I did this so that like initDataTables the JS
                    for serverside processing can be used for other tables.
                    NOTE: The names of the columns correspond to the View Model.
                    For example in this example the column names, first_name, last_name
                    etc are taken from ViewModels.Employee
*@
                

            initServerSideTable('#emp_table', url, columns);

            deleteEmployee = initDeleteEmployeeModal('#employee_modals', '@Url.Action("DeleteEmployee", "EmployeeManagement", null, Request.Url.Scheme)');

            editEmployee = initEditEmployeeModal('@Url.Action("EditEmployee", "EmployeeManagement", null, Request.Url.Scheme)');

               
            $('#employee-form').on("submit", function (e) {

                if (!checkSubmit('#employee-form')) {
                    e.preventDefault();
                }
            });

            });
            
            function displayToastrSuccessfull() {
                $('#toast').html('File Uploded Successfuly');
                $('#toast').stop().fadeIn(400).delay(3000).fadeOut(400);
            }

    </script>
