@model ViewModels.CreateEmployee

<h4 style="font-weight: bold;">Employee Management</h4>
<div class="row">
    <div class="form-group col-md-3">
        <h5 style="font-weight: bold;">Register User</h5>

        @using (Html.BeginForm("AddEmployee", "EmployeeManagement", FormMethod.Post, new { id = "employee-form" }))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary()
            <div class="row">

                <div class="col-md-12">
                    <label class="control-label">First Name</label>
                    <input type="text" class="form-control" name="first_name" id="fname" required>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">Last Name</label>
                    <input type="text" class="form-control" name="last_name" id="lname" required>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">Employee Number</label>
                    <input type="text" pattern="+[0-9]" class="form-control" name="employee_code" id="empid" required>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">Email Address</label>
                    <input type="email" class="form-control" name="email" id="email">
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">Address</label>
                    <input type="text" class="form-control" name="address" id="email">
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">Mobile No</label>
                    <input type="text" class="form-control" name="mobile_no" id="email">
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">Date of Joining</label>
                    <input type="text" class="form-control datepicker" name="date_of_joining" style="background-color: #FFF" required>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">Date of Leaving</label>
                    <input type="text" class="form-control datepicker" name="date_of_leaving" style="background-color: #FFF">
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">Function</label>

                    <select id="employee-function-select" class="form-control " name="function_id">
                        <option value="0">none</option>
                    </select>

