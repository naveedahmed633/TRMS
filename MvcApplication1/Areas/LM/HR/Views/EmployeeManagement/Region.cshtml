@model List<ViewModels.Region>


<h4 style="font-weight: bold;">Employee Management</h4>
<div class="row">
    <div class="form-group col-md-3">
        <h5 style="font-weight: bold;">Register Region</h5>
        @using (Html.BeginForm("AddRegion", "EmployeeManagement"))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary()
        <div class="row">

                <div class="col-md-12">
                    <label class="control-label">Region Name</label>
                    <input type="text" pattern=".{2,}" title="2 characters minimum" class="form-control" id="fname" name="name"
                           oninput="setCustomValidity('');" oninvalid="setCustomValidity('Name should contain at least 2 characters.');" required />
                </div>
            </div>

            <div class="row">

                <div class="col-md-12">
                    <label class="control-label">Description</label>
                    <textarea class="form-control" name="description"></textarea>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12" style="margin-top:5px">
                    <button type="submit" value="Submit">Add Region</button>
                    
                    <button type="reset" value="Reset">Reset</button>
                    
                </div>
            </div>
        }
    </div>
    <div class="col-md-9">
        <h5 style="font-weight: bold;">Current Regions</h5>
        <table id="region_table" class="display cell-border" width="100%">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Region Name</th>
                    <th>Region Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
        <button type="submit" id="btnExport" style="margin-top:5px">Export excel</button>

    </div>
</div>


@section JS {
    <script>
        $(document).ready(function () {
            $('#accordion').accordion("option", "active", 1);
            $("input[type=submit], button").button();
            



            setupTableExportButton('#region_table', '#btnExport', 'Regions');

            /*
            $('#btnExport').button();
            $("#btnExport").click(function (e) {
                $('#region_table').tableExport({ type: 'excel', escape: 'false' });
                e.preventDefault();
            });
            */



            var url = '@Url.Action("RegionDataHandler", "EmployeeManagement", null, Request.Url.Scheme)';

            var columns = [
                  { "data": "id" },
                  { "data": "name" },
                  { "data": "description" },
                  { "data": "actions" }

            ];

            initServerSideTable('#region_table', url, columns);

            editRegion = initEditModal("#modals", '@Url.Action("UpdateRegion", "EmployeeManagement", null, Request.Url.Scheme)', "Region");
            deleteRegion = initDeleteModal("#modals", '@Url.Action("RemoveRegion", "EmployeeManagement", null, Request.Url.Scheme)', "Region");
            setActiveLink("Region");


        });
    </script>
}
