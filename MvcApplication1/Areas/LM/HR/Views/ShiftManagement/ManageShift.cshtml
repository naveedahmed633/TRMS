@model List<ViewModels.Shift>

    <h4 style="font-weight: bold;">Shift Management</h4>

    <div class="row">
        <div class="form-group col-md-3">
            <h5 style="font-weight: bold;">Add Shifts</h5>
@using (Html.BeginForm("AddShift", "ShiftManagement", FormMethod.Post, new { id = "mngshift_form"}))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary()
           <div class="row">

                    <div class="col-md-12">
                        <label class="control-label">Shift Name</label>
                        
                        <input type="text" pattern=".{2,}" title="2 characters minimum" class="form-control" id="sname" name="name"
                               oninput="setCustomValidity('');" oninvalid="setCustomValidity('Name should contain at least 2 characters.');" required />
                    </div>
                </div>

                <div class="row">

                    <div class="col-md-12">
                        <label class="control-label">Early Time</label>
                        <input type="text" class="form-control timepicker" name="early_time" id="early_time" required>

                    </div>
                </div>
                <div class="row">

                    <div class="col-md-12">
                        <label class="control-label">Start Time</label>
                        <input type="text" class="form-control timepicker" name="start_time" id="start_time" required>
                    </div>
                </div>
                <div class="row">

                    <div class="col-md-12">
                        <label class="control-label">Late Time</label>
                        <input type="text" class="form-control timepicker" name="late_time" id="late_time" required>
                    </div>
                </div>
                <div class="row">

                    <div class="col-md-12">
                        <label class="control-label">Half Day</label>
                        <input type="text" class="form-control timepicker" name="half_day" id="half_day" required>
                    </div>
                </div>
                <div class="row">

                    <div class="col-md-12">
                        <label class="control-label">Shift End</label>
                        <input type="text" class="form-control timepicker" name="shift_end" id="shift_end" required>
                    </div>
                </div>
                <div class="row">

                    <div class="col-md-12">
                        <label class="control-label">Day End</label>
                        <input type="text" class="form-control timepicker" name="day_end" id="day_end" required>
                    </div>
                </div>
               
               
                <div class="row">
                    <div class="col-md-12" style="margin-top:5px">
                        <button type="submit" value="Submit">Add Shift</button>

                        <button type="reset" value="Reset">Reset</button>
                    </div>
                </div>
        
}
        </div>
        <div class="col-md-9">
            <h5 style="font-weight: bold;">Current Shifts</h5>
            <table id="shifts_table" class="display cell-border compact">
                <thead>
                    <tr>
                        <th>Shift Name</th>
                        <th>Early Time</th>
                        <th>Start Time</th>
                        <th>Late Time</th>
                        <th>Half Day</th>
                        <th>Shift End</th>
                        <th>Day End</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (ViewModels.Shift shift in Model)
                    {
                        <tr data-row="@shift.id">
                            <td>@shift.name</td>
                            <td>@shift.early_time</td>
                            <td>@shift.start_time</td>
                            <td>@shift.late_time</td>
                            <td>@shift.half_day</td>
                            <td>@shift.shift_end</td>
                            <td>@shift.day_end</td>
                            <td class="dt-center">
                                <div>
                                    <a href="javascript:void(editShift(@shift.id));">Edit</a>
                                    <span>/</span>
                                    <a href="javascript:void(deleteShift(@shift.id));">Delete</a>

                                </div>
                            </td>
                        </tr>
                    }

                </tbody>
            </table>
            <button type="submit" id="btnExport" style="margin-top:5px">Export excel</button>
           
        </div>
    </div>




<div id="shifts_modals">

    
</div>



    @section JS {
        <script src="@Url.Content("/Scripts/shiftCRUD.js")" type="text/javascript"></script>
       <script>

           // helper
           function convertTo24(time) {
               var hours = Number(time.match(/^(\d+)/)[1]);
               var minutes = Number(time.match(/:(\d+)/)[1]);
               var AMPM = time.match(/\s(.*)$/)[1];
               if (AMPM == "PM" && hours < 12) hours = hours + 12;
               if (AMPM == "AM" && hours == 12) hours = hours - 12;
               var sHours = hours.toString();
               var sMinutes = minutes.toString();
               if (hours < 10) sHours = "0" + sHours;
               if (minutes < 10) sMinutes = "0" + sMinutes;


               return sHours + sMinutes;
           }
           

           function checkShift(id) {
               var earlyTime = $(id).find('[name*="early_time"]').val();
               var startTime = $(id).find('[name*="start_time"]').val();
               var lateTime = $(id).find('[name*="late_time"]').val();
               var halfDay = $(id).find('[name*="half_day"]').val();
               var shiftEnd = $(id).find('[name*="shift_end"]').val();
               var dayEnd = $(id).find('[name*="day_end"]').val();


               //if (earlyTime >= startTime) {
               //    alert("Early Time must be less than the Start Time");
               //    return false;
               //} else
               //    if (startTime >= lateTime) {
               //        alert("Start Time must be less than the Late Time");
               //        return false;
               //    } else
               //        if (lateTime >= halfDay) {
               //            alert("Late Time must be less than the Half Day");
               //            return false;
               //        } else
               //            if (halfDay >= shiftEnd) {
               //                alert("Half Day must be less than the Shift End");
               //                return false;
               //            } else
               //                if (shiftEnd >= dayEnd) {
               //                    alert("Shift End must be less than the Day End");
               //                    return false;
               //                }

               // helper function, eats in all the shift times
               // and spits out the total number of hours for the shift
               function countHours(earlyTime, startTime, lateTime, halfDay, shiftEnd, dayEnd) {

                   // helper
                   function getString(i) {
                       return (i < 10) ? "0" + i : "" + i;
                   }

                   // populate all possible minutes
                   allPossibleMinutes = [];
                   for (i = 0; i <= 23; i++) {
                       for (j = 0; j <= 59; j++) {
                           str = getString(i) + getString(j);
                           allPossibleMinutes[allPossibleMinutes.length] = str;
                       }
                   }

                   index = 0;
                   // set the index to that of 
                   // the earlyTime in the array.
                   for (var i = 0; i < allPossibleMinutes.length; i++) {
                       if (allPossibleMinutes[i] === convertTo24(earlyTime)) {
                           index = i;
                           break;
                       }
                   }



                   // Now that we have the pointer set to 
                   // the early time, we will iterate through the
                   // list to find out the next time, which is startTime
                   // and meanwhile we will count the minutes.
                   totalMinutes = 0;
                   while (allPossibleMinutes[index] != convertTo24(startTime)) {

                       index = (index + 1) % allPossibleMinutes.length;
                       totalMinutes++;
                   }


                   // Our pointer is now at shiftStart
                   // Lets keep iterating to our next time which is
                   // lateTime
                   while (allPossibleMinutes[index] != convertTo24(lateTime)) {
                       //console.log()
                       index = (index + 1) % allPossibleMinutes.length;
                       totalMinutes++;
                   }

                   // Our pointer is now at lateTime
                   // Lets keep iterating to our next time which is
                   // halfDay
                   while (allPossibleMinutes[index] != convertTo24(halfDay)) {
                       //console.log()
                       index = (index + 1) % allPossibleMinutes.length;
                       totalMinutes++;
                   }

                   // Our pointer is now at halfDay
                   // Lets keep iterating to our next time which is
                   // shiftEnd
                   while (allPossibleMinutes[index] != convertTo24(shiftEnd)) {
                       //console.log()
                       index = (index + 1) % allPossibleMinutes.length;
                       totalMinutes++;
                   }

                   // Our pointer is now at shiftEnd
                   // Lets keep iterating to our next time which is
                   // dayEnd

                   while (allPossibleMinutes[index] != convertTo24(dayEnd)) {
                       //console.log()
                       index = (index + 1) % allPossibleMinutes.length;
                       totalMinutes++;
                   }


                   return totalMinutes / 60;
               }

               var totalHours = countHours(earlyTime, startTime, lateTime, halfDay, shiftEnd, dayEnd);
               if (totalHours < 24.0 && totalHours >0) {
                   return true;
               } else {

                   var message = "ERROR:\nTotal shift time cannot exceed 24 hours.\nThe current shift starts from "+earlyTime+" and ends at "+dayEnd+".\nWith a total time of "+totalHours+" hours.";
                   alert(message);
                   return false;
               }
           }

            $(document).ready(function () {
                $('#accordion').accordion("option", "active", 2);
                setActiveLink("Manage Shift");
                $("input[type=submit], button").button();
                initDataTable("#shifts_table");




                setupTableExportButton('#shifts_table', '#btnExport', 'ManageShifts');

                /*
                $('#btnExport').button();
                $("#btnExport").click(function (e) {
                    $('#shifts_table').tableExport({ type: 'excel', escape: 'false' });
                    e.preventDefault();
                });
                */


                deleteShift = initDeleteShiftModal('@Url.Action("DeleteShift", "ShiftManagement", null, Request.Url.Scheme)');
                editShift = initEditShiftModal('@Url.Action("EditShift", "ShiftManagement", null, Request.Url.Scheme)');


                $('#mngshift_form').on("submit", function (e) {
                    if (!checkShift('#mngshift_form')) {
                        e.preventDefault();
                    }
                });


            });
           
            $('.timepicker').timepicki();
            
          
        </script>
    }
