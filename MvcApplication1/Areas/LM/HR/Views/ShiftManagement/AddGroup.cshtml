@model ViewModels.CreateGroup
    <h4 style="font-weight: bold;">Shift Management</h4>
    <div class="row">
        <div class="form-group col-md-3">
            <h5 style="font-weight: bold;">Add Group</h5>
@using (Html.BeginForm("AddGroup", "ShiftManagement"))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary()
            <form>
                <div class="row">

                    <div class="col-md-12">
                        <label class="control-label">Group Name</label>
                        <input type="text" class="form-control" name="group_name" id="gname" >
                    </div>
                </div>
                <div class="row">

                    <div class="col-md-12">
                        <label class="control-label">Supervisor</label>
                        <select class="chzn-select" name="employee_id" style="width:100%;">
                            <option selected="selected" disabled="disabled" value="0">Select Supervisor</option>
                            @foreach (ViewModels.Employee item in Model.supervisor)
                            {
                                <option value="@item.id">@item.first_name</option>
                            }
                        </select>

                    </div>
                </div>
                <div class="row">

                    <div class="col-md-12">
                        <label class="control-label">Description</label>
                        <textarea class="form-control" name="group_description" id="gdescription"></textarea>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12" style="margin-top:5px">
                        <button type="submit" value="Submit">Register</button>
                        <button type="reset" value="Reset">Reset</button>
                    </div>
                </div>
            </form>
}
        </div>

    </div>


    @section JS {
        <script>
            $(document).ready(function () {
                $('#accordion').accordion("option", "active", 2);

                $(".chzn-select").chosen();
                $("input[type=submit], button").button();

            });



        </script>
    }
