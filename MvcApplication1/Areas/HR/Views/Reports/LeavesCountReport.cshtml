    //BLL.PdfReports.LeavesTypesTitles leavesTitles = new BLL.PdfReports.LeavesTypesTitles();
    LTCS = leavesTitles.getLeavesTypesCountsStatus();
    if (LTCS != null && LTCS.Contains(','))
