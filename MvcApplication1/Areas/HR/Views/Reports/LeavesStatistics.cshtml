@{
    ViewBag.Title = "TRMS - Leave Statistics";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

@model List<ViewModels.LeaveApplicationInfo>

<style>
    .b_absent {
        border: 1px solid red;
        border-radius: 10px;
        background-color: #fff;
        padding: 5px;
    }


    .b_sick {
        border: 1px solid #52b1aa;
        border-radius: 10px;
        background-color: #edfdfc;
        padding: 5px;
    }

    .b_casual {
        border: 1px solid #7266ba;
        border-radius: 10px;
        background-color: #e6e4f7;
        padding: 5px;
    }


    .b_annual {
        border: 1px solid #f25350;
        border-radius: 10px;
        background-color: #ffe5e5;
        padding: 5px;
    }

    .b_other {
        border: 1px solid #f25350;
        border-radius: 10px;
        background-color: #ffe5e5;
        padding: 5px;
    }
</style>
<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'HR'</span>! [Login ID: <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Reports</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> Leaves Statistics <span class="text-danger">@ViewBag.SelectedEmployeeCode</span></h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="d-none row">
                        <div class="col-4">

                            <form id="attendance-form">
                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">Date From <span class="text-danger font-14">*</span></label>
                                        <input id="from_date" type="text" class="form-control datepicker" autocomplete="off" name="time_in_from" style="background-color: #FFF" required>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Date To <span class="text-danger font-14">*</span></label>
                                        <input id="to_date" type="text" class="form-control datepicker" autocomplete="off" name="time_in_to" style="background-color: #FFF" required>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12">
                                        <button type="submit" id="search-consolidated-report" onclick="clearr();" class="btn btn-primary waves-effect waves-light m-t-10">Search</button>&nbsp;
                                        <button type="submit" id="btn-excel-download" onclick="HideBarr();" class="btn btn-primary waves-effect waves-light m-t-10">Download Excel</button>
                                        <span id="export_wait" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></span>
                                    </div>
                                </div>
                            </form>

                        </div>

                        <div class="form-group col-3">
                        </div>
                        <div class="form-group col-5" style="font-style: italic;">

                        </div>

                    </div>



                    <div id="select_year" class="row">

                        <div class="col-5">

                            <form method="post" action="/HR/Reports/LeavesStatistics">

                                <label class="control-label">Employee Code <span class="text-danger font-14">*</span></label>
                                <select id="monthly-time-sheet-employees" class="form-control" name="employee_id" required>
                                    <!--<option value="28317">002369</option>-->
                                </select>

                                @*<select id="monthly-time-sheet-employees" class="chzn-select w-100" name="employee_id">
                                        chzn-select w-100
                                        <option selected="selected" disabled="disabled" value="0">Select Employee Code</option>
                                        @foreach (ViewModels.Employee item in ViewBag.LMEmployeesList as List<ViewModels.Employee>)
                                        {
                                            <option value="@item.id" @{ if (ViewBag.SelectedEmployeeId != null && ViewBag.SelectedEmployeeId.ToString() == item.id.ToString()) { <text> selected</text> } }>@item.employee_code - @item.first_name @item.last_name</option>
                                        }
                                    </select>*@



                                <label class="control-label m-t-20">Select Session Year <span class="text-danger font-14">*</span></label>
                                <select id="session_year" name="session_year" class="form-control">
                                    @foreach (int i in ViewBag.SessionYearsList as System.Collections.ArrayList)
                                    {
                                        <option value="@i" @{ if (ViewBag.SelectedSessionYear != null && ViewBag.SelectedSessionYear.ToString() == i.ToString()) { <text> selected</text> } }>Session @i</option>
    }
                                </select>

                                <label class="m-t-10">
                                    <button value="Submit" class="btn btn-primary">Search</button>
                                    <button type="button" class="btn btn-primary waves-effect waves-light" onclick="redirectToPage();">Reset</button>
                                </label>

                            </form>


                            <hr />

                            <div height 670px;">

                                <div class="row">
                                    <div class="col-12">
                                        <h3>Leaves List By Date</h3>
                                    </div>
                                </div>


                                @foreach (var item in Model)
                                {
                                    // item.ApproverCode;
                                    string iClassType = "b_sick", iTextStyle = "text-success", iLeaveType = "", iDashes = "", iDays = "";

                                    if (item.LeaveTypeId == 1)
                                    {
                                        iClassType = "b_sick"; iTextStyle = "text-success";
                                        iLeaveType = "Sick Leave"; iDashes = "---";
                                    }
                                    else if (item.LeaveTypeId == 2)
                                    {
                                        iClassType = "b_casual"; iTextStyle = "text-purple";
                                        iLeaveType = "Casual Leave"; iDashes = "---";
                                    }
                                    else if (item.LeaveTypeId == 3)
                                    {
                                        iClassType = "b_annual"; iTextStyle = "text-warning";
                                        iLeaveType = "Annual Leave"; iDashes = "---";
                                    }
                                    else
                                    {
                                        iClassType = "b_other"; iTextStyle = "text-danger";
                                        iLeaveType = "Other Leave"; iDashes = "---";
                                    }

                                    if (item.DaysCount > 1)
                                    {
                                        iDays = "Days";
                                    }
                                    else
                                    {
                                        iDays = "Day";
                                    }

                                    <div class="row p-20">
                                        <div class="col-4 text-primary">
                                            <i class="fa fa-circle m-r-5" style="color: #86bcd0;">&nbsp;</i>@item.FromDate.ToString("dd MMM yyyy")
                                        </div>
                                        <div class="col-6 @iTextStyle">
                                            --- <span class="@iClassType">@iLeaveType</span> @iDashes
                                        </div>
                                        <div class="col-2 text-primary">
                                            @item.DaysCount @iDays
                                        </div>
                                    </div>

                                }



                            </div>

                        </div>
                        <div class="col-1">
                        </div>

                        <div class="col-6">

