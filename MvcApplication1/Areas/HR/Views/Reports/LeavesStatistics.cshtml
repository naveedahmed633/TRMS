                                        <thead>
                                            <tr class="bg-muted">
                                                <th>Leave Type</th>
                                                <th>Leaves Availed</th>
                                                <th>Total</th>
                                            </tr>
                                            <tr>
                                                <td>Sick Leaves</td>
                                                <td>@ViewBag.AvailedSickLeaves</td>
                                                <td>@ViewBag.AllocatedSickLeaves</td>
                                            </tr>
                                            <tr>
                                                <td>Casual Leaves</td>
                                                <td>@ViewBag.AvailedCasualLeaves</td>
                                                <td>@ViewBag.AllocatedCasualLeaves</td>
                                            </tr>
                                            <tr>
                                                <td>Annual Leaves</td>
                                                <td>@ViewBag.AvailedAnnualLeaves</td>
                                                <td>@ViewBag.AllocatedAnnualLeaves</td>
                                            </tr>

