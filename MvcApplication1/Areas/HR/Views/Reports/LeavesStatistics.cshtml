                                                    {
                                                        <tr>
                                                            <td>Other Leaves</td>
                                                            <td>@ViewBag.AvailedOtherLeaves</td>
                                                            <td>@ViewBag.AllocatedOtherLeaves</td>
                                                        </tr>
                                                    }
                                                }
                                            }

                                        </thead>
                                        <tbody></tbody>
                                    </table>

                                </div>
                            </div>



                            <div class="row">
