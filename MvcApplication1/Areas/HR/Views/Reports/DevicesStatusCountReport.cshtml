
@{
    ViewBag.Title = "TRMS - Devices Status Count Report";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}


@using BLL_UNIS.ViewModels
@model IEnumerable<C_office>

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.welcome")  <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span></h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">Device Status with Count</a></li>
                    <li class="breadcrumb-item active">Reports</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.dscr") </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row m-t-10">
                        <div class="col-3">
                            <form id="region-form">
                                <div class="row">
                                    <div class="col-md-12">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.loc") <span class="text-danger font-14">*</span></label>
                                        <select id="device_region_id" name="device_region_id" class="form-control" required>
                                            <option value="-1">-- @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.all") --</option>
                                            @foreach (var item in Model)
                                            {
                                                <option value="@item.c_id">@item.c_name</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        &nbsp;
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <button type="submit" id="search-region-report" class="btn btn-primary btn-sm d-none">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.search")</button>
                                    </div>
                                    <div class="col-md-6">
                                        <input type="button" id="refresh-consolidated-report" class="btn btn-primary d-none" onclick="redirectToPage();" value="Refresh" />
                                    </div>
                                </div>
                            </form>
                        </div>

                        <div class="col-3">
                            <div class="row m-2">
                                <div class="col-md-12 widget-simple-chart text-right card-box" style="background-color: #DCD6ED; border: 1px #7866BA dotted;">
                                    <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.total"):&nbsp;</label>
                                    <span id="lblTotal" class="text-primary">
                                        0
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="col-3">

                            <div class="row m-2">
                                <div class="col-md-12 widget-simple-chart text-right card-box" style="background-color: #E0F1E2; border: 1px #66BB6A dotted;">
                                    <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.connected"):&nbsp;</label>
                                    <span id="lblConnected" class="text-success">
                                        0
                                    </span>
                                </div>
                            </div>

                        </div>



                        <div class="col-3">



                            <div class="row m-2">
                                <div class="col-md-12 widget-simple-chart text-right card-box" style="background-color: #FBDDDE; border: 1px #EE6E73 dotted;">
                                    <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.disconnected"):&nbsp;</label>
                                    <span id="lblDisConnected" class="text-danger">
                                        0
                                    </span>
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <span id="lblMessage" class="text-success h3"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            &nbsp;
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <table id="device_status_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 160%;">
                                <thead>
                                    <tr>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.id")</th>
                                        <!--<th>Last Online</th>-->
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.loc")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.devicename")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.ipadd")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.devicestatus")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.region")</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" class="btn btn-primary btn-sm">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exportgrid")</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- End content -->

