@{
    ViewBag.Title = "TRMS - Consolidated Attendance";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}
<meta http-equiv="X-UA-Compatible" content="IE=IE8" >
<meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.welcome")  <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span></h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Reports</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.paar") </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-4">

                            <form id="consolidate-form">
                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.empcode") <span class="text-danger font-14">*</span></label>
                                        <select id="consolidated-employees" class="form-control" name="employee_id" required></select>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.status")</label>
                                        <select id="_status" class="form-control" name="status" required>
                                            <option value="none">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.none")</option>
                                            <option value="po">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.present")</option>
                                            <option value="ab">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.absent")</option>
                                            <option value="presentlate">Present Late</option>
                                            <option value="earlyout">Early Out</option>
                                            <option value="ple">Present Late Early Out</option>
                                            <option value="both">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.preabboth")</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.datefrom") <span class="text-danger font-14">*</span></label>
                                        <input id="date_from" type="text" class="form-control datepicker" autocomplete="off" name="from_date" required>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.dateto") <span class="text-danger font-14">*</span></label>
                                        <input id="date_to" type="text" class="form-control datepicker" autocomplete="off" name="to_date" required>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12">
                                        <button type="submit" id="search-consolidated-report" onclick="clearr();" class="btn btn-primary waves-effect waves-light m-t-10">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.search")</button>&nbsp;
                                        <button type="button" class="btn btn-primary waves-effect waves-light m-t-10" onclick="redirectToPage();">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.reset")</button>
                                    </div>
                                </div>
                            </form>

                        </div>

                        <div class="form-group col-3">
                        </div>
                        <div class="form-group col-5" style="font-style: italic;">
                            <h4>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.legend"):</h4>
                            <table style="line-height: 16px; width: 70%;">
                                <tr><td style="width: 20%"></td><td style="width: 10%"></td><td style="width: 70%"></td></tr>
                                <tr><td>AB</td><td>:</td><td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.absent")</td></tr>
                                <tr><td>PO</td><td>:</td><td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.PO")</td></tr>
                                <tr><td>PLE</td><td>:</td><td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.PLE")</td></tr>
                                <tr><td>POE</td><td>:</td><td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.POE")</td></tr>
                                <tr><td>PLM</td><td>:</td><td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.PLM")</td></tr>
                                <tr><td>*</td><td>:</td><td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.manualupdate")</td></tr>
                            </table>
                        </div>

                    </div>


                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="panel-body">
                    <div class="row">
                        <div class="col-12">
                            <table id="attendance_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 120%;">
                                <thead>
                                    <tr>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.date")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.empcode")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.fname")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.lname")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.timein")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.remarks")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.timeout")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.remarks")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.fremarks")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.devicein")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.deviceout")</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" onclick="ExortExcleBar();" class="btn btn-primary waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exportgrid")</button>
                            @*<button type="submit" id="btn-excel-download" form="consolidate-form" onclick="ExcleHide();" class="btn btn-primary waves-effect waves-light">Download Excel</button>*@
                            <span id="export_wait" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></span>
                            <span id="demo" class="text-danger"></span>
                            <p id="export_wait2" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- End content -->

