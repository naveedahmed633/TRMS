@{
    ViewBag.Title = "TRMS - Organization Attendance Report";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

@{
    //Present - Leave - Absent
    string pr_chart_color_a = "#66bb6a ", pr_chart_color_b = "#7266ba", pr_chart_color_c = "#ee6e73";
    //Ontime - Late - Earlyout
    string pn_chart_color_d = "#29b6f6", pn_chart_color_e = "#ffc107", pn_chart_color_f = "#f76397", pn_chart_color_g = "#FFFF6F";
}
<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.welcome")  <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span></h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Reports</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="mdi mdi-chart-bar"></i> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.oar") </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-4" id="consolidate-form">

                            @using (Html.BeginForm("DepartmentAttendanceReport", "Reports", FormMethod.Post, new { id = "department-attendance-form" }))
                            {
                                <input type="hidden" id="imgeData" name="imageData" value="" />

                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.datefrom") <span class="text-danger font-14">*</span></label>
                                        <input id="date_from" type="text" class="form-control datepicker" name="from_date" autocomplete="off" required>@*value="@DateTime.Now.ToString("01-MM-yyyy")"*@
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.dateto") <span class="text-danger font-14">* (@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.tillyesterday"))</span></label>
                                        <input id="date_to" type="text" class="form-control datepicker" name="to_date" autocomplete="off" required>  @*value="@DateTime.DaysInMonth(DateTime.Now.Year, DateTime.Now.Month).ToString()@DateTime.Now.ToString("-MM-yyyy")"*@
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.depname") <span class="text-danger font-14">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.searchbyname")</span></label>
                                        <select id="consolidated-department" class="form-control" name="department_id"></select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.desname")<span class="text-danger font-14">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.searchbyname")</span></label>
                                        <select id="consolidated-designation" class="form-control" name="designation_id"></select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.locname") <span class="text-danger font-14">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.searchbyname")</span></label>
                                        <select id="consolidated-location" class="form-control" name="location_id"></select>
                                    </div>
                                </div>


                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.userfunc") <span class="text-danger font-14">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.stdlecsta")</span></label>
                                        <select id="consolidated-function" class="form-control" name="function_id"></select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.stdgrp") <span class="text-danger font-14">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.ab")</span></label>
                                        <select id="consolidated-region" class="form-control" name="region_id"></select>
                                    </div>
                                </div>



                                <div class="row">
                                    <div class="col-12 text-danger">
                                        @Html.AntiForgeryToken()
                                        @Html.ValidationSummary()
                                    </div>
                                </div>

                                <div class="row">

                                    <button type="submit" id="search-department-report" onclick="clearr();" class="btn btn-primary waves-effect waves-light m-t-10">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.search")</button>&nbsp;
                                    <button type="button" id="refresh-department-report" class="btn btn-primary waves-effect waves-light m-t-10" onclick="redirectToPage();">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.reset")</button>
                                    @*<button type="submit" id="btn-excel-download" onclick="ExcleHide();" class="btn btn-primary waves-effect waves-light m-t-10">Download Excel</button>
                                        <span id="export_wait" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></span>*@


                                </div>

                                <div class="row">
                                    <div class="col-6">


                                    </div>
                                    <div class="col-6" style="display:none">
                                        <button id="btn-excel-download" class="btn btn-primary waves-effect waves-light m-t-10" onclick="ExportExcelBar()">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.downloadexcel")</button>
                                        <span id="export_wait_excel" style="display: none;"><img src='/images/loader.gif' style='width: 110px' alt='processing' /></span>
                                    </div>
                                </div>
                            }

                        </div>



                        <div class="col-8" id="boundary">

                            <div class="row">
                                <div class="col-6">
                                    <!-- Donut Chart - 1 -->
                                    <div id="chartPresence">
                                        <h4 class="m-t-0 header-title text-center">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.presencestatus")</h4>
                                        <svg id="svgChartPresence" style="height:300px;width:100%"></svg>
                                    </div>

                                </div>

                                <div class="col-6">
                                    <!-- Donut Chart - 2 -->
                                    <div id="chartPunctuality">
                                        <h4 class="m-t-0 header-title text-center">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.puncstatus")</h4>
                                        <svg id="svgChartPunctuality" style="height:300px;width:100%"></svg>
                                    </div>

                                </div>
                            </div>

                            <div class="row">
                                <div class="col-12 text-center">
                                    <!-- Donut Chart - 1 -->
                                    <div id="chartExit">
                                        <h4 class="m-t-0 header-title text-center">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exitstatus")</h4>
                                        <svg id="svgChartExit" style="height:300px;width:100%"></svg>
                                    </div>

                                </div>

                            </div>

                        </div>


                    </div>



                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="panel-body">
                    <div class="row">
                        <div class="col-12">
                            <table id="attendance_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.id")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.empcode")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.fname")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.lname")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.presentpercent")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.leavepercent")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.absentpercent")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.ontimepercent")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.latepercent")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exitpercent")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.earlyoutpercent")</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" onclick="ExortExcleBar();" class="btn btn-primary waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exportgrid")</button>
                            <button type="submit" id="btn-pdf-download" form="department-attendance-form" onclick="ExportPDFBar()" class="btn btn-primary waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exportpdf")</button>
                            <span id="export_wait_pdf" style="display: none;"><img src='/images/loader.gif' style='width: 110px' alt='processing' /></span>
                            <br /><span id="pdf-no-data-found">@ViewData["PDFNoDataFoundDept"]</span>
                            <span id="demo" class="text-danger"></span>
                            <p id="export_wait2" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- End content -->
@section JS {
    @*<script src="~/Scripts/zingchart.min.js"></script>*@
    <script type="text/javascript" src="@Href("~/Scripts/chosen.ajaxaddition.jquery.js")"></script>
    @*<script type="text/javascript" src="@Href("~/Scripts/monthpicker.js")"></script>*@
    <script src="~/Scripts/html2canvas.js"></script>

    <script type="text/javascript">

        function loadChart(a, b, c, d, e, f, g) {

            (function ($) {
                'use strict';

                //Donut chart1
                nv.addGraph(function () {
                    var chart = nv.models.pieChart()
                        .x(function (d) { return d.label })
                        .y(function (d) { return d.value })
                        .showLabels(true)     //Display pie labels
                        .labelThreshold(.05)  //Configure the minimum slice size for labels to show up
                        .labelType("percent") //Configure what type of data to show in the label. Can be "key", "value" or "percent"
                        .donut(true)          //Turn on Donut mode. Makes pie chart look tasty!
                        .donutRatio(0.35)     //Configure how big you want the donut hole size to be.

                    ;

                    d3.select("#chartExit svg")
                        .datum(ExitChartData())
                        .transition().duration(350)
                        .call(chart);

                    return chart;
                });
                //Donut chart2
                nv.addGraph(function () {
                    var chart = nv.models.pieChart()
                        .x(function (d) { return d.label })
                        .y(function (d) { return d.value })
                        .showLabels(true)     //Display pie labels
                        .labelThreshold(.05)  //Configure the minimum slice size for labels to show up
                        .labelType("percent") //Configure what type of data to show in the label. Can be "key", "value" or "percent"
                        .donut(true)          //Turn on Donut mode. Makes pie chart look tasty!
                        .donutRatio(0.35)     //Configure how big you want the donut hole size to be.

                    ;

                    d3.select("#chartPunctuality svg")
                        .datum(PunctualityChartData())
                        .transition().duration(350)
                        .call(chart);

                    //                  var positionX = 300;
                    //                  var positionY = 40;
                    //                  var verticalOffset = 25;

                    //                  d3.select(".nv-legendWrap")
                    //.attr("transform","translate(0,350)")

                    //d3.selectAll('.nv-legend .nv-series')[0].forEach(function(d) {
                    //    positionY += verticalOffset;
                    //    d3.select(d).attr('transform', 'translate(' + positionX + ',' + positionY + ')');
                    //});

                    return chart;
                });
                //Donut chart3
                nv.addGraph(function () {
                    var chart = nv.models.pieChart()
                        .x(function (d) { return d.label })
                        .y(function (d) { return d.value })
                        .showLabels(true)     //Display pie labels
                        .labelThreshold(.05)  //Configure the minimum slice size for labels to show up
                        .labelType("percent") //Configure what type of data to show in the label. Can be "key", "value" or "percent"
                        .donut(true)          //Turn on Donut mode. Makes pie chart look tasty!
                        .donutRatio(0.35)     //Configure how big you want the donut hole size to be.

                    ;

                    d3.select("#chartPresence svg")
                        .datum(PresenceChartData())
                        .transition().duration(350)
                        .call(chart);

                    return chart;
                });

                //Pie chart data
                function ExitChartData() {
                    return [
                        {
                            "label": "Exit",
                            "value": f,
                            "color": "@pn_chart_color_g" //"#29b6f6"
                        },
                        {
                            "label": "Early Out",
                            "value": g,
                            'color': "@pn_chart_color_f" //'#ffc107'
                        }
                        @*,{
                            "label": "Early Out",
                            "value": f,
                            'color': "@pn_chart_color_f" //'#f76397'
                        }*@


                    ];
                }
                function PunctualityChartData() {
                    return [
                        {
                            "label": "On Time",
                            "value": d,
                            "color": "@pn_chart_color_d" //"#29b6f6"
                        },
                        {
                            "label": "Late",
                            "value": e,
                            'color': "@pn_chart_color_e" //'#ffc107'
                        }
                        @*,{
                            "label": "Early Out",
                            "value": f,
                            'color': "@pn_chart_color_f" //'#f76397'
                        }*@


                    ];
                }
                function PresenceChartData() {
                    return [
                        {
                            "label": "Present",
                            "value": a,
                            "color": "@pr_chart_color_a" //"#66bb6a"
                        },
                        {
                            "label": "Leave",
                            "value": b,
                            'color': "@pr_chart_color_b" //'#7266ba'
                        },
                        {
                            "label": "Absent",
                            "value": c,
                            'color': "@pr_chart_color_c" //'#ee6e73'
                        }


                    ];
                }
            })(jQuery);
        }

        function ExortExcleBar() {
            $('#export_wait2').show();
            document.getElementById("btnExport").disabled = true;
            HideBarExcle();
            var ss = $("#attendance_table tr").children("td:first").text();
            if (ss == "No data available in table" || ss == "" || ss == " ") { document.getElementById("demo").innerHTML = "No Data Found."; }
            else { DownloadExcleCsv(); }
        }

        function DownloadExcleCsv() { setupTableExportButton('#attendance_table', 'DepartmentAttendanceReport'); }

        function HideBarExcle() {
            setTimeout(function () { $('#export_wait2').hide(); document.getElementById("btnExport").disabled = false; document.getElementById("demo").innerHTML = ""; }, 1500);
        }
        function redirectToPage() {
            window.location = '/HR/Reports/DepartmentAttendanceReport';
            //window.location.reload();
        }

        function searchReport() {




            // get the entered string
            var toSearch = $('attendance_table_filter input').val();

            $('#attendance_table').DataTable().search(toSearch);
            $('#attendance_table').DataTable().draw();
            ChartToImage();


        }
        $("#department-attendance-form").submit(function (e) {

            document.getElementById("btn-pdf-download").disabled = true;
            document.getElementById("btn-excel-download").disabled = true;
            return true;
        });

        function ExportExcelBar() {

            var FromDate = $('#date_from').val();
            var ToDate = $('#date_to').val();

            if (ToDate == "" || ToDate == null || FromDate == "" || FromDate == null) {

                validate_data();
            }
            else {
                $('#export_wait_excel').show(); //$('#export_wait_pdf').hide();

                document.getElementById("btn-pdf-download").disabled = true;
                HideBarPDF();
                HideMessage();
                //$('#export_wait_pdf').hide();
            }
        }

        function ExportPDFBar() {

            var FromDate = $('#date_from').val();
            var ToDate = $('#date_to').val();

            if (ToDate == "" || ToDate == null || FromDate == "" || FromDate == null) {

                validate_data();
            }
            else {
                $('#export_wait_pdf').show(); //$('#export_wait_excel').hide();
                document.getElementById("btnExport").disabled = true;
                document.getElementById("btn-excel-download").disabled = true;
                HideBarExcel();

                //$('#export_wait_excel').hide();
            }
        }

        function clearr() {
            $('input[type="search"]').focus();
            $('input[type="search"]').val("");
            $('#attendance_table').DataTable().search("");
            $('#attendance_table').DataTable().draw();
            $('input[type="search"]').blur();

            $('input[type="search"]').blur();
            setTimeout(function () { ChartToImage(); }, 2500);

            document.getElementById("btn-excel-download").disabled = false;


        }
        function HideMessage() { setTimeout(function () { $('#export_wait_excel').hide(); $('#pdf-no-data-found').hide(); }, 9000); }


        function HideBarExcel() {
            //alert('hExcel');
            setTimeout(function () { $('#export_wait_pdf').hide(); document.getElementById("btn-pdf-download").disabled = false; document.getElementById("btn-excel-download").disabled = false; document.getElementById("btnExport").disabled = false; }, 2000);
        }

        function HideBarPDF() {
            //alert('hPDF');
            setTimeout(function () { $('#export_wait_excel').hide(); document.getElementById("btn-pdf-download").disabled = false; document.getElementById("btn-excel-download").disabled = false; document.getElementById("btnExport").disabled = false; }, 2000);
        }

        function initReportDataTable(identifier, url, columns) {
            var oTable = $(identifier).DataTable({
                "searchDelay": 2000,
                "scrollY": "300px",
                "serverSide": true,
                "ajax": {
                    "type": "POST",
                    "url": url,
                    "contentType": 'application/json; charset=utf-8',
                    'data': function (data) {

                        data.department_id = $('#consolidated-department').val();
                        data.from_date = $('#date_from').val();
                        data.to_date = $('#date_to').val();
                        data.designation_id = $('#consolidated-designation').val();
                        data.function_id = $('#consolidated-function').val();
                        data.region_id = $('#consolidated-region').val();
                        data.location_id = $('#consolidated-location').val();
                        return data = JSON.stringify(data);
                    }
                },
                "scrollX": true,
                "scrollCollapse": true,
                "processing": true,
                "paging": true,
                "deferRender": true,
                "columns": columns,
                "order": [0, "desc"],
                "ordering": false,
                "iDisplayLength": 9000,
                "aLengthMenu": [[500, 1000, 5000, 9000], [500, 1000, 5000, 9000]]

            });

            oTable.on("draw", function () {
                var keyword = $(identifier + '_filter > label:eq(0) > input').val();
                $(identifier).unmark();
                $(identifier).mark(keyword, {});



                $(identifier + ' tbody tr').click(function (e) {
                    $('tr.row_selected').removeClass('row_selected');
                    $(this).addClass('row_selected');
                });


                //////////////////////////////////////////////////////////////

                //loadChart(20, 30, 50, 10, 90);

                $.ajax({
                    url: "/HR/Reports/DepartmentAttendancePercentage",
                    type: 'POST',
                    contentType: 'application/json',
                    //data: JSON.stringify(obj),
                    success: function (data) {

                        console.log('1: ' + data);

                        if (data.length > 0) {
                            var strMain = data.split(',');

                            var strInner0 = strMain[0].split('=');
                            var strInner1 = strMain[1].split('=');
                            var strInner2 = strMain[2].split('=');
                            var strInner3 = strMain[3].split('=');
                            var strInner4 = strMain[4].split('=');
                            var strInner5 = strMain[5].split('=');
                            var strInner6 = strMain[6].split('=');

                            var present = strInner0[1];
                            var leave = strInner1[1];
                            var absent = strInner2[1];
                            var ontime = strInner3[1];
                            var late = strInner4[1];
                            var out = strInner5[1];
                            var early = strInner6[1];
                            console.log("2: " + present + " : " + leave + " : " + absent + " : " + ontime + " : " + late + " : " + out + " : " + early);

                            //loadChart(20, 30, 50, 10, 90);
                            loadChart(present, leave, absent, ontime, late, out, early);
                        }

                        //present = data.present;
                        //absent = data.dashboardElement.absent;
                        //late = data.dashboardElement.late;
                        //onTime = data.dashboardElement.onTime;
                        //earlyGone = data.dashboardElement.earlyGone;
                        //console.log(present + " " + absent + " " + late + " " + earlyGone + " " + onTime);
                        //loadGraph(present, absent, late, earlyGone, onTime);
                    }
                });


                ///////////////////////////////////////////////////////////


            });




            // set the z-index of the 'processing...' overlay
            // to a great number, so that it may always display
            // on top of the table. Also set the text color
            // to black as it is white by default.
            $(identifier + '_processing').css({
                "z-index": "1000",
                "color": "rgb(0, 0, 0)"
            });


            // initiate search one second after the user
            // stops typing.
            function setSearchDelayOnDataTable(idSelector) {
                // remove all events from the search box
                $(idSelector + '_filter input').off();


                function customDataTableSearch() {

                    // get the entered string
                    var toSearch = $(idSelector + '_filter input').val();

                    // do nothing if the string is null.
                    // I've not tested this, it is just
                    // in case.
                    if (toSearch == null) {
                        return;
                    }

                    // initiate search programatically.
                    $(idSelector).DataTable().search(toSearch).draw();
                }

                // this variable holds the timer
                var timeout;

                // register a keypress on the search box
                $(idSelector + '_filter input').keypress(function () {
                    if (timeout != null) {
                        clearTimeout(timeout);
                        timeout = null;
                    }

                    // timeout set to 1 second.
                    timeout = setTimeout(customDataTableSearch, 1000);
                });

            }

            setSearchDelayOnDataTable(identifier);
        }

        function submitcheck() {

            fDate = $('#consolidate-form').find('[name*="from_date"]').val().split("-").reverse();
            tDate = $('#consolidate-form').find('[name*="to_date"]').val().split("-").reverse();

            fDate = new Date(fDate[0] + "-" + fDate[1] + "-" + fDate[2]);
            tDate = new Date(tDate[0] + "-" + tDate[1] + "-" + tDate[2]);

            if (tDate < fDate) {
                alert("To Date should be greater than From Date.");
                return false;
            }

            searchReport();
            return true;

        }

        function validate_data() {

            fDate1 = $('#consolidate-form').find('[name*="from_date"]').val();
            tDate1 = $('#consolidate-form').find('[name*="to_date"]').val();

            if (fDate1 == "") {
                alert("Please select 'From Date'" + fDate1);
                $('#date_from').focus();
                return false;
            }

            if (tDate1 == "") {
                alert("Please select 'To Date'" + tDate1);
                $('#date_to').focus();
                return false;
            }

            fDate = $('#consolidate-form').find('[name*="from_date"]').val().split("-").reverse();
            tDate = $('#consolidate-form').find('[name*="to_date"]').val().split("-").reverse();

            fDate = new Date(fDate[0] + "-" + fDate[1] + "-" + fDate[2]);
            tDate = new Date(tDate[0] + "-" + tDate[1] + "-" + tDate[2]);

            if (tDate < fDate) {
                alert("To Date should be greater than From Date.");
                return false;
            }

            return true;
        }

        $(document).ready(function () {
