
<h4 style="font-weight: bold;">Configuration Manager</h4>
<div class="row">
    <div class="form-group col-md-3">
        <form>

            
            <div class="row">

                <div class="col-md-12">
                    <label class="control-label">EMS Application Password</label>
                    <input type="password" class="form-control">
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">EMS Database IP</label>
                    <input required pattern="^([0-9]{1,3}\.){3}[0-9]{1,3}$" class="form-control">
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">EMS Database Name</label>
                    <input type="text" class="form-control">
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">EMS Database Username</label>
                    <input type="text" class="form-control">
                </div>
            </div>
            <div class="row">

                <div class="col-md-12">
                    <label class="control-label">EMS Database Password</label>
                    <input type="password" class="form-control">
                </div>
            </div>


            <div class="row">
                <div class="col-md-12" style="margin-top:5px">
                    <button type="submit" value="Submit">Change Password</button>
                </div>
            </div>
        </form>
    </div>

</div>


@section JS {
    <script>
        $(document).ready(function () {
            $('#accordion').accordion("option", "active", 0);
            $("input[type=submit], button").button();
            setActiveLink("Configuration Manager");
        });



    </script>
}
