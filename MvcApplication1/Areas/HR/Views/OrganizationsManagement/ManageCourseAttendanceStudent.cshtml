@{
    ViewBag.Title = "TRMS - Student Courses Attendance Management";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

<style>
    .monthPicker {
        z-index: 1000;
    }
</style>

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'HR'</span>! [Login ID: <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Student Portal</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> Student Courses Attendance Setting - Rare Cases ONLY</h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-12">
                            @using (Html.BeginForm("ManageCourseAttendanceStudent", "OrganizationsManagement", FormMethod.Post, new { id = "monthly-time-sheet-form" }))
                            {
                                <div class="row">
                                    <div class="col-4">
                                        <label class="control-label">Select Month</label>
                                        <select id="monthly-time-sheet-month" class="chzn-select w-100" name="month" required>
                                            <option selected="selected" disabled="disabled" value="0">Month of Year</option>
                                            @{
                                                string s01 = "", s02 = "", s03 = "", s04 = "", s05 = "", s06 = "", s07 = "", s08 = "", s09 = "", s10 = "", s11 = "", s12 = "";
                                                int year = DateTime.Now.Year;
                                                for (int y = year; y >= (year - 3); y--)
                                                {
                                                    if (y == year && DateTime.Now.Month == 1)
                                                    {
                                                        s01 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 2)
                                                    {
                                                        s02 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 3)
                                                    {
                                                        s03 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 4)
                                                    {
                                                        s04 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 5)
                                                    {
                                                        s05 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 6)
                                                    {
                                                        s06 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 7)
                                                    {
                                                        s07 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 8)
                                                    {
                                                        s08 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 9)
                                                    {
                                                        s09 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 10)
                                                    {
                                                        s10 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 11)
                                                    {
                                                        s11 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 12)
                                                    {
                                                        s12 = "selected";
                                                    }

                                                    <option value="@(y + "-01")" @s01>@("Jan - " + y)</option>
                                                    <option value="@(y + "-02")" @s02>@("Feb - " + y)</option>
                                                    <option value="@(y + "-03")" @s03>@("Mar - " + y)</option>
                                                    <option value="@(y + "-04")" @s04>@("Apr - " + y)</option>
                                                    <option value="@(y + "-05")" @s05>@("May - " + y)</option>
                                                    <option value="@(y + "-06")" @s06>@("Jun - " + y)</option>
                                                    <option value="@(y + "-07")" @s07>@("Jul - " + y)</option>
                                                    <option value="@(y + "-08")" @s08>@("Aug - " + y)</option>
                                                    <option value="@(y + "-09")" @s09>@("Sep - " + y)</option>
                                                    <option value="@(y + "-10")" @s10>@("Oct - " + y)</option>
                                                    <option value="@(y + "-11")" @s11>@("Nov - " + y)</option>
                                                    <option value="@(y + "-12")" @s12>@("Dec - " + y)</option>

                                                    s01 = ""; s02 = ""; s03 = ""; s04 = ""; s05 = ""; s06 = ""; s07 = ""; s08 = ""; s09 = ""; s10 = ""; s11 = ""; s12 = "";
                                                }
                                            }

                                        </select>
                                        @*<input id="monthly-time-sheet-month" type="text" name="month" class="form-control monthPicker" autocomplete="off" required />*@
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-4">
                                        <label class="control-label">Student Code</label>
                                        <select id="monthly-time-sheet-employees" class="form-control" name="employee_id" required>
                                            <!--<option value="28317">002369</option>-->
                                        </select>
                                    </div>
                                </div>



                                <div class="row">
                                    <div class="col-12 text-danger">
                                        @Html.AntiForgeryToken()
                                        @Html.ValidationSummary()
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12">
                                        <button type="submit" id="search-consolidated-report" onclick="clearr();" class="btn btn-primary waves-effect waves-light m-t-10">Search</button>
                                        <button type="button" class="btn btn-primary waves-effect waves-light m-t-10" onclick="redirectToPage();">Reset</button>
                                    </div>
                                </div>
                                                }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="panel-body">
                    <div class="row">
                        <div class="col-12">
                            <table id="attendance_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Student Code</th>
                                        <th>Student Name</th>
                                        <th>Schedule Date</th>
                                        <th>Course Code</th>
                                        <th>Remarks</th>
                                        <th>Actions</th>
                                        <th>Last Process By</th>
                                        <th>Process Count</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10 d-none">
                        <div class="col-12">
                            <button type="submit" id="btnExport" onclick="ExortExcleBar();" class="btn btn-primary waves-effect waves-light">Export Grid Data</button>
                            <button type="submit" id="generate-monthly-time-sheet" form="monthly-time-sheet-form" class="btn btn-primary waves-effect waves-light" style="display: @ViewData["PDFDownloadEnabled"];" onclick="return validateFormInfo();">Export PDF</button>
                            <span id="export_wait" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></span><span id="pdf-no-data-found" class="text-danger">@ViewData["PDFNoDataFound"]</span>
                            <span id="demo" class="text-danger"></span>
                            <p id="export_wait2" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <!-- Page-Title -->
    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="row">
                        <div class="col-12 m-b-10">
                            <h3>Manage using 'Upload File'</h3>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-3">
                            <a href="~/Uploads/SampleCourseAttendance.csv">Download Sample File</a>
                        </div>

                        <div class="col-6">
                            &nbsp;
                        </div>

                        <div class="col-3 text-right d-none">
                            @using (Html.BeginForm("DownloadCourseAttendanceCSVFile", "OrganizationsManagement", FormMethod.Post, new { id = "download-form" }))
                            {
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary()

                                <button id="btnDownload" type="submit" value="Submit" class="btn btn-sm btn-default waves-effect waves-light">Download ALL Employees (CSV)</button>

                            }
                        </div>

                    </div>

                    @using (Html.BeginForm("UploadCourseAttendanceCSVFile", "OrganizationsManagement", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary()

                        <div class="row">
                            <div class="col-4">
                                <label class="btn btn-primary" for="my-file-selector">
                                    <input id="my-file-selector" onchange="alertFilename()" type="file" name="file" value="alert" accept=".csv" style="display:none; ">
                                    Click to select file
                                </label>
                                <h3 class="label" id="file-name"></h3>
                            </div>

                            <div class="col-4">
                                <button id="btnUpload" type="submit" value="Submit" class="btn btn-danger waves-effect waves-light">Upload File</button>
                                @if (ViewBag.UpMessage != null && ViewBag.UpMessage.ToString().Contains("Success"))
                                {
                                    <label class="label msg" style="font-size:medium;  color:green;">@ViewBag.UpMessage</label>
                                }
                                else
                                {
                                    <label class="label msg" style="font-size:medium;  color:red;">@ViewBag.UpMessage</label>
                                }
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12">
                                Critical Required Fields:
                                <ul>
                                    <li>Schedule Date (dd/MM/yyyy - WITHIN last 30 days ONLY)</li>
                                    <li>Student Code (11 chars.)</li>
                                    <li>Course Code</li>
                                    <li>Final Remarks Only PO, PLO, PLE, PLM, POE, POM, AB, OFF</li>
                                    <!-- <li>NOTE: Collect such cases required-data by rotating 'Google Sheet' among these students.</li> -->
                                </ul>
                            </div>
                        </div>
                    }




                </div>
            </div>
        </div>
    </div>
</div>

<!-- End content -->
<!-- Custom Modal -->
