@{
    ViewBag.Title = "TRMS - Organization Courses-Enrollment Management";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

@model ViewModels.OrganizationProgramCourseEnrollmentView

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'HR'</span>! [Login ID: <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Student Portal</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="mdi mdi-file-document"></i> Courses-Enrollment Management </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    @using (Html.BeginForm("ManageOrganizationEnrollment", "OrganizationsManagement", FormMethod.Post, new { id = "organization-enrollment-form" }))
                    {
                        <div class="row">

                            <div class="col-4">


                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">General Calendar Year <span class="text-danger font-14">*</span></label>
                                        <select id="general_calendar_id" name="general_calendar_id" class="form-control" required>
                                            @if (Model.list_general_calendar != null)
                                            {
                                                foreach (ViewModels.GeneralCalendarView item in Model.list_general_calendar)
                                                {
                                                    if (item.YearName.ToString() == DateTime.Now.Year.ToString())
                                                    {
                                                        <option value="@item.Id" selected>@item.YearName</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@item.Id">@item.YearName</option>
                                                    }
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Campus <span class="text-danger font-14">*</span></label>
                                        <select id="campus_id" name="campus_id" class="form-control" required>
                                            @if (Model.list_campus != null)
                                            {
                                                foreach (ViewModels.OrganizationCampusView item in Model.list_campus)
                                                {
                                                    <option value="@item.Id">@item.CampusCode</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>


                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Programs <span class="text-danger font-14">*</span></label>
                                        <select id="program_id" name="program_id" class="form-control" required>
                                            @if (Model.list_program != null)
                                            {
                                                foreach (ViewModels.OrganizationProgramView item in Model.list_program)
                                                {
                                                    <option value="@item.Id">@item.ProgramCode</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>

                            </div>


                            <div class="col-4">

                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">Student <span class="text-danger font-14">*</span></label>
                                        <select id="employee_student_id" name="employee_student_id" class="form-control" required>
                                            @if (Model.list_employee != null)
                                            {
                                                foreach (ViewModels.EmployeeView item in Model.list_employee)
                                                {
                                                    <option value="@item.Id">@item.EmployeeCode</option>
                                                }

                                                <option value="1">000000</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Programs Course <span class="text-danger font-14">*</span></label>
                                        <select id="program_course_id" name="program_course_id" class="form-control" required>
                                            @if (Model.list_program_course != null)
                                            {
                                                foreach (ViewModels.OrganizationProgramCourseView item in Model.list_program_course)
                                                {
                                                    <option value="@item.Id">@item.CourseCode</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Enrollment Title <span class="text-danger font-14">*</span></label>
                                        <input id="enrollment_title" name="enrollment_title" type="text" autocomplete="off" class="form-control" />
                                    </div>
                                </div>

                            </div>

                            <div class="col-4">



                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">Enrolled Program Type <span class="text-danger font-14">*</span></label>
                                        <select id="enrolled_program_type_id" name="enrolled_program_type_id" class="form-control">
                                            @if (Model.list_enrolled_type != null)
                                            {
                                                foreach (ViewModels.OrganizationProgramTypeView item in Model.list_enrolled_type)
                                                {
                                                    <option value="@item.Id">@item.ProgramTypeName</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Enrolled Program Type Number <span class="text-danger font-14">*</span></label>
                                        <select id="enrolled_program_type_number" name="enrolled_program_type_number" class="form-control">
                                            <option value="1">01</option>
                                            <option value="2">02</option>
                                            <option value="3">03</option>
                                            <option value="4">04</option>
                                            <option value="5">05</option>
                                            <option value="6">06</option>
                                            <option value="7">07</option>
                                            <option value="8">08</option>
                                            <option value="9">09</option>
                                            <option value="10">10</option>
                                            <option value="11">11</option>
                                            <option value="12">12</option>
                                        </select>
                                    </div>
                                </div>



                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Is Course Failed?</label>
                                        <select id="is_course_failed" name="is_course_failed" class="form-control">
                                            <option value="false">No</option>
                                            <option value="true">Yes</option>
                                        </select>
                                    </div>
                                </div>

                            </div>

                        </div>

                        <div class="row">
                            <div class="col-12">
                                <label><span class="text-danger font-14">&nbsp;*</span> <span class="small">indicates required fields</span></label>
                            </div>
                        </div>

                        <div class="row m-t-10">
                            <div class="col-12 text-danger span_message">
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary()
                                @ViewBag.Message
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12">
                                <button type="submit" id="organization_enrollment" class="btn btn-primary waves-effect waves-light m-t-10">Submit</button>
                                <button type="button" class="btn btn-primary waves-effect waves-light m-t-10" onclick="redirectToPage();">Reset</button>
                                @*<button type="submit" id="btn-excel-download" onclick="HideBarr();" class="btn btn-primary waves-effect waves-light m-t-10">Download Excel</button>
                                    <span id="export_wait" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></span>*@
                            </div>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="panel-body">

                    <h3>List of Students Enrollment in Courses </h3>

                    <div class="row m-t-30">
                        <div class="col-12">
                            <table id="organization_enrollment_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>GC Year</th>
                                        <th>Campus</th>
                                        <th>Program</th>
                                        <th>Student Code</th>
                                        <th>Student Name</th>
                                        <th>Program-Course</th>
                                        <th>Enrollment Title</th>
                                        <th>Type</th>
                                        <th>Type Number</th>
                                        <th>Action</th>
                                        <th>Is Failed?</th>
                                        <th>Create Date</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" onclick="CheckData();" class="btn btn-primary waves-effect waves-light">Export Grid Data</button>
                            <span id="demo" class="text-danger"></span>
                            <p id="export_wait2" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>


    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="panel-body">

                    <div class="row m-t-10">
                        <div class="col-12">
                            <h3>Upload Enrollment using 'CSV File'</h3>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-3">
                            <a href="~/Uploads/SampleEnrollment.csv">Download Sample Enrollment File</a>
                        </div>

                        <div class="col-6">
                            &nbsp;
                        </div>



                    </div>

                    @using (Html.BeginForm("UploadEnrollmentCSVFile", "OrganizationsManagement", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary()

                        <div class="row">
                            <div class="col-6">
                                <label class="btn btn-primary" for="my-file-selector">
                                    <input id="my-file-selector" onchange="alertFilename()" type="file" name="file" value="alert" accept=".csv" style="display:none; ">
                                    Click to select file
                                </label>
                                <h3 class="label" id="file-name"></h3>
                            </div>

                            <div class="col-6">
                                <button id="btnUpload" type="submit" value="Submit" class="btn btn-danger waves-effect waves-light">Upload File</button>
                                @if (ViewBag.UpMessage != null && ViewBag.UpMessage.ToString().Contains("Success"))
                                {
                                    <label class="label msg" style="font-size:medium;  color:green;">@ViewBag.UpMessage</label>
                                }
                                else
                                {
                                    <label class="label msg" style="font-size:medium;  color:red;">@ViewBag.UpMessage</label>
                                }
                            </div>
                        </div>

                    }

                    <div class="row">
                        <div class="col-6">
                            Critical Required Fields:
                            <ul>
                                <li>Current Year Only</li>
                                <li>Proper Campus Code</li>
                                <li>Proper Student Code of that Campus</li>
                                <li>Proper Course Code</li>
                            </ul>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-3 align-top text-right">
                            @using (Html.BeginForm("DownloadEnrollmentCSVFile", "OrganizationsManagement", FormMethod.Post, new { id = "download-form" }))
                            {
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary()

                                <button id="btnDownload" type="submit" value="Submit" class="btn btn-sm btn-default waves-effect waves-light">Download existing enrollment (CSV)</button>

                            }
                        </div>
                    </div>



                </div>
            </div>
        </div>
    </div>


</div>
<!-- End content -->
