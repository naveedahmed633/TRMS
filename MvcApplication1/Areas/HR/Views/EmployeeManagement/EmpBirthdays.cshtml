@{
    ViewBag.Title = "TRMS - Employee Birthdays";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

@Model EMP_BirthdayEvent

<style>
    .even{
        background-color:#c3e6cb ;
    }

     .odd{
        background-color:#ffffff ;
    }

</style>

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.welcome")  <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span></h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">HR</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                @*<img src="~/Content/DisloyalWhoppingCob.gif" style=" margin-bottom: -845px; margin-left: 100px; opacity: 0.1; width: 900px; ">*@
                <div class="panel-body">

                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.bdaylist")</h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-12 m-b-10">
                            <h1 class="m-t-0 header-title"> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.todaybday")</h1>
</div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <table id="emp_table_today" class="table dataTable dt-responsive nowra" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.empcode")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.empname")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.birthdate")</th>
                                        
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.TodayBirthdays != null && Model.TodayBirthdays.Count > 0)
                                    {
                                        int break_count = 0;
                                        int counter = 0, a = 0;
                                        string classTitle = "", className = "table-success";

                                        foreach (var i in Model.TodayBirthdays)
                                        {
                                            if ((counter % 2) == 0)
                                            {
                                                if (a == 0)
                                                {
                                                    className = "table-warning";
                                                    a++;
                                                }
                                                else if (a == 1)
                                                {
                                                    className = "table-info";
                                                    a++;
                                                }
                                                else
                                                {
                                                    className = "table-success";
                                                    a = 0;
                                                }
                                            }
                                            else
                                            {
                                                className = "";
                                            }

                                            <tr class="@className">
                                                <th scope="row">@i.employee_code</th>
                                                <td>@i.first_name</td>
                                                <td>@i.date_of_birth</td>
                                               
                                            </tr>

                                            counter++;
                                            break_count++;
                                           
                                        }
                                    }
                                    else
                                    {
                                        <tr class="">
                                            <td colspan="4" class="text-danger">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.nodata")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <hr>

                <div class="panel-body">

                    <div class="row">
                        <div class="col-12 m-t-20 m-b-10">
                            <h1 class="m-t-0 header-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.upcomingbday")</h1>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <table id="emp_table_upcoming" class="table dataTable dt-responsive nowra" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.empcode")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.empname")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.birthdate")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.UpcomingBirthdays != null && Model.UpcomingBirthdays.Count > 0)
                                    {
                                        int break_count = 0;
                                        int counter = 0, a = 0;
                                        string classTitle = "", className = "table-success";

                                        foreach (var i in Model.UpcomingBirthdays)
                                        {
                                            if ((counter % 2) == 0)
                                            {
                                                if (a == 0)
                                                {
                                                    className = "table-success";
                                                    a++;
                                                }
                                                else if (a == 1)
                                                {
                                                    className = "table-info";
                                                    a++;
                                                }
                                                else
                                                {
                                                    className = "table-warning";
                                                    a = 0;
                                                }
                                            }
                                            else
                                            {
                                                className = "";
                                            }

                                            <tr class="@className">
                                                <th scope="row">@i.employee_code</th>
                                                <td>@i.first_name</td>
                                                <td>@i.date_of_birth</td>
                                              
                                            </tr>

                                            counter++;
                                            break_count++;

                                        }
                                    }
                                    else
                                    {
                                        <tr class="">
                                            <td colspan="4" class="text-danger">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.nodata")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>



<!-- End content -->


<div id="MidTermModal" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="MidTermModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                <h4 class="modal-title" id="CenterModalLabel">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.view")</h4>
            </div>
            <div class="modal-body text-center">
                <img id="image_source" src="~/Images/no-image.png" width="300" />

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary waves-effect" data-dismiss="modal">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.close")</button>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div>

<!-- Custom Modal -->
<div class="modal fade bs-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="mySmallModalLabel" aria-hidden="true" style="display: none;">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                <h4 class="modal-title" id="mySmallModalLabel">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.msgalert")</h4>
            </div>
            <div class="modal-body">
                <span id="alert_message"></span>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->


<div id="toast" class="toast-message" style='display:none'>Message!</div>

