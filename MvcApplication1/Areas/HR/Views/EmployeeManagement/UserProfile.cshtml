<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'HR'</span>! [Login ID: <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Employee Portal</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-xl-3 col-lg-4">
            <div class="text-center card-box">
                <div class="member-card">
                    <div class="thumb-xl member-thumb m-b-10 center-block">
                        @if (Model.emp_vm.photograph != null && Model.emp_vm.photograph.ToString() != "")
                        {
                            <img src="/Content/UserDocs/@Model.emp_vm.photograph" class="rounded-circle img-thumbnail" alt="profile-image">
                        }
                        else
                        {
                            <img src="/images/users/user.png" class="rounded-circle img-thumbnail" alt="profile-image">
                        }

                    </div>

                    <div class="">
                        <h3 class="m-b-5">@Model.emp_vm.first_name @Model.emp_vm.last_name</h3>
                        @if (Model.emp_vm.access_group_id == 1)
                        {
                            <p class="text-muted h4">User Type: HR</p>
                        }
                        else if (Model.emp_vm.access_group_id == 2)
                        {
                            <p class="text-muted h4">User Type: LM</p>
                        }
                        else if (Model.emp_vm.access_group_id == 3)
                        {
                            <p class="text-muted h4">User Type: EMP</p>
                        }
                        else if (Model.emp_vm.access_group_id == 4)
                        {
                            <p class="text-muted h4">User Type: SLM</p>
                        }
                        else
                        {
                            <p class="text-muted h4">User Type: N/A</p>
                        }

                    </div>

                    <!--<button type="button" class="btn btn-success btn-sm w-sm waves-effect m-t-10 waves-light">Print Profile</button>
                    <button type="button" class="btn btn-danger btn-sm w-sm waves-effect m-t-10 waves-light" style="display: none;">Deactivate</button>-->


                    <div class="text-left m-t-40">
                        <p class="text-muted font-13"><strong>First Name:</strong> <span class="m-l-15">@Model.emp_vm.first_name</span></p>

                        <p class="text-muted font-13"><strong>Last Name:</strong> <span class="m-l-15">@Model.emp_vm.last_name</span></p>

                        <p class="text-muted font-13"><strong>Doc. No.:</strong> <span class="m-l-15">@Model.emp_vm.cnic_no</span></p>

                        <p class="text-muted font-13"><strong>Mobile:</strong><span class="m-l-15">@Model.emp_vm.mobile_no</span></p>

                        <p class="text-muted font-13"><strong>Email:</strong> <span class="m-l-15">@Model.emp_vm.email</span></p>

                    </div>

                    <ul class="social-links list-inline m-t-30">
                        <li class="list-inline-item">
                            <a title="" data-placement="top" data-toggle="tooltip" class="tooltips" href="" data-original-title="Facebook"><i class="fa fa-facebook"></i></a>
                        </li>
                        <li class="list-inline-item">
                            <a title="" data-placement="top" data-toggle="tooltip" class="tooltips" href="" data-original-title="Twitter"><i class="fa fa-twitter"></i></a>
                        </li>
                        <li class="list-inline-item">
                            <a title="" data-placement="top" data-toggle="tooltip" class="tooltips" href="" data-original-title="Skype"><i class="fa fa-skype"></i></a>
                        </li>
                    </ul>

                </div>

            </div> <!-- end card-box -->

