    @section JS {
        <script>
            $(document).ready(function () {

                var empCode = @Html.Raw(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId);

                $.ajax({
                    url: '/HR/HR/VerfiyDataHandler',
                    type: "POST",
                    data: { empId: empCode },
                    dataType: "json",

                    success: function (data) {

                        if (data.HRDownloadExcel == false) {
                            $("#btn-excel-download").hide();
                        }
                        if (data.HRExportGridData == false) {
                            $("#btnExport").hide();
                        }
                        if (data.HRExportPDF == false) {
                            $("#btn-pdf-download").hide();
                        }

                    },
                    error: function () {
                        alert("error");
                    }
                });




                var present =  @Html.Raw(Json.Encode(Model.emp_vm.g_skills_set));
                present = present.replace(/,/g, '<hr>');
                console.log(present);
                $("#Skill_Sets").html(present);

            });

            popup = function viewImage(image_name) {
                $('#image_source').attr("src", "/Content/UserDocs/" + image_name);
                $('#MidTermModal').modal('show');
            }

        </script>
    }
