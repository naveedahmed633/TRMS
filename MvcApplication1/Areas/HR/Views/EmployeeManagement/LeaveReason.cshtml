@{
    ViewBag.Title = "TRMS - Leave Reasons Management";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.welcome")  <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span></h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Leaves</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.reasonsman") </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    @using (Html.BeginForm("LeaveReason", "EmployeeManagement", FormMethod.Post, new { id = "employee-form"}))
                    {
                      
                        <div class="row">
                            <div class="col-4">
                              
                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.reason") <span class="text-danger font-14">*</span></label>
                                        <input type="text" class="form-control" name="LeaveReasonText" autocomplete="off" required />
                                    </div>
                                </div>
                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <input type="checkbox" class="control-label" id="isactive" name="isactive">
                                        <label class="control-label" for="customCheck2">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.isactive")</label>
                                    </div>
                                </div>


                            </div>
                        </div>

                        <div class="row m-t-10">
                            <div class="col-12 text-danger">
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary()
                                @if (Request.QueryString["Message"] != null && Request.QueryString["Message"].ToString() == "success")
                                {
                                    <div class="row">
                                        <div class="col-12">
                                            <span class="span_message">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.successmsg")</span>
                                        </div>
                                    </div>
                                }
                                @if (Request.QueryString["Message"] != null && Request.QueryString["Message"].ToString() == "already")
                                {
                                    <div class="row">
                                        <div class="col-12">
                                            <span class="span_message">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.errmsg1")</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary waves-effect waves-light m-t-10">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.add")</button>
                                <button type="button" class="btn btn-primary waves-effect waves-light m-t-10" onclick="redirectToPage();">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.reset")</button>
                            </div>
                        </div>
                    }



                </div>
            </div>
        </div>

    </div>
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    

                    <div class="row">
                        <div class="col-12 m-b-10">
                            <h3>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.currentlist")</h3>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <table id="leaveReason_table" class="table table-striped table-bordered dataTable dt-responsive no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.id")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.reason")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.status")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.action")</th>

                                    </tr>
                                </thead>

                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" class="btn btn-primary waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exportgrid")</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>
<div id="moll">
</div>
<div id="toast" class="toast-message" style='display:none'>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.msg")</div>

<!-- Custom Modal -->
<div class="modal fade bs-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="mySmallModalLabel" aria-hidden="true" style="display: none;">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                <h4 class="modal-title" id="mySmallModalLabel">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.msgalert")</h4>
            </div>
            <div class="modal-body">
                <span id="alert_message"></span>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->



@section JS {
    <script type="text/javascript" src="@Href("~/Scripts/chosen.ajaxaddition.jquery.js")"></script>
    <script src="@Url.Content("/Scripts/leaveReasonCRUD.js")" type="text/javascript"></script>
    <script>
        $(document).ready(function () {

            var empCode2= @Html.Raw(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId);

            $.ajax({
                url: '/HR/HR/VerfiyDataHandler',
                type: "POST",
                data: { empId: empCode2 },
                dataType: "json",

                success: function (data) {
                    if (data.HRExportGridData == false) {
                        $("#btnExport").hide();
                    }
                    
                 
                },
                error: function () {
                    alert("error");
                }
            });

            $("#btnExport").click(function (e) {
                setupTableExportButton('#leaveReason_table', 'Leave-Reason');
                e.preventDefault();
            });

            HideSpanMessage();

        });

        function redirectToPage() {
            window.location = '/HR/EmployeeManagement/LeaveReason';
            //alert('abc');
            //window.location.reload();
        }

        function HideSpanMessage() {
            setTimeout(function () { $('.span_message').hide(); }, 3000);
        }

        $("#isactive").change(function () {
            if ($(this).prop("checked")) {
                $(this).val(true);
            } else {
                $(this).val(false);
            }
        });
    

       
        var url = '@Url.Action("LeaveReasonDataHandler", "EmployeeManagement", null, Request.Url.Scheme)';

        var columns = [
                  { "data": "Id" },
                  { "data": "LeaveReasonText" },
                  { "data": "setActive" },
                  { "data": "actions" },


        ];
        initServerSideTable('#leaveReason_table', url, columns, 25);//10, 25, 50, 100, 500, 1000, 1500
        editLeaveReason = initEditLeaveReason("#moll", '@Url.Action("UpdateLeaveReason", "EmployeeManagement", null, Request.Url.Scheme)', "LeaveReason");
        deleteLeaveReason = initDeleteModal("#moll", '@Url.Action("RemoveLeaveReason", "EmployeeManagement", null, Request.Url.Scheme)', "LeaveReason");

    </script>
}
