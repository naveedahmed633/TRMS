@{
    ViewBag.Title = "TRMS - UNIS User Management";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}


<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.welcome")  <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span></h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Employee Portal</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card-box">

                <div class="panel-body">


                    <div class="row">
                        <div class="col-12 m-b-10">
                            <h3>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.unisusers")</h3>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12">
                            <table id="region_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        @*<th>ID</th>*@
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.name")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.empcode")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.actions")</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <ul id="itemList"></ul>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" class="btn btn-primary waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exportgrid")</button>
                            <button type="submit" id="btnAdd" onclick="AddUser()" class="btn btn-primary waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.addusers")</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>
<!-- End content -->
@section JS {
    <script>
        $(document).ready(function () {
            var empCode2= @Html.Raw(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId);

            $.ajax({
                url: '/HR/HR/VerfiyDataHandler',
                type: "POST",
                data: { empId: empCode2 },
                dataType: "json",

                success: function (data) {
                    if (data.HRExportGridData == false) {
                        $("#btnExport").hide();
                    }



                },
                error: function () {
                    alert("error");
                }
            });
            //$('#btnExport').button();
            $("#btnExport").click(function (e) {
                setupTableExportButton('#region_table', 'UnisUserList');
                e.preventDefault();
            });


            var url = '@Url.Action("UNISUserAddDataHandler", "EmployeeManagement", null, Request.Url.Scheme)';

            var columns = [
                 // { "data": "id" },
                  { "data": "name" },
                  { "data": "empCode" },
                  { "data": "actions" }
            ];

            initServerSideTable('#region_table', url, columns);//10, 25, 50, 100, 500, 1000, 1500


            // AddUser = Add_User("#modals", '@Url.Action("UpdateRegion", "EmployeeManagement", null, Request.Url.Scheme)', "Region");

        });
        var object = [];
        function AddUser()
        {
            if (object != "") {


                $.ajax({
                    url: '/HR/EmployeeManagement/AddUNISUserAdd',
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify({ obj : object }),
                    //dataType: "json",

                    success: function (data) {

                        swal(
                            {
                                title: 'User Successfully Added',
                                text: 'To Update User Visit Manage Employees Page!',
                                type: 'success',
                                confirmButtonClass: 'btn btn-confirm mt-2'
                            }
                        )
                        $('#region_table').DataTable().ajax.reload();
                        object = [];

                    },
                    error: function () {
                        swal(
                               {
                                   title: 'User Successfully Added',
                                   text: 'To Update User Visit Manage Employees Page!',
                                   type: 'success',
                                   confirmButtonClass: 'btn btn-confirm mt-2'
                               }
                           )

                        $('#region_table').DataTable().ajax.reload();
                        object = [];
                    }
                });
            }
            else {
                swal(
                               {
                                   title: 'No User Selected',
                                   text: 'Please Select User By Clicking Checkbox',
                                   type: 'warning',
                                   confirmButtonClass: 'btn btn-confirm mt-2'
                               }
                           )
            }
        }

        function toggle(_id,_Empcode,_Name)
        {

            if ($('#'+_id+'').is(":checked")) {

                object.push({id: _id, name: _Empcode, type: _Name});
            }
            else {

                for(var i = 0; i < object.length; i++) {
                    if(object[i].id == _id) {
                        object.splice(i, 1);
                        break;
                    }
                }

            }

            console.log(object)
        }


    </script>
}
