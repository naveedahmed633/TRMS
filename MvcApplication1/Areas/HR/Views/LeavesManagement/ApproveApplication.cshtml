@{
    ViewBag.Title = "TRMS - Approve Application";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.welcome")  <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span></h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Leaves</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="mdi mdi-file-document"></i> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.approveapplication") </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row m-t-30">
                        <div class="col-12">
                            <table id="leave_application_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 140%;">
                                <thead>
                                    <tr>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.id")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.leavetype")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.datefrom")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.dateto")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.leavestatus")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.action")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.usercode")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.approvercode")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.dayscount")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.leavereason")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.username")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.approvername")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.attachment")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.reasondetail")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.approverres")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.applydate")</th>
                                        @*<th>HOD Approved</th>
                                        <th>PRN Approved</th>
                                        <th>HR Approved</th>
                                        <th>VC Approved</th>*@
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-2">
                            <span class="h4">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exportgrid"):</span>
                        </div>
                        <div id="divExportButtons" class="col-10">
                            &nbsp;
                        </div>
                    </div>

                    <div class="row m-t-10 d-none">
                        <div class="col-12">
                            <button type="submit" id="btnExport" onclick="CheckData();" class="btn btn-primary waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exportgrid")</button>
