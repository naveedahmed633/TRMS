    <script type="text/javascript">
        jQuery(document).ready(function (e) {

            var data = '@Session["GV_Langauge"]';
            $("#ddl_language").val(data);





            @*var empCode= @Html.Raw(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeCode);
            if (empCode=="000187") {
                $('#MenuPayroll').hide();
                $('#MenuHR').hide();
            }*@




            var empCode= @Html.Raw(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId);

            $.ajax({
                url: '/HR/HR/VerfiyDataHandler',
                type: "POST",
                data: { empId: empCode },
                dataType: "json",

                success: function (data) {


                    if (data.HREmployeeManagement == false) {
                        $("#HREmpManagementMenu").hide();
                    }
                    if (data.HRHR == false) {
                        $("#MenuHR").hide();
                    }
                    if (data.HRLeaves == false) {
                        $("#HRLeavesMenu").hide();
                    }
                    if (data.HRPayrollLoan == false) {
                        $("#HRPayrollLoanMenu").hide();
                    }
                    if (data.HROvertime == false) {
                        $("#HROvertimeMenu").hide();
                    }
                    if (data.HRShiftManagement == false) {
                        $("#HRShiftManagementMenu").hide();
                    }
                    if (data.HRRoasterManagement == false) {
                        $("#HRRoasterManagementMenu").hide();
                    }
                    if (data.HRAttendanceManagement == false) {
                        $("#HRAttendanceManagementMenu").hide();
                    }
                    if (data.HRReport == false) {
                        $("#HRReportMenu").hide();
                    }
                    if (data.HRManual == false) {
                        $("#HRManualMenu").hide();
                    }

                    console.log(data);
                },
                error: function () {
                    alert("error");
                }
            });


            var tt_exp = "20"; //set the exp time in min
            tt_exp = (parseInt(tt_exp) * 60000);
            jQuery(document).bind("idle.idleTimer", function () {
                //alert("Session Timeout"); //here you can attach any function for timeout action even ajax call too.
                location.reload();
            });

            jQuery.idleTimer(tt_exp);


        });
        function changeText() {
            $('#test span').text('0');
        };

    </script>

