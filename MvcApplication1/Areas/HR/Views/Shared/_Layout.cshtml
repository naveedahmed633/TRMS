<!DOCTYPE html>
<html>
<head>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="A fully featured biometric attendance managment system having various modules to manage like users, departments, designations, functions, regions, locations, grups and grades. View reports include Monthly timesheet, Consolidated Attendance and Department wise reports.">
    <meta name="author" content="Coderthemes">

    <link rel="shortcut icon" href="/images/favicon.ico">

    <title>
        @{
            if (ViewBag.Title == null)
            {
                <text>TRMS - Time Resourse Management System</text>;
            }
            else
            {
                @ViewBag.Title;
            }
        }
    </title>

    <link href="@Href("~/Content/ui-darkness/jquery-ui-1.9.2.custom.css")" rel="stylesheet"> <!-- JQuery UI theme -->

    <link href="@Href("~/plugins/datatables/dataTables.bootstrap4.min.css")" rel="stylesheet" type="text/css" />
    <link href="@Href("~/plugins/datatables/buttons.bootstrap4.min.css")" rel="stylesheet" type="text/css" />
    <!-- Responsive datatable examples -->
    <link href="@Href("~/plugins/datatables/responsive.bootstrap4.min.css")" rel="stylesheet" type="text/css" />
    <!-- Multi Item Selection examples -->
    <link href="@Href("~/plugins/datatables/select.bootstrap4.min.css")" rel="stylesheet" type="text/css" />

    <link href="@Href("/plugins/custombox/dist/custombox.min.css")" rel="stylesheet">

    <link rel="stylesheet" href="@Href("~/plugins/morris/morris.css")">

    <!--Chartist Chart CSS -->
    <link rel="stylesheet" href="/plugins/chartist/dist/chartist.min.css">

    <link href="/plugins/jquery-circliful/css/jquery.circliful.css" rel="stylesheet" type="text/css" />

    <link href="/plugins/nvd3/build/nv.d3.min.css" rel="stylesheet" type="text/css" />
    <!-- Sweet Alert css -->

    <link href="/plugins/sweet-alert/sweetalert2.min.css" rel="stylesheet" type="text/css" />
    <link href="/plugins/switchery/switchery.min.css" rel="stylesheet" />


    <link href="@Href("~/Content/timepicki.css")" rel="stylesheet" />  <!-- CSS for TimePicker -->
