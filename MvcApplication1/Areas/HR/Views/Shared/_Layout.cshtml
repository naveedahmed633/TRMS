                        if (MvcApplication1.ViewModel.GlobalVariables.GV_SiteTitle.ToString().ToLower().Contains("prin") || MvcApplication1.ViewModel.GlobalVariables.GV_SiteTitle.ToString().ToLower().Contains("vc") || MvcApplication1.ViewModel.GlobalVariables.GV_SiteTitle.ToString().ToLower().Contains("hod"))
