                                            <option value="Ar">Arabic</option>
                                        </select>
                                    </td>
                                    <td><button type="submit" class="btn btn-primary waves-effect" style="font-size: smaller; background-color:#2a3142; ">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("hr.changelang")</button></td>
                                </tr>

                            </table>
                        }
