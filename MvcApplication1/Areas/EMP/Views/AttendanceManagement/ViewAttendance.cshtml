@{
    ViewBag.Title = "TRMS - View Attendance";
    Layout = "~/Areas/EMP/Views/Shared/_Layout.cshtml";

    string EMP_STD_LEC_LoginUserType = "";
    if (MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeFunctionSLSID.ToString().Contains("student"))
    {
        EMP_STD_LEC_LoginUserType = "STD";
    }
    else if (MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeFunctionSLSID.ToString().Contains("lecturer"))
    {
        EMP_STD_LEC_LoginUserType = "LEC";
    }
    else
    {
        EMP_STD_LEC_LoginUserType = "EMP";
    }
}

@model ViewModels.ReportPersistentAttendanceLog

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.welcome")  <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span></h4>
                 <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/EMP/EMP/Dashboard">@EMP_STD_LEC_LoginUserType</a></li>
                    <li class="breadcrumb-item active">Attendance</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="mdi mdi-file-document"></i> @Model.employee_first_name @Model.employee_last_name ( @Model.employee_code )</h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-md-3 col-sm-4 col-xs-6 tile_stats_count">
                            <span class="h4"><i class="fa fa-clock-o"></i> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("atendance.timein")</span>
                            <div class="text">@Model.time_in</div>
                        </div>
                        <div class="col-md-3 col-sm-4 col-xs-6 tile_stats_count">
                            <span class="h4"><i class="fa fa-clock-o"></i>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("atendance.timeout") </span>
                            <div class="text">@Model.time_out</div>
                        </div>
                        <div class="col-md-3 col-sm-4 col-xs-6 tile_stats_count">
                            <span class="h4"><i class="mdi mdi-hospital-building"></i>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("atendance.terminalin")</span>
                            <div class="text">@Model.terminal_in</div>
                        </div>
                        <div class="col-md-3 col-sm-4 col-xs-6 tile_stats_count">
                            <span class="h4"><i class="mdi mdi-hospital-building"></i>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("atendance.terminalOut")</span>
                            <div class="text">@Model.terminal_out</div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- End content -->

@section JS {
    <script>
        $(document).ready(function () {
            
        });
    </script>
}

