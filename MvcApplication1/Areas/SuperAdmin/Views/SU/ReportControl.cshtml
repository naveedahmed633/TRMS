@{
    ViewBag.Title = "TRMS - User Control";
    Layout = "~/Areas/SuperAdmin/Views/Shared/_Layout.cshtml";
}

@model ViewModels.CreateEmployee

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'SuperAdmin'</span>! [Login ID: <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@User.Identity.Name</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/SuperAdmin">SuperAdmin</a></li>
                    <li class="breadcrumb-item active">User Control</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <!-- Page-Title -->
    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="row">
                        <div class="col-12 m-b-10">
                            <h3>Reports Permissions Set</h3>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12">
                            @if (Request.QueryString["message"] != null && Request.QueryString["message"].ToString() == "success")
                            {
                                <div class="form-group row">
                                    <div class="text-danger h4 msg">
                                        Successfully Apply
                                    </div>
                                </div>
                            }

                        </div>
                    </div>
                    @using (Html.BeginForm("AddReportPermissionUser", "SU"))
                    {
                        <div class="row">
                            <div class="col-12">
                                <div class="row m-t-10">
                                    <div class="col-4">
                                        <label class="control-label">Employee Code</label>
                                        <select id="monthly-time-sheet-employees" class="form-control" name="EmployeeCode" required>
                                            <!--<option value="28317">002369</option>-->
                                        </select>
                                    </div>

                                </div>

                                <div class="row m-t-10">
                                    <button class="btn btn-default" onclick="javascript: window.location.href = '/SuperAdmin/SU/ReportControl'">Refresh Page</button>
                                </div>



                                <div id="tblEMP">
                                    <p class="bold" style="text-align: center; font-size: larger; font-weight: 600;">Permissions</p>


                                    <table class="table table-bordered">
                                        <thead>


                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td>
                                                    Report 01 - Devices Count Report
                                                </td>
                                                <td class="text-center">
                                                    <div class="checkbox">
                                                        <input type="checkbox" value="true" name="prep_01" id="prep_01">
                                                        <label for="ExportGridData"></label>
                                                    </div>
                                                </td>

                                            </tr>
                                            <tr>
                                                <td>
                                                    Report 02
                                                </td>
                                                <td class="text-center">
                                                    <div class="checkbox">
                                                        <input type="checkbox" value="true" name="prep_02" id="prep_02">
                                                        <label for="DownloadExcel"></label>
                                                    </div>
                                                </td>


                                            <tr>
                                                <td>
                                                    Report 03
                                                </td>
                                                <td class="text-center">
                                                    <div class="checkbox">
                                                        <input type="checkbox" value="true" name="prep_03" id="prep_03">
                                                        <label for="ExportPDF"></label>
                                                    </div>
                                                </td>

                                            </tr>


                                            <tr>
                                                <td>
                                                    Report 04
                                                </td>
                                                <td class="text-center">
                                                    <div class="checkbox">
                                                        <input type="checkbox" value="true" name="prep_04" id="prep_04">
                                                        <label for="ManualMenu"></label>
                                                    </div>
                                                </td>

                                            </tr>
                                        </tbody>
                                    </table>
                                    <button type="submit" class="btn btn-info pull-right">Apply</button>
                                </div>





                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>





<!-- End content -->


<div id="MidTermModal" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="MidTermModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                <h4 class="modal-title" id="CenterModalLabel">View</h4>
            </div>
            <div class="modal-body text-center">
                <img id="image_source" src="~/Images/no-image.png" width="300" />

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary waves-effect" data-dismiss="modal">Close</button>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div>

<!-- Custom Modal -->
<div class="modal fade bs-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="mySmallModalLabel" aria-hidden="true" style="display: none;">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                <h4 class="modal-title" id="mySmallModalLabel">Message Alert</h4>
            </div>
            <div class="modal-body">
                <span id="alert_message"></span>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->


<div id="toast" class="toast-message" style='display:none'>Message!</div>

