        function getDetailsOfRights() {
            $.ajax({
                url: '/SU/SuperAdminModuleRight',
                type: 'Get',
                data: {},
                //dataType: "json",

                success: function (data) {


                    if (data.EmployeeManagement != true) {
                        $("#HREmployeeManagement").attr("disabled", true);
                    }
                    if (data.HR != true) {
                        $("#HRHR").attr("disabled", true);

                    }
                    if (data.Leaves != true) {
                        $("#LeavesMenu").attr("disabled", true);
                        $("#HRLeaves").attr("disabled", true);
                        $("#LMLeaves").attr("disabled", true);

                    }
                    if (data.PayrollLoan != true) {
                        $("#LoanMenu").attr("disabled", true);
                        $("#PayrollMenu").attr("disabled", true);
                        $("#HRPayrollLoan").attr("disabled", true);


                    }
                    if (data.Overtime != true) {
                        $("#LMOvertime").attr("disabled", true);
                        $("#HROvertime").attr("disabled", true);
                        $("#OvertimeMenu").attr("disabled", true);

                    }
                    if (data.ShiftManagement != true) {
                        $("#HRShiftManagement").attr("disabled", true);

                    }
                    if (data.RoasterManagement != true) {
                        $("#HRRoasterManagement").attr("disabled", true);
                        $("#LMRoaster").attr("disabled", true);


                    }
                    if (data.AttendanceManagement != true) {

                        $("#AttendanceMenu").attr("disabled", true);
                        $("#LMAttendance").attr("disabled", true);

                    }
                    if (data.Report != true) {

                        $("#ReportsMenu").attr("disabled", true);
                        $("#HRReport").attr("disabled", true);
                        $("#LMReport").attr("disabled", true);

                    }
                    if (data.Manual != true) {
                        $("#LMManual").attr("disabled", true);
                        $("#HRManual").attr("disabled", true);
                        $("#ManualMenu").attr("disabled", true);



                    }


                    console.log(data);
                },
                error: function () {
                    //alert("error");
                }
            });
        }


