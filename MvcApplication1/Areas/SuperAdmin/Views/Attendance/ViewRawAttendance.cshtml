@{
    ViewBag.Title = "TRMS - Archive Tables";
    Layout = "~/Areas/SuperAdmin/Views/Shared/_Layout.cshtml";
}

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'SuperAdmin'</span>! [Login ID: <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@User.Identity.Name</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/SuperAdmin">Super Admin</a></li>
                    <li class="breadcrumb-item active">Raw Attendance Log</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="mdi mdi-account-box"></i>Raw Attendance Log </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>


                    <div class="form-group row">
                        <div class="col-12">
                            <table id="attendance_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%">
                                <thead>

                                    <tr>
                                        <th>First Name</th>
                                        <th>Last Name</th>
                                        <th>Employee Code</th>
                                        <th>Date</th>
                                        <th>Time </th>
                                    </tr>

                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>



                    <div class="row">
                        <div class="col-12">
                            <button id="btnExport" type="submit" class="btn btn-primary waves-effect waves-light">Export Grid Data</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- End content -->

@section JS {
    <script type="text/javascript">

        $(document).ready(function () {
            //$('#accordion').accordion("option", "active", 3);
            $(".datepicker").datepicker({ dateFormat: 'dd-mm-yy' });
            //setActiveLink("View Raw Attendance");


            //$('#btnExport').button();
            $("#btnExport").click(function (e) {
                setupTableExportButton('#attendance_table', 'ViewRawAttendance');
                e.preventDefault();
            });


            /*
            $('#btnExport').button();
            $("#btnExport").click(function (e) {
                $('#attendance_table').tableExport({ type: 'excel', escape: 'false' });
                e.preventDefault();
            });
            */


            var url = '@Url.Action("RawAttendanceDataHandler", "Attendance", null, Request.Url.Scheme)';

            var columns = [

                   { "data": "employee_first_name" },
                   { "data": "employee_last_name" },
                   { "data": "employee_code" },
                   { "data": "date" },
                   { "data": "time" }

            ];

            @*
               I did this so that like initDataTables the JS
        for serverside processing can be used for other tables.
            NOTE: The names of the columns correspond to the View Model.
        For example in this example the column names, first_name, last_name
        etc are taken from ViewModels.Employee
    *@

            initServerSideTable('#attendance_table', url, columns);




        });
    </script>
}