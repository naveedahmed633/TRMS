@{
    ViewBag.Title = "TRMS - Edit Terminal";
    Layout = "~/Areas/SuperAdmin/Views/Shared/_Layout.cshtml";
}

@model ViewModels.CreateManualAttendance

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'SuperAdmin'</span>! [Login ID: <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@User.Identity.Name</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/SuperAdmin">SuperAdmin</a></li>
                    <li class="breadcrumb-item active">Edit Terminal</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> Edit Terminal </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-4">

                            @using (Html.BeginForm("EditTerminal", "ManageEmployees", FormMethod.Post, new { id = "attendance-form" }))
                            {

                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">Select Terminal ID</label>
                                        <select id="terminal" class="form-control" name="id" required></select>
                                    </div>
                                </div>


                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Terminal Name</label>
                                        <input type="text" class="form-control " id="terminal_name" name="terminal_name" required>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Terminal Location</label>
                                        <input type="text" class="form-control " id="terminal_id" name="terminal_id" required>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Branch Code</label>
                                        <input type="text" class="form-control " id="branch_code" name="branch_code" required>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Branch Name</label>
                                        <input type="text" class="form-control " id="branch_name" name="branch_name" required>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12 text-danger">
                                        @Html.AntiForgeryToken()
                                        @Html.ValidationSummary()
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12">
                                        <button type="submit" class="btn btn-primary waves-effect waves-light m-t-10">Update Terminal</button>&nbsp;
                                        <button type="button" class="btn btn-primary waves-effect waves-light m-t-10" onclick="redirectToPage();">Reset</button>
                                    </div>
                                </div>
                            }

                        </div>

                    </div>

                  

                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">

    <div class="row">
        <div class="col-12">
            <div class="card-box">
           
                  
                    <div class="row">
                        <div class="col-12">
                            <table id="attendance_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 120%;">
                                <thead>
                                    <tr>
                                        <th>Terminal Id</th>
                                        <th>Terminal Name</th>
                                        <th>Terminal Location</th>
                                        <th>Branch Code</th>
                                        <th>Branch Name</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" class="btn btn-primary waves-effect waves-light">Export Grid Data</button>
                        </div>
                    </div>

               
            </div>
        </div>
    </div>
</div>
<!-- End content -->

@section JS {
    <script type="text/javascript" src="@Href("~/Scripts/chosen.ajaxaddition.jquery.js")"></script>
    <script type="text/javascript">
        function redirectToPage() {
            window.location.reload();
        }

        $(document).ready(function () {
            //$('#accordion').accordion("option", "active", 1);
            //setActiveLink("Edit Device");
            //setActiveLink("Manual Attendance");
            $(".chzn-select").chosen();
            //  $(".datepicker").datepicker({ dateFormat: 'yy-mm-dd' });
            //$("input[type=submit], button").button();


            $('#terminal').ajaxChosen({
                dataType: 'json',
                type: 'POST',
                url: '@Url.Action("terminal", "ManageEmployees", null, Request.Url.Scheme)'
            }, {
                loadingImg: '@Href("~/Content/ChosenAutoComplete/loading.gif")'
            });


            //  setChosenSelectList('#terminal-select', '@Url.Action("terminal", "ManageEmployees", null, Request.Url.Scheme)');



            var url = '@Url.Action("TerminalDataHandler", "ManageEmployees", null, Request.Url.Scheme)';
            var deleteUrl = '@Url.Action("deleteTerminal", "ManageEmployees", null, Request.Url.Scheme)';
            var columns = [
                  { "data": "id" },
                   { "data": "name" },
                   { "data": "terminal_id" },
                   { "data": "action" }
            ];
            initServerSideTable('#attendance_table', url, columns);
        });



        function deleteTerminal(val) {

            var answer = confirm("Are you sure you want to delete terminal ?")
            if (answer) {
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("deleteTerminal", "ManageEmployees", null, Request.Url.Scheme)',
                    data: {
                        id: val
                    },
                    success: function (data) {
                        // remove the row from the data table
                        console.log();

                    },
                    error: function (event) {

                        deleteDialog.dialog("close");
                        $('#toast').html('There was an error. The database server might be down.');
                        //  $('#toast').stop().fadeIn(400).delay(3000).fadeOut(400);
                    },
                    complete: function (data) {


                    },
                    dataType: 'text json'
                });
                $('*[data-id="' + val + '"]')
                          .parent()
                          .parent()
                          .remove();


                deleteDialog.dialog("close");
                $('#toast').html('Terminal deleted successfully');
                $('#toast').stop().fadeIn(400).delay(3000).fadeOut(400);
            }
            else {
                //some code
                return false;
            }

        };

        $("#btnExport").click(function (e) {
            setupTableExportButton('#attendance_table', 'Terminals');
            e.preventDefault();
        });


        $('#attendance-form').on("submit", function (e) {
            return true;
        });
    </script>
}