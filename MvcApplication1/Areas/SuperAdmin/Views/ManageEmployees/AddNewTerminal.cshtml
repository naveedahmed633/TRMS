@{
    ViewBag.Title = "TRMS - Add New Terminal";
    Layout = "~/Areas/SuperAdmin/Views/Shared/_Layout.cshtml";
}

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'SuperAdmin'</span>! [Login ID: <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@User.Identity.Name</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/SuperAdmin">SuperAdmin</a></li>
                    <li class="breadcrumb-item active">Add New Terminal</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i>Add a New Terminal </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>



                    @using (Html.BeginForm("AddNewTerminal", "ManageEmployees", FormMethod.Post, new { id = "attendance-form" }))
                    {

                        <div class="row">
                            <div class="col-4">

                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">Terminal Code <small class="text-danger">(L_ID in UNIS tTerminal)</small></label>
                                        <input type="text" class="form-control " pattern="^[0-9]*$" id="id" name="id" required>
                                    </div>
                                </div>


                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Terminal Name <small class="text-danger">(including Branch Name from UNIS)</small></label>
                                        <input type="text" class="form-control " id="terminal_name" name="terminal_name" required>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Location</label>
                                        <input type="text" class="form-control " id="terminal_id" name="terminal_id" required>
                                    </div>
                                </div>

                            </div>

                            <div class="col-4">
                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">Branch Code <small class="text-danger">(c_code in UNIS cOffice)</small></label>
                                        <input type="text" class="form-control " id="branch_code" name="branch_code" required>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Branch Name <small class="text-danger">(c_code in UNIS cOffice)</small></label>
                                        <input type="text" class="form-control " id="branch_name" name="branch_name" required>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Terminal Type</label>
                                        <select id="type" class="form-control" name="type" required>
                                            <option value="In">In</option>
                                            <option value="Out">Out</option>
                                        </select>
                                    </div>
                                </div>



                            </div>

                        </div>


                        <div class="row">
                            <div class="col-12 text-danger">
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary()
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary waves-effect waves-light m-t-10">Add Terminal</button>&nbsp;
                            </div>
                        </div>

                    }


                    <hr>

                    <div class="row">
                        <div class="col-12">
                            <table id="attendance_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 120%;">
                                <thead>
                                    <tr>
                                        <th>Terminal Code</th>
                                        <th>Terminal Name</th>
                                        <th>Location</th>
                                        <th>Branch Code</th>
                                        <th>Branch Name</th>
                                        <th>Terminal Type</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" class="btn btn-primary waves-effect waves-light">Export Grid Data</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- End content -->
@section JS {
    <script src="@Url.Content("/Scripts/terminalsCRUD.js")" type="text/javascript"></script>

    <script type="text/javascript" src="@Href(" ~/Scripts/chosen.ajaxaddition.jquery.js")"></script>



    <script type="text/javascript">

        $(document).ready(function () {
            //$('#accordion').accordion("option", "active", 1);
            setActiveLink("Add Device");
            $(".chzn-select").chosen();
            //  $(".datepicker").datepicker({ dateFormat: 'yy-mm-dd' });
            //$("input[type=submit], button").button();


            $('#terminal').ajaxChosen({
                dataType: 'json',
                type: 'POST',
                url: '@Url.Action("terminal", "ManageEmployees", null, Request.Url.Scheme)'
            }, {
                loadingImg: '@Href("~/Content/ChosenAutoComplete/loading.gif")'
            });


            //  setChosenSelectList('#terminal-select', '@Url.Action("terminal", "ManageEmployees", null, Request.Url.Scheme)');



            var url = '@Url.Action("TerminalDataHandler", "ManageEmployees", null, Request.Url.Scheme)';

            var columns = [
                  { "data": "id" },
                   { "data": "name" },
                   { "data": "terminal_id" },
                   { "data": "branch_code" },
                   { "data": "branch_name" },
                   { "data": "type" },
                    { "data": "action" },
            ];
            initServerSideTable('#attendance_table', url, columns, 500);

            editTerminal = initEditModalSkill("#modals", '@Url.Action("EditTerminal", "ManageEmployees", null, Request.Url.Scheme)', "Terminal");
            deleteTerminal = initDeleteModalSkill("#modals", '@Url.Action("deleteTerminal", "ManageEmployees", null, Request.Url.Scheme)', "Terminal");

        });

        $("#btnExport").click(function (e) {
            setupTableExportButton('#attendance_table', 'Terminals');
            e.preventDefault();
        });


        $('#attendance-form').on("submit", function (e) {
            return true;
        });
    </script>
}