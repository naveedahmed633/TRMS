@{
    ViewBag.Title = "ViewAttendance";
    Layout = "~/Areas/SuperAdmin/Views/Shared/_Layout.cshtml";
}

<h4 style="font-weight: bold;">Local Services</h4>




<div class="row">
    <div class="col-md-12">
        <h5 style="font-weight: bold;">Local Services</h5>


        <table id="attendance_table" class="display cell-border" width="100%">
            <thead>

                <tr>
                    <th>Service Name</th>
                    <th>Service Discription</th>
                    <th>Service Status</th>
                    <th>On Service</th>
                    <th>Off Service</th>
                </tr>

            </thead>
            <tbody></tbody>
        </table>
        <button type="submit" id="btnExport" style="margin-top:5px">Export Grid Data</button>

    </div>
</div>


@section JS {
    <script>
        $(document).ready(function () {
            $('#accordion').accordion("option", "active", 2);
            setActiveLink("Service On Off");

            $('#btnExport').button();
            $("#btnExport").click(function (e) {
            setupTableExportButton('#attendance_table',  'ViewAttendance');
            e.preventDefault();
            });
            /*
            $('#btnExport').button();
            $("#btnExport").click(function (e) {
                $('#attendance_table').tableExport({ type: 'excel', escape: 'false' });
                e.preventDefault();
            });*/
            //serviceStart
            var url = '@Url.Action("ServiceDataHandler", "ManageEmployees", null, Request.Url.Scheme)';

            var columns = [

                   { "data": "serviceName" },
                   { "data": "Description" },
                   { "data": "status" },
                   { "data": "on_action" },
                   { "data": "off_action" }


            ];

            @*
               I did this so that like initDataTables the JS
        for serverside processing can be used for other tables.
            NOTE: The names of the columns correspond to the View Model.
        For example in this example the column names, first_name, last_name
        etc are taken from ViewModels.Employee
            *@

            initServerSideTable('#attendance_table', url, columns);


        });

        function startService(val) {
            
            var entity = document.getElementById("serviceStart" + val + "").onclick = function () {

                var r = confirm("Are you sure you want to Start the Service " + this.value);
                if (r == false) {
                    return false;
                }
            $.ajax({
                type: "POST",
                url: '@Url.Action("startService", "ManageEmployees", null, Request.Url.Scheme)',
                data: {
                    serviceName: this.value
                },
                success: function (data) {
                    // remove the row from the data table
                    
                    deleteDialog.dialog("close");
                    $('#toast').html('Service start Successfully successfully');
                    $('#toast').stop().fadeIn(400).delay(3000).fadeOut(400);

                },
                error: function (event) {

                    deleteDialog.dialog("close");
                    $('#toast').html('There was an error. The database server might be down.');
                    //  $('#toast').stop().fadeIn(400).delay(3000).fadeOut(400);
                },
                complete: function (data) {


                },
                dataType: 'text json'
            });
        }

        }




        function stopService(val) {
           
            var entity = document.getElementById("serviceStop" + val + "").onclick = function () {
                var r = confirm("Are you sure you want to Stop the Service " + this.value);
                if (r == false) {
                    return false;
                }
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("stopService", "ManageEmployees", null, Request.Url.Scheme)',
                    data: {
                        serviceName: this.value
                    },
                    success: function (data) {
                        // remove the row from the data table

                        deleteDialog.dialog("close");
                        $('#toast').html('Service start Successfully successfully');
                        $('#toast').stop().fadeIn(400).delay(3000).fadeOut(400);

                    },
                    error: function (event) {

                        deleteDialog.dialog("close");
                        $('#toast').html('There was an error. The database server might be down.');
                        //  $('#toast').stop().fadeIn(400).delay(3000).fadeOut(400);
                    },
                    complete: function (data) {


                    },
                    dataType: 'text json'
                });
        }
        }


    </script>
}