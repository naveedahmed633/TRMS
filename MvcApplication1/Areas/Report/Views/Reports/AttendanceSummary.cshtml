@{
    ViewBag.Title = "TRMS - Attendance Summary";
    Layout = "~/Areas/REPORT/Views/Shared/_Layout.cshtml";
}

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'REPORT'</span>! Username: @User.Identity.Name</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/REPORT/REPORT/Dashboard">REPORT</a></li>
                    <li class="breadcrumb-item active">Attendance Summary</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> Attendance Summary </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-12">
                            @using (Html.BeginForm("AttendanceSummarytDataHandler", "Reports", FormMethod.Post, new { id = "report-form" }))
                            {
                                <div class="row">
                                    <div class="col-4">
                                        <label class="control-label">Date From</label>
                                        <input type="text" class="form-control datepicker" name="from_date" required />
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-4">
                                        <label class="control-label">Date To</label>
                                        <input type="text" class="form-control datepicker" name="to_date" required />
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12 text-danger">
                                        @Html.AntiForgeryToken()
                                        @Html.ValidationSummary()
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12">
                                        <button type="submit" value="Submit" onclick="clearr();" class="btn btn-primary waves-effect waves-light m-t-10">Search</button>
                                        <button type="reset" value="Reset" class="btn btn-primary waves-effect waves-light m-t-10">Reset</button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-12">
                            <table id="report_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>Employee Code</th>
                                        <th>Present</th>
                                        <th>On Time</th>
                                        <th>Late</th>
                                        <th>Early Out</th>
                                        <th>Absent</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" onclick="ExortExcleBar();" class="btn btn-primary waves-effect waves-light">Export Grid Data</button>
                            <span id="demo" class="text-danger"></span>
                            <p id="export_wait2" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- End content -->


@section JS {
    <script type="text/javascript" src="@Href("~/Scripts/chosen.ajaxaddition.jquery.js")"></script>
    <script type="text/javascript">

        function ExortExcleBar() {
            $('#export_wait2').show();
            document.getElementById("btnExport").disabled = true;
            HideBarExcle();
            var ss = $("tr").children("td:first").text();
            if (ss != "No data available in table") { DownloadExcleCsv(); }
            else { document.getElementById("demo").innerHTML = "No Data Found."; }
        }

        function DownloadExcleCsv() { setupTableExportButton('#attendance_table', 'AttendanceSummary'); }

        function HideBarExcle() {
            setTimeout(function () { $('#export_wait2').hide(); document.getElementById("btnExport").disabled = false; document.getElementById("demo").innerHTML = ""; }, 1500);
        }
        $(document).ready(function () {
            //$('#accordion').accordion("option", "active", 2);
            $(".datepicker").datepicker({ dateFormat: 'dd-mm-yy' });

            $('.hasDatepicker').keydown(function (e) {
                var unicode = e.keyCode ? e.keyCode : e.charCode;
                if (unicode != 13 && unicode != 8 && unicode != 9) {



                    e.preventDefault();
                }
            });

            $('.hasDatepicker').keydown(function (e) {
                var unicode = e.keyCode ? e.keyCode : e.charCode;
                if (unicode == 8) { e.preventDefault(); e.stopPropagation(); }
            });
            //$("input[type=submit], button").button();
            $('.hasDatepicker').keydown(function (e) {
                var unicode = e.keyCode ? e.keyCode : e.charCode;
                if (unicode != 13 && unicode != 8 && unicode != 9) { e.preventDefault(); }
            });
            //$('#btnExport').button();

        });



        function checkSubmit(id) {

            fDate = $(id).find('[name*="from_date"]').val().split("-").reverse();
            tDate = $(id).find('[name*="to_date"]').val().split("-").reverse();


            fDate = new Date(fDate[0] + "-" + fDate[1] + "-" + fDate[2]);
            tDate = new Date(tDate[0] + "-" + tDate[1] + "-" + tDate[2]);

            if (tDate < fDate) {
                alert("To date should be greater than from date.");
                return false;
            }

            return true;
        }




        function initReportDataTable(identifier, url, columns) {
            var oTable = $(identifier).DataTable({
                "searchDelay": 2000,
                "scrollY": "300px",
                "serverSide": true,
                "ajax": {
                    "type": "POST",
                    "url": url,
                    "contentType": 'application/json; charset=utf-8',
                    'data': function (data) {

                        data.from_date = $('#report-form').find('[name*="from_date"]').val();;
                        data.to_date = $('#report-form').find('[name*="to_date"]').val();
                        return data = JSON.stringify(data);
                    }
                },
                "scrollX": true,
                "scrollCollapse": true,
                "processing": true,
                "paging": true,
                "deferRender": true,
                "columns": columns,
                "order": [0, "asc"]

            });

            oTable.on("draw", function () {
                var keyword = $(identifier + '_filter > label:eq(0) > input').val();
                $(identifier).unmark();
                $(identifier).mark(keyword, {});



                $(identifier + ' tbody tr').click(function (e) {
                    $('tr.row_selected').removeClass('row_selected');
                    $(this).addClass('row_selected');
                });
            });


            // set the z-index of the 'processing...' overlay
            // to a great number, so that it may always display
            // on top of the table. Also set the text color
            // to black as it is white by default.
            $(identifier + '_processing').css({
                "z-index": "1000",
                "color": "rgb(0, 0, 0)"
            });


            // initiate search one second after the user
            // stops typing.
            function setSearchDelayOnDataTable(idSelector) {
                // remove all events from the search box
                $(idSelector + '_filter input').off();


                function customDataTableSearch() {

                    // get the entered string
                    var toSearch = $(idSelector + '_filter input').val();

                    // do nothing if the string is null.
                    // I've not tested this, it is just
                    // in case.
                    if (toSearch == null) {
                        return;
                    }

                    // initiate search programatically.
                    $(idSelector).DataTable().search(toSearch).draw();
                }

                // this variable holds the timer
                var timeout;

                // register a keypress on the search box
                $(idSelector + '_filter input').keypress(function () {
                    if (timeout != null) {
                        clearTimeout(timeout);
                        timeout = null;
                    }

                    // timeout set to 1 second.
                    timeout = setTimeout(customDataTableSearch, 1000);
                });

            }

            setSearchDelayOnDataTable(identifier);
        }


        var url = '@Url.Action("AttendanceSummaryDataHandler", "Reports", null, Request.Url.Scheme)';
        var columns = [
       { "data": "employeeCode" },
       { "data": "present" },
       { "data": "ontime" },
       { "data": "late" },
       { "data": "earlyGone" },
       { "data": "absent" }
        ];

        initReportDataTable('#report_table', url, columns);

        $('#report-form').on("submit", function (e) {

            if (checkSubmit('#report-form')) {
                var toSearch = $("#report_table_filter input").val();

                //var fDate = $('#report-form').find('[name*="from_date"]').val();
                //var tDate = $('#report-form').find('[name*="to_date"]').val();
                $("#report_table").DataTable().search(toSearch).draw();

            }


            e.preventDefault();

        });
    </script>
}
