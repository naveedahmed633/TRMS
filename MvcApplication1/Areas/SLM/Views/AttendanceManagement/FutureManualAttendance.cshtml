@{
    ViewBag.Title = "TRMS - Future Attendance";
    Layout = "~/Areas/SLM/Views/Shared/_Layout.cshtml";
}

@model ViewModels.CreateManualAttendance

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'SLM'</span>! [Login ID: <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/SLM/SLM/Dashboard">SLM</a></li>
                    <li class="breadcrumb-item active">Future Attendance</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> Future Attendance</h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-12">
                            @using (Html.BeginForm("FutureManualAttendance", "AttendanceManagement", FormMethod.Post, new { id = "attendance-form" }))
                            {
                                <div class="row">
                                    <div class="col-4">
                                        <label class="control-label">Employee Code</label>
                                        <!-- <select id="consolidated-employees" class="form-control" name="employee_id" required></select>-->
                                        <select id="employees" class="chzn-select" name="employee_code">
                                            <option selected="selected" disabled="disabled" value="0">Select Employee Code</option>
                                            @foreach (ViewModels.Employee item in Model.employee)
                                            {
                                                <option value="@item.employee_code">@item.employee_code - @item.first_name @item.last_name</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-4">
                                        <label class="control-label">Date From</label>
                                        <input id="from_date" type="text" class="form-control datepicker" name="time_in_from" required />
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-4">
                                        <label class="control-label">Date To</label>
                                        <input id="to_date" type="text" class="form-control datepicker" name="time_in_to" required />
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-4">
                                        <label class="control-label">Reason</label>
                                        <select class="chzn-select" name="remarks">
                                            <option disabled="disabled" selected="selected">Select an option</option>
                                            <option value="OV">Official Visit - OV</option>
                                            <option value="OM">Official Meeting - OM</option>
                                            <option value="OT">Official Training - OT</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12 text-danger">
                                        @Html.AntiForgeryToken()
                                        @Html.ValidationSummary()
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-4">
                                        <button id="update" type="submit" value="Submit" class="btn btn-primary waves-effect waves-light m-t-10">Update Attendance</button>
                                        <label class="label" style="font-size:medium; color:red"> @ViewBag.Message</label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-12">
                            <table id="attendance_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>From Date</th>
                                        <th>To Date</th>
                                        <th>Employee Code</th>
                                        <th>Remarks</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" class="btn btn-primary waves-effect waves-light">Export Grid Data</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- End content -->

@section JS {

    <script type="text/javascript" src="@Href("~/Scripts/chosen.ajaxaddition.jquery.js")"></script>
    <script>

        $(document).ready(function () {
            //$('#accordion').accordion("option", "active", 1);
            //setActiveLink("Future Manual Attendance");
            $(".chzn-select").chosen();
            $(".datepicker").datepicker({ dateFormat: 'yy-mm-dd' });
            //$("input[type=submit], button").button();


            //$('#btnExport').button();
            $("#btnExport").click(function (e) {

            setupTableExportButton('#attendance_table', 'ManualAttendance');


                e.preventDefault();
            });
            /*
            $('#btnExport').button();
            $("#btnExport").click(function (e) {
                $('#attendance_table').tableExport({ type: 'excel', escape: 'false' });
                e.preventDefault();
            });

            */


            //initDataTable("#leavebalance_table");


            $('#employees').ajaxChosen({
                dataType: 'json',
                type: 'POST',
                url: '@Url.Action("getEmployeeDropDown", "AttendanceManagement", null, Request.Url.Scheme)'
            }, {
                loadingImg: '@Href("~/Content/ChosenAutoComplete/loading.gif")'
            });




            var url = '@Url.Action("FutureManualAttendanceDataHandler", "AttendanceManagement", null, Request.Url.Scheme)';

            var columns = [
                   { "data": "from_date" },
                   { "data": "to_date" },
                   { "data": "employee_code" },
                   { "data": "remarks" }

            ];

        @*
               I did this so that like initDataTables the JS
            for serverside processing can be used for other tables.
                NOTE: The names of the columns correspond to the View Model.
            For example in this example the column names, first_name, last_name
            etc are taken from ViewModels.Employee
        *@

            initServerSideTable('#attendance_table', url, columns);
        });

        $('#attendance-form').on("submit", function (e) {

            fDate = $('#attendance-form').find('[name*="time_in_from"]').val().split("-").reverse();
            tDate = $('#attendance-form').find('[name*="time_in_to"]').val().split("-").reverse();


            fDate = new Date(fDate[2] + "-" + fDate[1] + "-" + fDate[0]);
            tDate = new Date(tDate[2] + "-" + tDate[1] + "-" + tDate[0]);
            var timeDiff = Math.abs(tDate.getTime() - fDate.getTime());
            var diffDays = Math.abs(tDate.getDate() - fDate.getDate());
            var diffDays = parseInt(diffDays) + 1;
            var today = new Date();
            console.log(today,fDate);
            if (today >= fDate || tDate <=today) {
                alert("Please select future date");
                return false;
            }
            else {
                if (tDate < fDate) {
                    alert("To date should be greater than from date");
                    return false;
                }

                var r = confirm("Are you sure you want to Update Attendance of " + diffDays + " day(s)");
                if (r == false) {
                    return false;
                }


                return true;
            }


        });




    </script>
}