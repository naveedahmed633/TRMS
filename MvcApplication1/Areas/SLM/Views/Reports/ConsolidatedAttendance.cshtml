@{
    ViewBag.Title = "TRMS - Consolidated Attendance";
    Layout = "~/Areas/SLM/Views/Shared/_Layout.cshtml";
}

@model ViewModels.CreateManualAttendance

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'SLM'</span>! [Login ID: <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/SLM/SLM/Dashboard">SLM</a></li>
                    <li class="breadcrumb-item active">Consolidated Attendance</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> Consolidated Attendance </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-4">

                            <form id="attendance-form">

                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">Employee Code</label>
                                        <!-- <select id="consolidated-employees" class="form-control" name="employee_id" required></select>-->
                                        <select id="employee_id" class="chzn-select" name="employee_id">
                                            <option selected="selected" disabled="disabled" value="0">Select Employee Code</option>
                                            @foreach (ViewModels.Employee item in Model.employee)
                                            {
                                                <option value="@item.employee_code">@item.employee_code - @item.first_name @item.last_name</option>
                                            }
                                        </select>
                                    </div>
                                </div>


                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Date From</label>
                                        <input id="date_from" type="text" class="form-control datepicker" autocomplete="off" name="from_date" required />
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Date To</label>
                                        <input id="date_to" type="text" class="form-control datepicker" autocomplete="off" name="to_date" required />
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12">
                                        <button type="submit" id="search-consolidated-report" onclick="clearr();" class="btn btn-primary waves-effect waves-light m-t-10">Search</button>&nbsp;
                                        <button type="submit" id="btn-excel-download" onclick="HideMsg();" class="btn btn-primary waves-effect waves-light m-t-10">Download Excel</button>
                                        <span id="export_wait" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></span>
                                    </div>
                                </div>
                            </form>

                        </div>

                        <div class="form-group col-3">
                        </div>
                        <div class="form-group col-5" style="font-style: italic;">
                            <h4>Legends:</h4>
                            <table style="line-height: 16px; width: 70%;">
                                <tr><td style="width: 20%"></td><td style="width: 10%"></td><td style="width: 70%"></td></tr>
                                <tr><td>AB</td><td>:</td><td>Absent</td></tr>
                                <tr><td>LV</td><td>:</td><td>Leave</td></tr>
                                <tr><td>PLO</td><td>:</td><td>Present Late</td></tr>
                                <tr><td>PO</td><td>:</td><td>Present On Time</td></tr>
                                <tr><td>PLE</td><td>:</td><td>Present Late Early Out</td></tr>
                                <tr><td>POE</td><td>:</td><td>Present On Time Early Out</td></tr>
                                <tr><td>PLM</td><td>:</td><td>Present Late and Miss Punch</td></tr>
                                <tr><td>OV</td><td>:</td><td>Official Visit</td></tr>
                                <tr><td>OM</td><td>:</td><td>Official Meeting</td></tr>
                                <tr><td>OT</td><td>:</td><td>Official Training</td></tr>
                                <tr><td>*</td><td>:</td><td>Manually Updated</td></tr>
                            </table>
                        </div>

                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-12">
                            <table id="attendance_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Employee Code</th>
                                        <th>First Name</th>
                                        <th>Last Name</th>
                                        <th>Time In</th>
                                        <th>Remarks</th>
                                        <th>Time Out</th>
                                        <th>Remarks</th>
                                        <th>Final Remarks</th>
                                        <th>Device In</th>
                                        <th>Device Out</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" onclick="ExortExcleBar();" class="btn btn-primary waves-effect waves-light">Export Grid Data</button>
                            <span id="demo" class="text-danger"></span>
                            <p id="export_wait2" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- End content -->

