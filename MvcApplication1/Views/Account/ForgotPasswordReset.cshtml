@{
    Layout = "~/Views/Shared/_EmptyLayout.cshtml";
    ViewBag.Title = "TRMS - Forgot Password Reset";
}

@model BLL.ViewModels.ResetPassword

<div class="wrapper-page">

    <div class="text-center">
        <a href="/Account/Login" class="logo-lg"><i class="mdi mdi-radar"></i> <span>TRMS - Reset Password</span> </a>
    </div>

    <div style="@{ if (ViewBag.EmployeeCode == "") { <text>display: none;</text> } }" class="form-group row">
        <div class="col-md-12">

            @*<form class="form-horizontal m-t-20" action="index.html">*@
            @using (Html.BeginForm("ForgotPasswordReset", "Account", FormMethod.Post, new { @id = "form-forgot-password-reset", @class = "form-3" }))
            {
                <div class="form-group row">
                    <div class="col-12">
                        Enter your new passwords below. The password you enter below, will be used to replace old password:
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col-12">
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text"><i class="mdi mdi-radar"></i></span>
                            </div>
                            <input id="NewPassword" name="NewPassword" class="form-control" type="password" required="" placeholder="New Password">
                        </div>
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col-12">
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text"><i class="mdi mdi-radar"></i></span>
                            </div>
                            <input id="NewPasswordConfirm" name="NewPasswordConfirm" class="form-control" type="password" required="" placeholder="Confirm - New Password">
                        </div>
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col-12 text-danger">
                        @Html.ValidationSummary(true)
                        @Html.AntiForgeryToken()
                    </div>
                </div>

                <input data-val="true" class="field" id="GuidCode" name="GuidCode" type="hidden" value="@ViewBag.GCode" />

                <div class="form-group text-right m-t-20">
                    <div class="col-xs-12">
                        <input class="btn left" type="submit" name="submit" @{ if (ViewBag.EmployeeCode == "") { <text> disabled</text> } } onclick="HideLoadingBar();" value="Reset Password" />
                    </div>
                </div>
    }
            @*</form>*@
        </div>
    </div>

    <div class="form-group row text-center">
        <div class="col-12">
            <div id="loading_wait" style='@{ if (ViewBag.EmployeeCode == "") { <text>display: none;</text>} else{ <text>display: none;</text> } }'><img src='/images/loader.gif' alt='processing' /></div>
            <div id="loading_message">@Html.Raw(ViewBag.Message)</div>
        </div>
    </div>

</div>

@section JS {
    <script>

        function HideLoadingBar() {
            setTimeout(function () { document.getElementById("loading_message").innerHTML = ""; $('#loading_message').hide(); }, 5000);
        }

        $(document).ready(function () {
            //HideLoadingBar();
        });

        $('#form-forgot-password-reset').submit(function () {

            var strNewPassword = "", strNewPasswordConfirm = "";
            strNewPassword = $('#NewPassword').val();
            strNewPasswordConfirm = $('#NewPasswordConfirm').val();

            if (strNewPassword != strNewPasswordConfirm) {
                alert("Please enter SAME password in both fields.");

                $('#NewPassword').val("");
                $('#NewPasswordConfirm').val("");

                $('#NewPassword').focus();
                return false;
            }

            if (strNewPassword.length < 6) {
                alert("Both Passwords must be atleast 6 characters long.");

                $('#NewPassword').val("");
                $('#NewPasswordConfirm').val("");

                $('#NewPassword').focus();
                return false;
            }

            if (strNewPasswordConfirm.length < 6) {
                alert("Both Passwords must be atleast 6 characters long.");

                $('#NewPassword').val("");
                $('#NewPasswordConfirm').val("");

                $('#NewPassword').focus();
                return false;
            }

            if (!validatePasswordPolicy(strNewPassword)) {
                alert("The password must be at least 6 characters long and must contain at least: 1 small letter, 1 capital letter, 1 number, and 1 of the following special characters ! @@ # $ % ^ & * ( ) _ -");

                $('#NewPassword').val("");
                $('#NewPasswordConfirm').val("");

                return false;
            }

            $('#loading_wait').show();
            return true;

        });


        function validatePasswordPolicy(password) {

            //debugger;

            // minimum length must be 6.
            var minLengthMet = password.length >= 6;

            // Must contain a capital letter.
            hasUpper = (/[A-Z]+/).test(password);

            // Must have a lower case letter.
            hasLower = (/[a-z]+/).test(password);

            // Must have a number
            hasNumber = (/[0-9]+/).test(password);

            // Must have a special character.
            hasSpecial = (/[!@@#$%^&*()_-]+/).test(password);


            return minLengthMet && hasUpper && hasLower && hasNumber && hasSpecial;
        }

    </script>
}
