@{
    Layout = "~/Views/Shared/_EmptyLayout.cshtml";
    ViewBag.Title = "TRMS - Forgot Password Recovery";
}

@model BLL.ViewModels.ForgotPassword

<div class="wrapper-page">

    <div class="text-center">
        <a href="/Account/Login" class="logo-lg"><i class="mdi mdi-radar"></i> <span>TRMS - Recover</span> </a>
    </div>

    <div style='@{ if (ViewBag.Message != null && (ViewBag.Message.ToString().Contains("password-reset request has been submitted") || ViewBag.Message.ToString().Contains("connection is not"))) { <text>display: none;</text>}}' class="form-group row">
        <div class="col-12">
            @*<form method="post" action="#" role="form" class="text-center m-t-20">*@
            @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post, new { @id = "form-forgot-password", @class = "text-center m-t-20" }))
            {
                <div class="form-group row">
                    <div class="col-12">
                        Enter your <b>Username</b> and on submit you will receive an email with instructions!
                    </div>
                </div>

                <div class="form-group m-b-0">
                    <div class="input-group">
                        <input id="EmployeeCode" name="EmployeeCode" type="number" class="form-control" placeholder="Enter Username" required="">
                        <span class="input-group-append"> <button type="submit" class="btn btn-email btn-primary waves-effect waves-light" onclick="HideLoadingBar();">Send Email</button> </span>
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col-12 text-danger">
                        @Html.ValidationSummary(true)
                        @Html.AntiForgeryToken()
                    </div>
                </div>


                <div class="form-group row">
                    <div class="col-4">
                        <a href="/Account/Login" class="text-muted">Back to Login?</a>
                    </div>
                    <div class="col-8 text-right">
                        
                    </div>
                </div>
            }
            @*</form>*@
        </div>
    </div>

    <div class="form-group row">
        <div class="col-12">
            <div id="loading_wait" style='@{ if(ViewBag.Message != null) { <text>display: none;</text>} else{ <text>display: none;</text> } } color: red;'><img src='/images/loader.gif' alt='processing' /></div>
            <div id="loading_message">@Html.Raw(ViewBag.Message)</div>
        </div>
    </div>

</div>

@section JS {
    <script>

        function HideLoadingBar() {
            setTimeout(function () { document.getElementById("loading_message").innerHTML = ""; $('#loading_message').hide(); }, 5000);
        }

        $(document).ready(function () {

            $('#EmployeeCode').val("");
            ////$('#EmployeeEmail').val("");

            if ($('#loading_message').html().indexOf("connection is not") != -1 || $('#loading_message').html().indexOf("password-reset request has been submitted") != -1) {
                //alert('sent');
            }
            else {
                HideLoadingBar();
            }
        });

        $('#form-forgot-password').submit(function () {

            var strEmployeeCode = "", strEmail = "";
            strEmployeeCode = $('#EmployeeCode').val();
            ////strEmail = $('#EmployeeEmail').val();

            //if (strEmployeeCode.length < 6) {
            //    alert("Employee Code must have 6 digits in total.");
            //    $('#EmployeeCode').focus();
            //    return false;
            //}

            if (strEmployeeCode == "" && strEmail == "") {
                alert("Please enter both field values.");
                $('#EmployeeCode').focus();
                return false;
            }

            //if (strEmployeeCode.length < 6) {
            //    alert("The Employee Code value must be atleast 6 digits.");
            //    $('#EmployeeCode').focus();
            //    return false;
            //}

            ////if (strEmail.length < 8 || strEmail.length > 50) {
            ////    alert("The Employee Email must be bewteen 8 to 50 characters in length.");
            ////    $('#EmployeeEmail').focus();
            ////    return false;
            ////}

            $('#loading_wait').show();
            return true;

        });
    </script>
}


