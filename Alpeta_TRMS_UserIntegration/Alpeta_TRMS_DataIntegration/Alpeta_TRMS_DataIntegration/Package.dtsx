                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=16.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT Employeeid, employee_code
 FROM TRMS.dbo.Employees
WHERE NOT EXISTS (
    SELECT 1
    FROM TRMS.dbo.PersistentAttendanceLogs
    WHERE Employees.employee_code = PersistentAttendanceLogs.employee_code
	and Employees.EmployeeId = PersistentAttendanceLogs.PersistentAttendanceLogId
);</property>
