@{
    Layout = "~/Views/Shared/_EmptyLayout.cshtml";
    ViewBag.Title = "TRMS - Login";
}

@model BLL.ViewModels.LoginModel

<script src="http://ajax.googleapis.com/ajax/libs/jquery/1.7.1/jquery.min.js" type="text/javascript"></script>
<style>
.topnav {
  overflow: hidden;
  background-color: #333;
}

.topnav a {
  float: left;
  color: #f2f2f2;
  text-align: center;
  padding: 14px 16px;
  text-decoration: none;
  font-size: 17px;
}

.topnav a:hover {
  background-color: #ddd;
  color: black;
}

.topnav a.active {
  background-color: #04AA6D;
  color: white;
}

.topnav-right {
  float: right;
}

</style>
<div class="topnav">
    <div class="topnav-right">
       <table>
           <tr>
               <td style="color:white">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("languagechange"):</td>
               <td>
                   <select id="ddl_language" name="ddl_language" class="form-control">
                       <option value="Select">Select</option>
                       <option value="En">English</option>
                       <option value="Ar">Arabic</option>
                   </select>
               </td>
           </tr>
       </table>
        @*<label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("languagechange")<span class="text-danger font-14"></span></label>*@
      
    </div>

</div>
<div class="wrapper-page">
  
        <div class="row m-t-10">
        
        </div>
  
        <div class="text-center">
            <a href="/Account/Login" class="logo-lg">

                @*<i class="mdi mdi-radar"></i>*@

                <span>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("login.title")</span>
            </a>
        </div>

        <div style="display: @ViewBag.LoginFormDisplay">
            @*<form class="form-horizontal m-t-20" action="index.html">*@
            @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { @class = "form-horizontal m-t-20" }))
            {
                <div class="form-group row">
                    <div class="col-12">
                        @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("login.h1") <b>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("login.h2")</b> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("login.h3") <b>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("login.h4")</b> @*@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("login.h5")*@
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col-12">
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text"><i class="mdi mdi-account"></i></span>
                            </div>
                            <input id="UserName" name="UserName" class="form-control" type="text" required autocomplete="off" placeholder=@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("login.h2")>
                        </div>
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col-12">
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text"><i class="mdi mdi-radar"></i></span>
                            </div>
                            <input id="Password" name="Password" class="form-control" type="password" required autocomplete="off" placeholder=@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("login.h4")>
                        </div>
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col-12 text-pink">
                        @Html.ValidationSummary(true)
                        @Html.AntiForgeryToken()
                    </div>
                </div>

                <div class="form-group text-right m-t-20">
                    <div class="col-xs-12">
                        <button class="btn btn-primary btn-custom w-md waves-effect waves-light" type="submit">
                            @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("login.btn")
                        </button>
                    </div>
                </div>

                <div class="form-group row m-t-30">
                    <div class="col-sm-7">
                        <a style="@{ if (BLL.ADMIN.ForgotPassword.verifyAccessAllowed().ToString().ToLower() == "false") { <text>display: none;</text> } else { <text>display: block;</text> } }"
                           href="/Account/ForgotPassword" class="text-muted">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("login.forget")</a>
                        @*<a href="pages-recoverpw.html" class="text-muted">
                                <i class="fa fa-lock m-r-5"></i> Forgot your
                                password?
                            </a>*@
                    </div>
                    <div class="col-sm-5 text-right">
                        @*<a href="pages-register.html" class="text-muted">Create an account</a>*@
                    </div>
                </div>
    }
            @*</form>*@
        </div>

        <div style="display: @ViewBag.LicenseFormDisplay">
            <!--License Key Update -->
            @using (Html.BeginForm("LicenseKey", "Account", FormMethod.Post, new { @class = "form-horizontal m-t-20" }))
            {
                <div class="form-group row">
                    <div class="col-12">
                        Enter a Valid License Key:
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col-12">
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text"><i class="mdi mdi-account"></i></span>
                            </div>
                            <input id="LicenseKey" name="LicenseKey" class="form-control" type="text" required maxlength="35" autocomplete="off" placeholder="License Key">
                        </div>
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col-12 text-pink">
                        @Html.ValidationSummary(true)
                        @Html.AntiForgeryToken()
                    </div>
                </div>

                <div class="form-group text-right m-t-20">
                    <div class="col-xs-12">
                        <button class="btn btn-primary btn-custom w-md waves-effect waves-light" type="submit">
                            Update Now
                        </button>
                    </div>
                </div>


            }
        </div>
    </div>

<script>
        $("#ddl_language").change(function () {
            var selectedvalue = this.value;
        


            $.ajax({
                contentType: 'application/json',
                type: 'POST',
                url: "/Account/changelanguage",
                data: JSON.stringify({
                    value: selectedvalue 
                }),
                success: function (data) {
                    
                    window.location.reload();
                },
                error: function (event) {

                },
                complete: function (data) {
                },
                dataType: 'text json'
            });
        });
    $(document).ready(function () {
        var data = '@Session["GV_Langauge"]';
        $("#ddl_language").val(data);
    });
   
    </script>



