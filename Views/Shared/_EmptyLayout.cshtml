<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="A fully featured biometric attendance managment system having various modules to manage like users, departments, designations, functions, regions, locations, grups and grades. View reports include Monthly timesheet, Consolidated Attendance and Department wise reports.">
    <meta name="author" content="Coderthemes">

    <link rel="shortcut icon" href="/images/favicon.png">

    <title>TRMS - Time Resource Management System</title>

    <link href="@Href("~/plugins/switchery/switchery.min.css")" rel="stylesheet" />

    <link href="@Href("~/css/bootstrap.min.css")" rel="stylesheet" type="text/css">
    <link href="@Href("~/css/icons.css")" rel="stylesheet" type="text/css">
    <link href="@Href("~/css/style_dark.css")" rel="stylesheet" type="text/css">

    <script src="@Url.Content("/js/modernizr.min.js")"></script>

</head>
<body>

    @RenderBody()

    <script>
        var resizefunc = [];
    </script>

    <!-- Plugins  -->
    <script src="@Url.Content("/js/jquery.min.js")"></script>
    <script src="@Url.Content("/js/popper.min.js")"></script><!-- Popper for Bootstrap -->
    <script src="@Url.Content("/js/bootstrap.min.js")"></script>
    <script src="@Url.Content("/js/detect.js")"></script>
    <script src="@Url.Content("/js/fastclick.js")"></script>
    <script src="@Url.Content("/js/jquery.slimscroll.js")"></script>
    <script src="@Url.Content("/js/jquery.blockUI.js")"></script>
    <script src="@Url.Content("/js/waves.js")"></script>
    <script src="@Url.Content("/js/wow.min.js")"></script>
    <script src="@Url.Content("/js/jquery.nicescroll.js")"></script>
    <script src="@Url.Content("/js/jquery.scrollTo.min.js")"></script>
    <script src="@Url.Content("/plugins/switchery/switchery.min.js")"></script>

    <!-- Custom main Js -->
    <script src="@Url.Content("/js/jquery.core.js")"></script>
    <script src="@Url.Content("/js/jquery.app.js")"></script>

    @RenderSection("JS", required: false)

</body>
</html>



