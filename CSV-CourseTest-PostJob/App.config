    <add name="TimeTune" connectionString="Data Source=10.10.12.51; Initial Catalog=TRMS_DUHS; User Id=sa; Password=resco123; Integrated Security=False" />

    <add name="UNISDataLogMaster" connectionString="Data Source=10.10.12.51; Initial Catalog=UNISDataLog; User Id=sa; Password=resco123; Integrated Security=False" />

    <add name="UNISRegion" connectionString="Data Source=10.10.0.20; Initial Catalog=UNIS; User Id=sa; Password=resco123; Integrated Security=False" />

  </connectionStrings>-->
  <appSettings>
    <add key="CSVorDBImport" value="2" />
    <!-- 0 for CSV and 1 for SQL DB and 2 for Oracle DB -->
    
    <add key="OracleSQLQuery" value="select * from intr_cms_class_schedules order by id" />
    <!-- KEEP Empty for Prod -  <add key="OracleSQLQuery" value="select * from sysadm.std_class order by course_id" /> -->
    <add key="DefaultFilePath" value="E:\IR\TRMS_Project_DUHS\TimeTuneLatest\MvcApplication1\Uploads\" />
    <add key="DefaultFileName" value="sample-schedule-w1-t2-bds-dmc.csv" />
    <!-- 600s = 60 * 10 = 10 min-->
    <add key="DBTimeOut" value="600" />
    <add key="LogTitleText" value="(Push)" />
    <add key="LogSave" value="999" />
    <add key="IsTTLogAllowed" value="1" />
    <add key="ClientSettingsProvider.ServiceUri" value="" />
  </appSettings>
  <system.web>
    <membership defaultProvider="ClientAuthenticationMembershipProvider">
      <providers>
        <add name="ClientAuthenticationMembershipProvider" type="System.Web.ClientServices.Providers.ClientFormsAuthenticationMembershipProvider, System.Web.Extensions, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" serviceUri="" />
      </providers>
    </membership>
    <roleManager defaultProvider="ClientRoleProvider" enabled="true">
      <providers>
        <add name="ClientRoleProvider" type="System.Web.ClientServices.Providers.ClientRoleProvider, System.Web.Extensions, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" serviceUri="" cacheTimeout="86400" />
      </providers>
    </roleManager>
  </system.web>
</configuration>
