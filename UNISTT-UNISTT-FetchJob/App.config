    <connectionStrings>
    <!-- Region - UT -->
    <!--<add name="UNISTimeTuneRegion" connectionString="Data Source=192.168.1.144; Initial Catalog=UNISTimeTuneR2; User Id=sa; Password=resco@1234; Integrated Security=False" />-->
    <add name="UNISTimeTuneRegion" connectionString="Data Source=10.10.0.20; Initial Catalog=UNISTimeTune; User Id=sa; Password=resco123; Integrated Security=False" />

    <!-- Master - UT -->
    <add name="UNISTimeTuneMaster" connectionString="Data Source=10.10.12.51; Initial Catalog=UNISTimeTune; User Id=sa; Password=resco123; Integrated Security=False" />
    <add name="TimeTune" connectionString="Data Source=10.10.12.51; Initial Catalog=TRMS_DUHS; User Id=sa; Password=resco123; Integrated Security=False" />
  </connectionStrings>
    
  <appSettings>
    <add key="DBTimeOut" value="600" />
    <add key="LogTitleText" value="(Push)" />
    <add key="LogSave" value="999" />
    <add key="IsTTLogAllowed" value="1" />
  </appSettings>

</configuration>
