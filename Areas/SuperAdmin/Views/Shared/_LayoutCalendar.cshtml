    <!--FOOTER-->

    <footer class="footer">
        @DateTime.Now.Year © TRMS. All rights reserved
    </footer>

    <div style="display:none;height:0px;width:0px;">

        <form id="csvDownloadForm" method="POST" action="/CSV/getFile" enctype="multipart/form-data">
            <input id="csvDownloadData" type="hidden" name="base64stream" value="" />
            <input id="csvDownloadName" type="hidden" name="fileName" value="" />
        </form>

    </div>





    @{// SECTION for Javascript
// Keeping JS as the end of the page decreases apparent load time.
    }
    <script src="@Url.Content("/CSCAL/jquery-1.10.2.min.js")" type="text/javascript"></script> <!-- Jquery -->



    <script src="@Url.Content("/CSCAL/bootstrap-year-calendar.min.js")" type="text/javascript"></script> <!-- Jquery for bootstrap calendar -->

    <script src="@Url.Content("/CSCAL/bootstrap.min.js")" type="text/javascript"></script> <!-- Bootstrap JavaScript-->
    <script src="@Url.Content("/CSCAL/jquery-ui-1.9.2.custom.js")" type="text/javascript"></script> <!-- Jquery UI Theme -->
    <script src="@Url.Content("/CSCAL/datatables.min.js")" type="text/javascript"></script> <!-- DataTables JS -->
    <script src="@Url.Content("/CSCAL/mark.min.js")" type="text/javascript"></script> <!-- JS for marking text -->
    <script src="@Url.Content("/CSCAL/modal.js")" type="text/javascript"></script> <!-- JS for modal making -->
    <script src="@Url.Content("/CSCAL/timepicki.js")" type="text/javascript"></script> <!-- TimePicker JavaScript -->
    <script src="@Url.Content("/CSCAL/chosen.jquery.js")" type="text/javascript"></script> <!-- Chosen JavaScript -->
    <script type="text/javascript" src="@Url.Content("/CSCAL/tableexport.js")"></script>
    <script type="text/javascript" src="@Url.Content("/CSCAL/jquery.base64.js")"></script>
    <script src="@Url.Content("/js/jspdf.umd.min.js")"></script>
    <script src="@Url.Content("/js/jspdf.plugin.autotable.min.js")"></script>
    <script src="@Url.Content("/js/Amiri-Regular-normal.js")"></script>
    <script src="@Url.Content("/js/export-t.js")"></script>
    @{
        string exportLogoPath = "/Content/Logos/logo-default.png";
        try
        {
            var reportLogoTitle = new BLL.PdfReports.MonthlyTimeSheet();
            var logoTitleParts = (reportLogoTitle.getOrganizationLogoTitle() ?? "").Split('^');
            if (logoTitleParts.Length > 0 && !string.IsNullOrWhiteSpace(logoTitleParts[0]))
            {
                exportLogoPath = Url.Content(logoTitleParts[0]);
            }
        }
        catch { }
    }
    <script type="text/javascript">
        window.ExportTConfig = window.ExportTConfig || {};
        window.ExportTConfig.logoPath = '@exportLogoPath';
    </script>
    <script src="@Url.Content("/CSCAL/custom.js")" type="text/javascript"></script> <!-- custom JavaScript -->
    <script src="@Url.Content("/CSCAL/idle_timer.js")" type="text/javascript"></script>

    <script type="text/javascript">
        jQuery(document).ready(function (e) {
            var tt_exp = "20"; //set the exp time in min
            tt_exp = (parseInt(tt_exp) * 60000);
            jQuery(document).bind("idle.idleTimer", function () {
                //alert("Session Timeout"); //here you can attach any function for timeout action even ajax call too.
                location.reload();
            });

            jQuery.idleTimer(tt_exp);


        });
    </script>

    @RenderSection("JS", required: false)


    <div id="modals">

    </div>

    <div id="toast" class="toast-message" style='display:none'>Message!</div>
</body>

</html>