@model ViewModels.CreateManualAttendance
<style>
    .validation-summary-errors > ul {
        padding-left: 0px;
        color: red;
    }

        .validation-summary-errors > ul > li {
            list-style: none;
        }
</style>
<h4 style="font-weight: bold;">Attendance Management</h4>

<div class="row">
    <div class="form-group col-md-3">
        <h5 style="font-weight: bold;">Future Dated Attendance</h5>
        @using (Html.BeginForm("FutureManualAttendance", "ManageEmployees", FormMethod.Post, new { id = "attendance-form" }))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary()

            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">Employee Code</label>

                    <select id="employees" class="form-control" name="employee_code" required></select>


                    @*<select class="chzn-select" name="employee_code" style="width:100%;">
                            <option selected="selected" disabled="disabled" value="0">Select EmployeeCode</option>
                            @foreach (ViewModels.Employee item in Model.employee)
                            {
                                <option value="@item.employee_code">@item.employee_code</option>
                            }
                        </select>*@
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">Date From</label>
                    <input type="text" class="form-control datepicker" id="from_date" name="time_in_from" required>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">Date To</label>
                    <input type="text" class="form-control datepicker" id="to_date" name="time_in_to" required>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <label class=".chzn-select control-label">Result</label>
                    <select class="form-control" name="remarks" style="width:100%;">
                        <option disabled="disabled" selected="selected">Select an option</option>
                        <option value="OV">Official Visit - OV</option>
                        <option value="OM">Meeting - OM</option>
                        <option value="OT">Official Training - OT</option>
                    </select>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12" style="margin-top:5px">
                    <button id="update" type="submit" value="Submit">Update Attendance</button>
                </div>
            </div>
    <br><br>
    <label class="label" style="font-size:medium; color:red"> @ViewBag.Message</label>
        }
    </div>

</div>

<div class="row" style="margin-bottom:5px">
    <table id="attendance_table" class="display cell-border" width="100%">
        <thead>

            <tr>
                <th>From Date</th>
                <th>To Date</th>
                <th>Employee Code</th>
                <th>Remarks</th>
                
            </tr>

        </thead>
        <tbody></tbody>
    </table>
    <button type="submit" id="btnExport" style="margin-top:5px">Export Grid Data</button>


</div>
<br><br><br><br><br><br><br><br>

@section JS {

    <script type="text/javascript" src="@Href("~/Scripts/chosen.ajaxaddition.jquery.js")"></script>
    <script>

        $(document).ready(function () {
            $('#accordion').accordion("option", "active", 1);
            setActiveLink("Add Future Manual Attendance");
            $(".chzn-select").chosen();
            $(".datepicker").datepicker({ dateFormat: 'yy-mm-dd' });
            $("input[type=submit], button").button();


            $('#btnExport').button();
            $("#btnExport").click(function (e) {

            setupTableExportButton('#attendance_table',  'ManualAttendance');
            e.preventDefault();
            });

            /*
            $('#btnExport').button();
            $("#btnExport").click(function (e) {
                $('#attendance_table').tableExport({ type: 'excel', escape: 'false' });
                e.preventDefault();
            });

            */


            //initDataTable("#leavebalance_table");


            $('#employees').ajaxChosen({
                dataType: 'json',
                type: 'POST',
                url: '@Url.Action("getEmployeeDropDown", "ManageEmployees", null, Request.Url.Scheme)'
            }, {
                loadingImg: '@Href("~/Content/ChosenAutoComplete/loading.gif")'
            });




            var url = '@Url.Action("FutureManualAttendanceDataHandler", "ManageEmployees", null, Request.Url.Scheme)';

            var columns = [
                   { "data": "from_date" },
                   { "data": "to_date" },
                   { "data": "employee_code" },
                   { "data": "remarks" }

            ];

        @*
               I did this so that like initDataTables the JS
            for serverside processing can be used for other tables.
                NOTE: The names of the columns correspond to the View Model.
            For example in this example the column names, first_name, last_name
            etc are taken from ViewModels.Employee
        *@

            initServerSideTable('#attendance_table', url, columns);
        });

        $('#attendance-form').on("submit", function (e) {


            fDate = $('#attendance-form').find('[name*="time_in_from"]').val().split("-").reverse();
            tDate = $('#attendance-form').find('[name*="time_in_to"]').val().split("-").reverse();


            fDate = new Date(fDate[2] + "-" + fDate[1] + "-" + fDate[0]);
            tDate = new Date(tDate[2] + "-" + tDate[1] + "-" + tDate[0]);
            var timeDiff = Math.abs(tDate.getTime() - fDate.getTime());
            var diffDays = Math.abs(tDate.getDate()-fDate.getDate());
            var diffDays = parseInt(diffDays) + 1;
            var today = new Date();
            console.log(today.getDate());
            if (today >= fDate)
            {
                alert("Please select greater date");
                return false;
            }
            else
            {
                if (tDate < fDate) {
                    alert("To date should be greater than from date.");
                    return false;
                }

                var r = confirm("Are you sure you want to Update Attendance of " + diffDays + " day(s)");
                if (r == false) {
                    return false;
                }


                return true;
            }
          

        });




    </script>
}