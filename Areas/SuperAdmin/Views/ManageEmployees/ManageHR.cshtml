@{
    ViewBag.Title = "TRMS - HR Management";
    Layout = "~/Areas/SuperAdmin/Views/Shared/_Layout.cshtml";
}

@model List<ViewModels.Employee>

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'SuperAdmin'</span>! [Login ID: <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@User.Identity.Name</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/SuperAdmin">SuperAdmin</a></li>
                    <li class="breadcrumb-item active">HR Management</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> HR Management </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-4">

                            @using (Html.BeginForm("AddHr", "ManageEmployees"))
                            {

                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">Select Employee</label>
                                        <select id="employees" class="form-control" name="emp-id" required></select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Campus-Code or Super-HR</label>
                                        <select id="campuses" class="form-control" name="campus-id" required>
                                            @{
                                                if (ViewBag.CampusesList != null)
                                                {
                                                    foreach (ViewModels.OrganizationCampusView c in ViewBag.CampusesList as List<ViewModels.OrganizationCampusView>)
                                                    {
                                                        <option value="@c.Id">@c.CampusCode</option>
                                                    }
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Is Super HR? (Leaves Approver of other HRs)</label>
                                        <select id="is-super-hr" class="form-control" name="is-super-hr" required>
                                            <option value="false">No</option>
                                            <option value="true">Yes</option>
                                        </select>
                                    </div>
                                </div>


                                <div class="row">
                                    <div class="col-12 text-danger">
                                        @Html.AntiForgeryToken()
                                        @Html.ValidationSummary()
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12">
                                        <button type="submit" class="btn btn-primary waves-effect waves-light m-t-10">Create HR Account</button>&nbsp;
                                    </div>
                                </div>
                                                }

                        </div>

                    </div>


                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <!-- Page-Title -->
    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">

                @*<h1 class="m-t-0 header-title">Currently set in HR Users</h1>*@

                <div class="row">
                    <div class="col-12">
                        <table id="hr_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">
                            <thead>
                                <tr>
                                    <th>Employee Code</th>
                                    <th>Campus Code</th>
                                    <th>Full Name</th>
                                    <th>Is Super HR?</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (ViewModels.Employee emp in Model)
                                {
                                    <tr>
                                        <td>@emp.employee_code</td>
                                        <td>@emp.campus_name</td>
                                        <td>@emp.first_name&nbsp;@emp.last_name</td>
                                        <td>@emp.is_super_hr_str</td>
                                        <td>
                                            <div>
                                                <a href="javascript:void(deleteHr(@emp.id));">Remove HR Access</a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="row m-t-10">
                    <div class="col-12">
                        <button type="submit" id="btnExport" class="btn btn-primary waves-effect waves-light">Export Grid Data</button>

                    </div>
                </div>

                <div class="row m-t-10" style="display:none;height:0px;width:0px;">
                    <div class="col-12">
                        @using (Html.BeginForm("DeleteHr", "ManageEmployees", FormMethod.Post, new { id = "deletehr-form" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.ValidationSummary()

                            <input type="hidden" id="hr-to-delete" name="emp-id" />

                            <input type="submit" value="submit" />
                        }
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- End content -->

@section JS {
    <script type="text/javascript" src="@Href("~/Scripts/chosen.ajaxaddition.jquery.js")"></script>
    <script>

        function deleteHr(id) {

            $('#hr-to-delete').val(id);
            $('#deletehr-form').submit();
        }

        $(document).ready(function () {
            //$('#accordion').accordion("option", "active", 1);
            //$("input[type=submit], button").button();

            initDataTable('#hr_table');

            //$('#btnExport').button();
            $("#btnExport").click(function (e) {
                setupTableExportButton('#hr_table', 'Functions');
                e.preventDefault();
            });



            //setActiveLink("Manage HRs");



            $('#employees').ajaxChosen({
                dataType: 'json',
                type: 'POST',
                url: '@Url.Action("getAllNonHrsDataHandler", "ManageEmployees", null, Request.Url.Scheme)'
            }, {
                loadingImg: '@Href("~/Content/ChosenAutoComplete/loading.gif")'
            });


        });

    </script>
}
