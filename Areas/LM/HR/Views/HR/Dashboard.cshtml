        <div class="row tile_count" style="color:#008269">
            <div class="col-md-3 col-sm-4 col-xs-6 tile_stats_count">
                <span class="count_top"><i class="fa fa-user"></i>Present</span>
                <div class="count">@Model.dashboardElement.present</div>
                <span class="count_bottom" style="color:#000"><i class="green"></i>For Last 30 Days</span>
            </div>
            <div class="col-md-3 col-sm-4 col-xs-6 tile_stats_count">
                <span class="count_top"><i class="fa fa-clock-o"></i>Late</span>
                <div class="count">@Model.dashboardElement.late</div>
                <span class="count_bottom" style="color:#000"><i class="green"></i>For Last 30 Days</span>
            </div>
            <div class="col-md-3 col-sm-4 col-xs-6 tile_stats_count">
                <span class="count_top"><i class="fa fa-user"></i>Absent</span>
                <div class="count green">@Model.dashboardElement.absent</div>
                <span class="count_bottom" style="color:#000"><i class="green"></i>For Last 30 Days</span>
            </div>
          <div class="col-md-3 col-sm-4 col-xs-6 tile_stats_count">
                <span class="count_top"><i class="fa fa-user"></i>Early Out</span>
                <div class="count">@Model.dashboardElement.earlyGone</div>
              <span class="count_bottom" style="color:#000"><i class="green"></i>For Last 30 Days</span>
            </div>
