@model List<ViewModels.Department>


<h4 style="font-weight: bold;">Employee Management</h4>
<div class="row">
    <div class="form-group col-md-3">
        <h5 style="font-weight: bold;">Register Department</h5>
        @using (Html.BeginForm("AddDepartment", "EmployeeManagement"))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary()
            <div class="row">

                <div class="col-md-12">
                    <label class="control-label">Department Name</label>
                    <input type="text" pattern=".{2,}" title="2 characters minimum" class="form-control" id="fname" name="name"
                           oninput="setCustomValidity('');" oninvalid="setCustomValidity('Name should contain at least 2 characters.');" required />
                </div>
            </div>

            <div class="row">

                <div class="col-md-12">
                    <label class="control-label">Description</label>
                    <textarea class="form-control" name="description"></textarea>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12" style="margin-top:5px">
                    <button type="submit" value="Submit">Add Department</button>

                    <button type="reset" value="Reset">Reset</button>

                </div>
            </div>
        }
    </div>
    <div class="col-md-9">
        <h5 style="font-weight: bold;">Current Departments</h5>
        <table id="department_table" class="display cell-border" width="100%">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Department Name</th>
                    <th>Department Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
        <button type="submit" id="btnExport" style="margin-top:5px">Export excel</button>
        
    </div>
</div>


@section JS {
    <script>
        $(document).ready(function () {
            $('#accordion').accordion("option", "active", 1);
            $("input[type=submit], button").button();


            setupTableExportButton('#department_table', '#btnExport', 'Departments');

            /*
            $('#btnExport').button();
            $("#btnExport").click(function (e) {
                $('#department_table').tableExport({ type: 'excel', escape: 'false' });
                e.preventDefault();
            });
            */

            
            var url = '@Url.Action("DepartmentDataHandler", "EmployeeManagement", null, Request.Url.Scheme)';

            var columns = [
                  { "data": "id" },
                  { "data": "name" },
                  { "data": "description" },
                  { "data": "actions" }

            ];

            initServerSideTable('#department_table', url, columns);
            editDepartment = initEditModal("#modals", '@Url.Action("UpdateDepartment", "EmployeeManagement", null, Request.Url.Scheme)', "Department");
            deleteDepartment = initDeleteModal("#modals", '@Url.Action("RemoveDepartment", "EmployeeManagement", null, Request.Url.Scheme)', "Department");
            setActiveLink("Department");


        });
    </script>
}
