

<h4 style="font-weight: bold;">Employee Management</h4>
<div class="row">
    <div class="form-group col-md-3">
        <h5 style="font-weight: bold;">Manage Employee Hierarchy</h5>
        <form>
            <div class="row">

                <div class="col-md-12">
                    <label class="control-label">Supervisor</label>
                        <select class="form-control">
                            <option selected="selected" disabled="disabled">Select Employee</option>
                            <option>1</option>
                            <option>2</option>
                            <option>3</option>
                            <option>4</option>
                            <option>5</option>
                        </select>
                    </div>
            </div>

            <div class="row">

                <div class="col-md-12">
                    <input type="checkbox" name="select-deselect" value="value1"/>Select/Deselect All<br />
                </div>
            </div>

            <div class="row">
                <div class="col-md-12" style="margin-top:5px">
                    <button type="submit" value="Submit">Register</button>
                     <button type="reset" value="Reset">Reset</button>
                   
                </div>
            </div>
        </form>
    </div>
    
</div>


@section JS {
    <script>
        $(document).ready(function () {
            $('#accordion').accordion("option", "active", 1);

            $("input[type=submit], button").button();

            setActiveLink("Employee Hierarchy");

            initDataTable("#designation_table");

        });



    </script>
}
