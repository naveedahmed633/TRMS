@model List<ViewModels.Function>

<h4>Employee Management</h4>

<div class="row">
    <div class="form-group col-md-3">
        <h5>Register Function</h5>
        @using (Html.BeginForm("AddFunction", "EmployeeManagement"))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary()
            <div class="row">

                <div class="col-md-12">
                    <label class="control-label">Function Name</label>
                    <input type="text" pattern=".{2,}" title="2 characters minimum" class="form-control" id="fname" name="name"
                           oninput="setCustomValidity('');" oninvalid="setCustomValidity('Name should contain at least 2 characters.');" required/>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">Description</label>
                    <textarea class="form-control" name="description"></textarea>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12" style="margin-top:5px">
                    <button type="submit" value="Submit">Add Function</button>


                    <button type="reset" value="Reset">Reset</button>
                </div>
            </div>
        }
    </div>

    <div class="col-md-9">
        <h5>Current Functions</h5>

        <table id="function_table" class="display cell-border" width="100%">
            <thead>

                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>description</th>
                    <th>Actions</th>
                </tr>

            </thead>
            <tbody>


            </tbody>
        </table>
        <button type="submit" id="btnExport" style="margin-top:5px">Export excel</button>

    </div>
  
</div>

              
            

@section JS {
    <script>
    $(document).ready(function () {
        $('#accordion').accordion("option", "active", 1);
        $("input[type=submit], button").button();


        setupTableExportButton('#function_table', '#btnExport', 'Functions');

        /*
        $('#btnExport').button();
        $("#btnExport").click(function (e) {
            $('#function_table').tableExport({ type: 'excel', escape: 'false' });
            e.preventDefault();
        });
        */



        setActiveLink("Function");

        var url = '@Url.Action("FunctionDataHandler", "EmployeeManagement", null, Request.Url.Scheme)';

        var columns = [
                  { "data": "id" },
                  { "data": "name" },
                  { "data": "description" },
                  { "data":"actions" }

            ];
            initServerSideTable('#function_table', url, columns);
            editFunction = initEditModal("#modals", '@Url.Action("UpdateFunction", "EmployeeManagement", null, Request.Url.Scheme)', "Function");
            deleteFunction = initDeleteModal("#modals", '@Url.Action("RemoveFunction", "EmployeeManagement", null, Request.Url.Scheme)', "Function");
        });





    </script>
}
