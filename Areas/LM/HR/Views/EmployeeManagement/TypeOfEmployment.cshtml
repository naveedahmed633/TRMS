@model List<ViewModels.TypeOfEmployment>


<h4 style="font-weight: bold;">Employee Management</h4>
<div class="row">
    <div class="form-group col-md-3">
        <h5 style="font-weight: bold;">Register Type Of Employment</h5>
        @using (Html.BeginForm("AddTypeOfEmployment", "EmployeeManagement"))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary()
            <div class="row">

                <div class="col-md-12">
                    <label class="control-label">Type Name</label>
                    <input type="text" pattern=".{2,}" title="2 characters minimum" class="form-control" id="fname" name="name"
                           oninput="setCustomValidity('');" oninvalid="setCustomValidity('Name should contain at least 2 characters.');" required />
                </div>
            </div>

            <div class="row">

                <div class="col-md-12">
                    <label class="control-label">Description</label>
                    <textarea class="form-control" name="description"></textarea>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12" style="margin-top:5px">
                    <button type="submit" value="Submit">Add Type</button>

                    <button type="reset" value="Reset">Reset</button>

                </div>
            </div>
        }
    </div>
    <div class="col-md-9">
        <h5 style="font-weight: bold;">Current Types of Employments</h5>
        <table id="typeofemployment_table" class="display cell-border compact">
            <thead>
                <tr>
                    <th>Type Name</th>
                    <th>Type Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (ViewModels.TypeOfEmployment typeofemployment in Model)
                {
                    <tr data-row="@typeofemployment.id">
                        <td>@typeofemployment.name</td>
                        <td>@typeofemployment.description</td>
                        <td class="dt-center">
                            <div>
                                <a href="javascript:void(editTypeOfEmployment(@typeofemployment.id,'@typeofemployment.name','@typeofemployment.description'));">Edit</a>
                                <span>/</span>
                                <a href="javascript:void(deleteTypeOfEmployment(@typeofemployment.id));">Delete</a>
                            </div>

                        </td>
                    </tr>
                }

            </tbody>
        </table>
        <button type="submit" id="btnExport" style="margin-top:5px">Export excel</button>

    </div>
</div>


@section JS {
    <script>
        $(document).ready(function () {
            $('#accordion').accordion("option", "active", 1);
            $("input[type=submit], button").button();
            initDataTable("#typeofemployment_table");


            setupTableExportButton('#typeofemployment_table', '#btnExport', 'TypeOfEmployees');

            /*
            $('#btnExport').button();
            $("#btnExport").click(function (e) {
                $('#typeofemployment_table').tableExport({ type: 'excel', escape: 'false' });
                e.preventDefault();
            });
            */



            editTypeOfEmployment = initEditModal("#modals", '@Url.Action("UpdateTypeOfEmployment", "EmployeeManagement", null, Request.Url.Scheme)', "TypeOfEmployment");
            deleteTypeOfEmployment = initDeleteModal("#modals", '@Url.Action("RemoveTypeOfEmployment", "EmployeeManagement", null, Request.Url.Scheme)', "TypeOfEmployment");
            setActiveLink("Type of Employment");


        });
    </script>
}
