@model ViewModels.CreateManualAttendance
<style>
    .validation-summary-errors > ul {
        padding-left: 0px;
        color: red;
    }

        .validation-summary-errors > ul > li {
            list-style: none;
        }
</style>
<h4 style="font-weight: bold;">Attendance Management</h4>

<div class="row">
    <div class="form-group col-md-3">
        <h5 style="font-weight: bold;">Past Attendance</h5>
        @using (Html.BeginForm("AddManualAttendance", "AttendanceManagement", FormMethod.Post, new { id = "attendance-form" }))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary()

            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">Employee Number</label>

                    <select id="employees" class="form-control" name="employee_code" required>

                    </select>


                    @*<select class="chzn-select" name="employee_code" style="width:100%;">
                        <option selected="selected" disabled="disabled" value="0">Select EmployeeCode</option>
                        @foreach (ViewModels.Employee item in Model.employee)
                        {
                            <option value="@item.employee_code">@item.employee_code</option>
                        }
                    </select>*@
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">Date From</label>
                    <input type="text" class="form-control datepicker" id="from_date" name="time_in_from" required>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">Date To</label>
                    <input type="text" class="form-control datepicker" id="to_date" name="time_in_to" required>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">Reasons</label>
                    <select class="chzn-select" name="remarks" style="width:100%;">
                        <option disabled="disabled" selected="selected">Select an option</option>
                        <option value="AB">Absent - AB</option>
                        <option value="PLO">Present Late - PLO</option>
                        <option value="PO">Present On Time - PO</option>
                        <option value="OFF">Off - OFF</option>
                        <option value="POE">Early Out-POE</option>
                    </select>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12" style="margin-top:5px">
                    <button id="update" type="submit" value="Submit">Update Attendance</button>
                </div>
            </div>

        }
    </div>
    @using (Html.BeginForm("UploadFileManualAttendance", "AttendanceManagement", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary()

        <div class="row">
            <div class="col-md-4">
                <label class="btn btn-primary" for="my-file-selector" style="margin-left: 15px">
                    <input id="my-file-selector" onchange="alertFilename()" type="file" name="file" value="alert" accept=".csv" style="display:none; ">
                    Click to select file
                </label>
                <h3 class="label" style="font-size:medium; color:black" id="file-name"></h3>
            </div>

            <div class="col-md-4" style="margin-top:5px">
                <button id="btnUpload" type="submit" value="Submit">Upload File</button>
                <label class="label" style="font-size:medium; color:black"> @ViewBag.Message</label>
            </div>
        </div>
    }
</div>
<br><br><br><br>
<div class="row" style="margin-bottom:5px">
    <table id="attendance_table" class="display cell-border" width="100%">
        <thead>

            <tr>
                <th>Date</th>
                <th>Employee Number</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Time In</th>
                <th>Remarks</th>
                <th>Time Out</th>
                <th>Remarks</th>
                <th>Final Remarks</th>
                <th>Device In</th>
                <th>Device Out</th>
            </tr>

        </thead>
        <tbody></tbody>
    </table>
    <button type="submit" id="btnExport" style="margin-top:5px">Export excel</button>


</div>








@section JS {

    <script type="text/javascript" src="@Href("~/Scripts/chosen.ajaxaddition.jquery.js")"></script>
    <script>
        
        $(document).ready(function () {
            $('#accordion').accordion("option", "active", 4);
            setActiveLink("Manual Attendance");
//            $(".chzn-select").chosen();
            $(".datepicker").datepicker({ dateFormat: 'yy-mm-dd' });
            $("input[type=submit], button").button();

            


            setupTableExportButton('#attendance_table', '#btnExport', 'ManualAttendance');


            /*
            $('#btnExport').button();
            $("#btnExport").click(function (e) {
                $('#attendance_table').tableExport({ type: 'excel', escape: 'false' });
                e.preventDefault();
            });

            */


            //initDataTable("#leavebalance_table");


            $('#employees').ajaxChosen({
                dataType: 'json',
                type: 'POST',
                url: '@Url.Action("ChangeEmployeePasswordDataHandler", "EmployeeManagement", null, Request.Url.Scheme)'
            }, {
                loadingImg: '@Href("~/Content/ChosenAutoComplete/loading.gif")'
            });






            var url = '@Url.Action("DataHandler", "AttendanceManagement", null, Request.Url.Scheme)';

            var columns = [
                  { "data": "date" },
                   { "data": "employee_code" },
                   { "data": "employee_first_name" },
                   { "data": "employee_last_name" },
                   { "data": "time_in" },
                   { "data": "status_in" },
                   { "data": "time_out" },
                   { "data": "status_out" },
                   { "data": "final_remarks" },
                   { "data": "terminal_in" },
                   { "data": "terminal_out" }

            ];

        @*
               I did this so that like initDataTables the JS
            for serverside processing can be used for other tables.
                NOTE: The names of the columns correspond to the View Model.
            For example in this example the column names, first_name, last_name
            etc are taken from ViewModels.Employee
        *@

            initServerSideTable('#attendance_table', url, columns);
        });

        $('#attendance-form').on("submit", function (e) {
            
            
            fDate = $('#attendance-form').find('[name*="time_in_from"]').val().split("-").reverse();
            tDate = $('#attendance-form').find('[name*="time_in_to"]').val().split("-").reverse();

            
            fDate = new Date(fDate[2] + "-" + fDate[1] + "-" + fDate[0]);
            tDate = new Date(tDate[2] + "-" + tDate[1] + "-" + tDate[0]);
            
            
            if (tDate < fDate) {
                alert("To date should be greater than from date.");
                return false;
            }

            var r = confirm("Are you sure you want to Update?");
            if (r == false) {
                return false;
            }

            return true;
            
        });

        


    </script>
}