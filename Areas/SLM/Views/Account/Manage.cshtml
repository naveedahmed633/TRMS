@{
    ViewBag.Title = "TRMS - Change Password";
    Layout = "~/Areas/SLM/Views/Shared/_Layout.cshtml";
}

@model BLL.ViewModels.LocalPasswordModel

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'SLM'</span>! [Login ID: <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/SLM/SLM/Dashboard">SLM</a></li>
                    <li class="breadcrumb-item active">Change Password</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="mdi mdi-account-box"></i> Change Password </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    @if (Request.QueryString["Message"] != null && Request.QueryString["Message"].ToString() == "ChangePasswordSuccess")
                    {
                        <div class="form-group row">
                            <div class="col-10 text-success">
                                Your password has been changed successfully!!!
                            </div>
                        </div>
                    }

                    @using (Html.BeginForm("Manage", "Account", FormMethod.Post, new { id = "chg_pass" }))
                    {
                        <div class="row">
                            <div class="col-4">
                                <label class="control-label">Old Password</label>
                                <input type="password" class="form-control" id="OldPassword" name="OldPassword" required />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-4 m-t-10">
                                <label class="control-label" for="example-email">New Password</label>
                                <input type="password" class="form-control" id="NewPassword" name="NewPassword" required />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-4 m-t-10">
                                <label class="control-label" for="example-email">Confirm Password</label>
                                <input type="password" class="form-control" id="ConfirmPassword" name="ConfirmPassword" required />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12 text-danger">
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary()
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary waves-effect waves-light">Change Password</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
<!-- End content -->

@section JS {
    @*@Scripts.Render("~/bundles/jqueryval")*@
    <script>

        $(document).ready(function () {
            //$('#accordion').accordion("option", "active", 0);
            //setActiveLink("Change Password");

            //$("input[type=submit], button").button();

            $('#chg_pass').on("submit", function () {
                var password = $("#NewPassword").val();
                var confirmPassword = $("#ConfirmPassword").val();
                if (password != confirmPassword) {
                    alert("Passwords do not match. Re-enter passwords");
                    return false;
                } else if (!followsPasswordPolicy(password)) {
                    alert("Your password must be at least 6 characters long and must contain at least, 1 small letter, 1 capital letter, 1 number, and 1 of the following special characters. ! @@ # $ % ^ & * ( ) _ - ");
                    return false;
                }
                return true;

            });

        });



    </script>
}

