@{
    ViewBag.Title = "TRMS - View Attendance";
    Layout = "~/Areas/SLM/Views/Shared/_Layout.cshtml";
}

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'SLM'</span>! [Login ID: <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/SLM/SLM/Dashboard">SLM</a></li>
                    <li class="breadcrumb-item active">View Attendance</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="mdi mdi-file-document"></i> Attendance Log - @Model.employee_first_name @Model.employee_last_name (@Model.employee_code): @Model.date</h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-md-3 col-sm-4 col-xs-6 tile_stats_count">
                            <span class="h4"><i class="fa fa-clock-o"></i> Time In</span>
                            <div class="text">@Model.time_in</div>
                        </div>
                        <div class="col-md-3 col-sm-4 col-xs-6 tile_stats_count">
                            <span class="h4"><i class="fa fa-clock-o"></i> Time Out</span>
                            <div class="text">@Model.time_out</div>
                        </div>
                        <div class="col-md-3 col-sm-4 col-xs-6 tile_stats_count">
                            <span class="h4"><i class="mdi mdi-hospital-building"></i> Terminal In</span>
                            <div class="text">@Model.terminal_in</div>
                        </div>
                        <div class="col-md-3 col-sm-4 col-xs-6 tile_stats_count">
                            <span class="h4"><i class="mdi mdi-hospital-building"></i> Terminal Out</span>
                            <div class="text">@Model.terminal_out</div>
                        </div>
                    </div>

                    <hr />

                    <div class="row">
                        <div class="col-12">
                            <table id="attendance_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%">
                                <thead>

                                    <tr>
                                        <th>First Name</th>
                                        <th>Last Name</th>
                                        <th>Employee Code</th>
                                        <th>Date</th>
                                        <th>Time In</th>
                                        <th>Time Out</th>
                                        <th>Device In</th>
                                        <th>Device Out</th>
                                    </tr>

                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <hr />

                    <div class="row">
                        <div class="col-12">
                            <button type="submit" id="btnExport" class="btn btn-primary waves-effect waves-light">Export Grid Data</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- End content -->

@section JS {
    <script>
    $(document).ready(function () {
        //$('#accordion').accordion("option", "active",1);
        //setActiveLink("View Attendance");


        //$('#btnExport').button();
        $("#btnExport").click(function (e) {
        setupTableExportButton('#attendance_table', 'ViewAttendance');
            e.preventDefault();
        });


        /*
        $('#btnExport').button();
        $("#btnExport").click(function (e) {
            $('#attendance_table').tableExport({ type: 'excel', escape: 'false' });
            e.preventDefault();
        });
        */



        var url = '@Url.Action("PersistentDataHandler", "AttendanceManagement", null, Request.Url.Scheme)';

        var columns = [

               { "data": "employee_first_name" },
               { "data": "employee_last_name" },
               { "data": "employee_code" },
               { "data": "date" },
               { "data": "time_in" },
               { "data": "time_out" },
               { "data": "terminal_in" },
               { "data": "terminal_out" }

        ];

        @*
               I did this so that like initDataTables the JS
        for serverside processing can be used for other tables.
            NOTE: The names of the columns correspond to the View Model.
        For example in this example the column names, first_name, last_name
        etc are taken from ViewModels.Employee
            *@

        initServerSideTable('#attendance_table', url, columns);
    });
    </script>
}