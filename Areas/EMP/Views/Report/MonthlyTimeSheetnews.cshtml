@{
    ViewBag.Title = "TRMS - Monthly Timesheet";
    Layout = "~/Areas/EMP/Views/Shared/_Layout.cshtml";

    string EMP_STD_LEC_LoginUserType = "";
    if (MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeFunctionSLSID.ToString().Contains("student"))
    {
        EMP_STD_LEC_LoginUserType = "STD";
    }
    else if (MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeFunctionSLSID.ToString().Contains("lecturer"))
    {
        EMP_STD_LEC_LoginUserType = "LEC";
    }
    else
    {
        EMP_STD_LEC_LoginUserType = "EMP";
    }
}

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.welcome")  <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span></h4>
                 <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/EMP/EMP/Dashboard">@EMP_STD_LEC_LoginUserType</a></li>
                    <li class="breadcrumb-item active">Reports</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("lblmonthlytitle") </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-12">
                            @using (Html.BeginForm("MonthlyTimeSheetnews", "Report", FormMethod.Post, new { id = "monthly-time-sheet-form" }))
                            {
                                <div class="row">
                                    <div class="col-4">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("select.month") <span class="text-danger font-14">*</span></label>
                                        <select id="monthly-time-sheet-month" class="chzn-select w-100" name="month" required>
                                            <option selected="selected" disabled="disabled" value="0">Month of Year</option>
                                            @{
                                                string s01 = "", s02 = "", s03 = "", s04 = "", s05 = "", s06 = "", s07 = "", s08 = "", s09 = "", s10 = "", s11 = "", s12 = "";
                                                int year = DateTime.Now.Year;
                                                for (int y = year; y >= (year - 3); y--)
                                                {
                                                    if (y == year && DateTime.Now.Month == 1)
                                                    {
                                                        s01 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 2)
                                                    {
                                                        s02 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 3)
                                                    {
                                                        s03 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 4)
                                                    {
                                                        s04 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 5)
                                                    {
                                                        s05 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 6)
                                                    {
                                                        s06 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 7)
                                                    {
                                                        s07 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 8)
                                                    {
                                                        s08 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 9)
                                                    {
                                                        s09 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 10)
                                                    {
                                                        s10 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 11)
                                                    {
                                                        s11 = "selected";
                                                    }
                                                    else if (y == year && DateTime.Now.Month == 12)
                                                    {
                                                        s12 = "selected";
                                                    }

                                                    <option value="@(y + "-01")" @s01>@("Jan - " + y)</option>
                                                    <option value="@(y + "-02")" @s02>@("Feb - " + y)</option>
                                                    <option value="@(y + "-03")" @s03>@("Mar - " + y)</option>
                                                    <option value="@(y + "-04")" @s04>@("Apr - " + y)</option>
                                                    <option value="@(y + "-05")" @s05>@("May - " + y)</option>
                                                    <option value="@(y + "-06")" @s06>@("Jun - " + y)</option>
                                                    <option value="@(y + "-07")" @s07>@("Jul - " + y)</option>
                                                    <option value="@(y + "-08")" @s08>@("Aug - " + y)</option>
                                                    <option value="@(y + "-09")" @s09>@("Sep - " + y)</option>
                                                    <option value="@(y + "-10")" @s10>@("Oct - " + y)</option>
                                                    <option value="@(y + "-11")" @s11>@("Nov - " + y)</option>
                                                    <option value="@(y + "-12")" @s12>@("Dec - " + y)</option>

                                                    s01 = ""; s02 = ""; s03 = ""; s04 = ""; s05 = ""; s06 = ""; s07 = ""; s08 = ""; s09 = ""; s10 = ""; s11 = ""; s12 = "";
                                                }
                                            }

                                        </select>
                                        @*<input id="monthly-time-sheet-month" type="text" name="month" class="form-control monthPicker" autocomplete="off" required />*@
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12 text-danger">
                                        @Html.AntiForgeryToken()
                                        @Html.ValidationSummary()
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12">
                                        <button type="submit" id="search-consolidated-report" onclick="clearr();" class="btn btn-primary waves-effect waves-light m-t-10">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.search")</button>
                                        <button type="button" class="btn btn-primary waves-effect waves-light m-t-10" onclick="redirectToPage();">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.reset")</button>
                                    </div>
                                </div>                                
                            }
                        </div>
                    </div>
 
            
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    
                    <div class="row">
                        <div class="col-12">
                            <table id="attendance_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">

                                <thead>
                                    <tr>
                                      
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("llbldate")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("lblday")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("monthly.timein")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("atendance.timeout")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("monthly.st")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("preremarks")</th>
                                    
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" onclick="ExortExcleBar();" class="btn btn-primary waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.expo")</button>
                            <button type="submit" id="generate-monthly-time-sheet" form="monthly-time-sheet-form" class="btn btn-primary waves-effect waves-light" style="display: @ViewData["PDFDownloadEnabled"];" onclick="return validateFormInfo();">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exportpdf")</button>
                            <span id="export_wait" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></span><span id="pdf-no-data-found" class="text-danger">@ViewData["PDFNoDataFound"]</span>
                            <span id="demo" class="text-danger"></span>
                            <p id="export_wait2" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- End content -->
<div class="modal fade bs-example-modal-sm" tabindex="-1" role="dialog" aria-labelledby="mySmallModalLabel" aria-hidden="true" style="display: none;">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                <h4 class="modal-title" id="mySmallModalLabel">Message Alert</h4>
            </div>
            <div class="modal-body">
                <span id="alert_message"></span>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->

@section JS {

    <script type="text/javascript" src="@Href("~/Scripts/chosen.ajaxaddition.jquery.js")"></script>
    @*<script type="text/javascript" src="@Href(" ~/Scripts/GenerateReports.js")"></script>*@
    <script type="text/javascript" src="@Href("~/Scripts/monthpicker.js")"></script>


    <script>
        function redirectToPage() {
            window.location.reload();
        }
        // ----------------------- Added by IR ------------------------

        function validateFormInfo() {

            if ($('#monthly-time-sheet-month').val() == null || $('#monthly-time-sheet-month').val() == "") {
                $('#alert_message').text("Please select a Month");
                $('.bs-example-modal-sm').modal('show');
                //$('#monthly-time-sheet-employees').focus();
                return false;
            }

            $('#export_wait').show();

            $('#pdf-no-data-found').val("");
            $('#pdf-no-data-found').text("");

            myFunction();
        }

        function myFunction() {
            setTimeout(function () { $('#export_wait').hide(); document.getElementById("generate-monthly-time-sheet").disabled = false; }, 2000);
        }

        function submitcheck() {

            var fDate = $('[name="month"]').val();
            var tDate = $('[name="month"]').val();

            var lastDay = GetLastDayOfMonth(fDate.split("-")[1], fDate.split("-")[0]);

            fDate = fDate.replace("-", "-01-");
            tDate = tDate.replace("-", "-" + lastDay + "-");

            //console.log('1>> ' + fDate + ' - ' + tDate);

            fDate = fDate.split("-").reverse()
            tDate = tDate.split("-").reverse();

            //console.log('2>> ' + fDate + ' - ' + tDate);

            fDate = new Date(fDate[0] + "-" + fDate[1] + "-" + fDate[2]);
            tDate = new Date(tDate[0] + "-" + tDate[1] + "-" + tDate[2]);

            //console.log('3>> ' + fDate + ' - ' + tDate);

            //return false;

            if (tDate < fDate) {
                alert("The 'To Date' should be greater than 'From Date'.");
                return false;
            }


            searchReport();
            return true;

        }



        function GetLastDayOfMonth(m, y) {

            var lastDay = 28;

            if (m == "04" || m == "06" || m == "09" || m == "11") {
                lastDay = 30;
            }
            else if (m == "02") {
                if ((y % 4) == 0) {
                    lastDay = 29;
                }
                else {
                    lastDay = 28;
                }
            }
            else {
                lastDay = 31;
            }

            return lastDay;
        }

        function searchReport() {
            // get the entered string
            var toSearch = $('attendance_table_filter input').val();

            $('#attendance_table').DataTable().search(toSearch);
            $('#attendance_table').DataTable().draw();
        }

        function initReportDataTable(identifier, url, columns) {
            var oTable = $(identifier).DataTable({
                "searchDelay": 2000,
                "scrollY": "1020px",
                "serverSide": true,
                "ajax": {
                    "type": "POST",
                    "url": url,
                    "contentType": 'application/json; charset=utf-8',
                    'data': function (data) {

                        // ---------------------------------------------

                        var fDate = $('[name="month"]').val();
                        var tDate = $('[name="month"]').val();

                        var lastDay = GetLastDayOfMonth(fDate.split("-")[1], fDate.split("-")[0]);

                        fDate = fDate.replace("-", "-01-");
                        tDate = tDate.replace("-", "-" + lastDay + "-");

                        //console.log('1>> ' + fDate + ' - ' + tDate);

                        fDate = fDate.split("-").reverse()
                        tDate = tDate.split("-").reverse();

                        //console.log('2>> ' + fDate[0] + "-" + fDate[1] + "-" + fDate[2]);
                        //console.log('3>> ' + tDate[0] + "-" + tDate[1] + "-" + tDate[2]);

                        fDate = fDate[1] + "-" + fDate[0] + "-" + fDate[2];
                        tDate = tDate[1] + "-" + tDate[0] + "-" + tDate[2];
                        //console.log('4>> ' + fDate + ' - ' + tDate);

                        // ---------------------------------------------


                        var dtVals = $('#monthly-time-sheet-month').val();
                        if (dtVals.length != 7) {
                            data.employee_id = 0; //$('#monthly-time-sheet-employees').val();
                            data.from_date = fDate;
                            data.to_date = tDate;
                            return data = JSON.stringify(data);
                        } else {
                            data.employee_id = "TYPE_EMP"; //$('#monthly-time-sheet-employees').val();
                            data.from_date = fDate;
                            data.to_date = tDate;
                            return data = JSON.stringify(data);


                        }




                    }
                },
                "scrollX": true,
                "scrollCollapse": true,
                "processing": true,
                "paging": true,
                "deferRender": true,
                "columns": columns,
                "order": [0, "desc"],
                "iDisplayLength": 31,
                "aLengthMenu": [[10, 20, 31], [10, 20, 31]]

            });

            oTable.on("draw", function () {
                var keyword = $(identifier + '_filter > label:eq(0) > input').val();
                $(identifier).unmark();
                $(identifier).mark(keyword, {});

                $(identifier + ' tbody tr').click(function (e) {
                    $('tr.row_selected').removeClass('row_selected');
                    $(this).addClass('row_selected');
                });
            });


            // set the z-index of the 'processing...' overlay
            // to a great number, so that it may always display
            // on top of the table. Also set the text color
            // to black as it is white by default.
            $(identifier + '_processing').css({
                "z-index": "1000",
                "color": "rgb(0, 0, 0)"
            });


            // initiate search one second after the user
            // stops typing.
            function setSearchDelayOnDataTable(idSelector) {
                // remove all events from the search box
                $(idSelector + '_filter input').off();


                function customDataTableSearch() {

                    // get the entered string
                    var toSearch = $(idSelector + '_filter input').val();

                    // do nothing if the string is null.
                    // I've not tested this, it is just
                    // in case.
                    if (toSearch == null) {
                        return;
                    }

                    // initiate search programatically.
                    $(idSelector).DataTable().search(toSearch).draw();
                }

                // this variable holds the timer
                var timeout;

                // register a keypress on the search box
                $(idSelector + '_filter input').keypress(function () {
                    if (timeout != null) {
                        clearTimeout(timeout);
                        timeout = null;
                    }

                    // timeout set to 1 second.
                    timeout = setTimeout(customDataTableSearch, 1000);
                });

            }

            setSearchDelayOnDataTable(identifier);
        }
        // ------------------------------------------------------------


        function setTypeOfReportDropDown() {
            $('#type-of-report').chosen();
            $('#type-of-report').on("change", function () {
                switch ($('#type-of-report').val()) {
                    case "monthly-time-sheet":

                        $('#monthly-time-sheet').show();
                        $('#summary-report').hide();
                        $('#monthly-attendance-register').hide();

                        break;
                    case "summary-report":

                        $('#monthly-time-sheet').hide();
                        $('#summary-report').show();
                        $('#monthly-attendance-register').hide();

                        break;
                    case "monthly-attendance-register":

                        $('#monthly-time-sheet').hide();
                        $('#summary-report').hide();
                        $('#monthly-attendance-register').show();

                        break;
                }
            });
        }


        $("#monthly-time-sheet-form").submit(function (e) {
            //document.getElementById("generate-monthly-time-sheet").disabled = true;

            $('#pdf-no-data-found').val("");
            $('#pdf-no-data-found').text("");

            return true;
        });

        function clearr() {
            $('input[type="search"]').focus();
            $('input[type="search"]').val("");

            // if ($('#monthly-time-sheet-employees').val() != null) {
            $('#attendance_table').DataTable().search("");
            $('#attendance_table').DataTable().draw();
            // }

            $('input[type="search"]').blur();
            myFunction();
        }

        function HideMessage() { setTimeout(function () { $('#pdf-no-data-found').hide(); }, 5000); }

        function myFunction() {
            setTimeout(function () { $('#export_wait').hide(); document.getElementById("generate-monthly-time-sheet").disabled = false; }, 1500);
        }

        function ExortExcleBar() {
            $('#export_wait2').show();

            document.getElementById("btnExport").disabled = true;

            HideBarExcle();

            var ss = $("tr").children("td:first").text();

            if (ss == "" || ss == "No data available in table" || ss == " ") {
                document.getElementById("demo").innerHTML = "No Data Found.";
            }
            else {
                DownloadExcleCsv();
            }
        }

        function DownloadExcleCsv() { setupTableExportButton('#attendance_table', 'MonthlyTimesheetReport'); }

        function HideBarExcle() {
            setTimeout(function () { $('#export_wait2').hide(); document.getElementById("btnExport").disabled = false; document.getElementById("demo").innerHTML = ""; }, 1500);
        }


        $(document).ready(function () {

            var empCode= @Html.Raw(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId);

            $.ajax({
                url: '/EMP/EMP/DataHandler',
                type: "POST",
                data: { empId: empCode },
                dataType: "json",

                success: function (data) {


                    if (data.ExportGridData == false) {
                        $("#btnExport").hide();
                    }
                    if (data.ExportPDF == false) {
                        $("#generate-monthly-time-sheet").hide();
                    }
                   
                   

                },
                error: function () {
                    alert("error");
                }
            });

            //$('#accordion').accordion("option", "active", 2);
            //$("input[type=submit], button").button();
            $(".chzn-select").chosen();
            $(".datepicker").datepicker();
            //setActiveLink("Monthly Time Sheet");
            HideMessage();
            setTypeOfReportDropDown();


            $('.hasDatepicker').keydown(function (e) {
                var unicode = e.keyCode ? e.keyCode : e.charCode;
                if (unicode != 13 && unicode != 8 && unicode != 9) { e.preventDefault(); }
            });

            $('.hasDatepicker').keydown(function (e) {
                var unicode = e.keyCode ? e.keyCode : e.charCode;
                if (unicode == 8) { e.preventDefault(); e.stopPropagation(); }
            });

            //added by IR
            //DataTables.NET
            //search-consolidated-report
            //generate-monthly-time-sheet

            //var fewSeconds = 5;
            //$('#search-consolidated-report').click(function () {
            //    // Ajax request
            //    var btn = $(this);
            //    btn.prop('disabled', true); //btn.hide();
            //    setTimeout(function () {
            //        btn.prop('disabled', false); //btn.show();
            //    }, fewSeconds * 1000);

            //});



            //$('#search-consolidated-report').button();
            $("#search-consolidated-report").click(function (e) {

                //$('input[type="search"]').focus();
                //$('input[type="search"]').val("");

                //alert('values >> ' + $('#monthly-time-sheet-employees').val() + ' >> ' + $('#monthly-time-sheet-month').val());



                //<select id="monthly-time-sheet-employees"

                //        <input id="monthly-time-sheet-month" type="text" name="month" class="form-control monthPicker" required />



                //if ($('#monthly-time-sheet-employees').val() == "") {
                //    alert('Please select an Employee Id.');
                //    return false;
                //}


                if ($('#monthly-time-sheet-month').val() == "") {
                    $('#alert_message').text("Please select a Month");
                    $('.bs-example-modal-sm').modal('show');
                    $('#monthly-time-sheet-month').focus();
                    return false;
                }

                $('#pdf-no-data-found').val("");
                $('#pdf-no-data-found').text("");

                submitcheck();
                //  serializeAndSend();
                e.preventDefault();

                //$('input[type="search"]').blur();
            });

            var url = '@Url.Action("MonthlyTimesheetReportForEMPDataHandlernews", "Report", null, Request.Url.Scheme)';

            var columns = [
                //  { "data": "date" },
                //   { "data": "employee_code" },
                //   { "data": "employee_first_name" },
                //   { "data": "employee_last_name" },
                //   { "data": "time_in" },
                //   { "data": "status_in" },
                //   { "data": "time_out" },
                //   { "data": "status_out" },
                //{ "data": "final_remarks" },
                //{ "data": "description" },
                //   { "data": "terminal_in" },
                //   { "data": "terminal_out" }
                   { "data": "date" },
                   { "data": "day" },
                   { "data": "time_in" },
                   { "data": "time_out" },
                   { "data": "status" },
                   { "data": "final_remarks" }
            ];

            initReportDataTable('#attendance_table', url, columns);


            //$('#btnExport').focus();
            //$('#monthly-time-sheet-month').focus();

        });





</script>
}


