@{
    ViewBag.Title = "TRMS - View Future Attendance";
    Layout = "~/Areas/EMP/Views/Shared/_Layout.cshtml";

    string EMP_STD_LEC_LoginUserType = "";
    if (MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeFunctionSLSID.ToString().Contains("student"))
    {
        EMP_STD_LEC_LoginUserType = "STD";
    }
    else if (MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeFunctionSLSID.ToString().Contains("lecturer"))
    {
        EMP_STD_LEC_LoginUserType = "LEC";
    }
    else
    {
        EMP_STD_LEC_LoginUserType = "EMP";
    }
}

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.welcome")  <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span></h4>
                 <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/EMP/EMP/Dashboard">@EMP_STD_LEC_LoginUserType</a></li>
                    <li class="breadcrumb-item active">Attendance</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="mdi mdi-file-document"></i> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("preadj")</h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-12">
                            <table id="attendance_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%">
                                <thead>
                                    <tr>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("consloe.from")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("consloe.to")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("monthly.epcode")<th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("preremarks")</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" class="btn btn-primary waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.expo")</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- End content -->

@section JS {

    <script type="text/javascript" src="@Href("~/Scripts/chosen.ajaxaddition.jquery.js")"></script>
    <script>

        $(document).ready(function () {
            //$('#accordion').accordion("option", "active", 1);
            //setActiveLink("Future Manual Attendance");
            //          $(".chzn-select").chosen();
            $(".datepicker").datepicker({ dateFormat: 'yy-mm-dd' });
            //$("input[type=submit], button").button();

            //$('#btnExport').button();
            $("#btnExport").click(function (e) {
                setupTableExportButton('#attendance_table', 'FutureManualAttendance');
                e.preventDefault();
            });

            /*
            $('#btnExport').button();
            $("#btnExport").click(function (e) {
                $('#attendance_table').tableExport({ type: 'excel', escape: 'false' });
                e.preventDefault();
            });

            */


            //initDataTable("#leavebalance_table");

            var url = '@Url.Action("FutureManualAttendanceDataHandler", "AttendanceManagement", null, Request.Url.Scheme)';

            var columns = [
                   { "data": "from_date" },
                   { "data": "to_date" },
                   { "data": "employee_code" },
                   { "data": "remarks" }

            ];

            @*
               I did this so that like initDataTables the JS
            for serverside processing can be used for other tables.
                NOTE: The names of the columns correspond to the View Model.
            For example in this example the column names, first_name, last_name
            etc are taken from ViewModels.Employee
        *@

            initServerSideTable('#attendance_table', url, columns);
        });

    </script>
}