@{
    ViewBag.Title = "TRMS - Organization Room - Schedule Management";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

@using MvcApplication1.ViewModel;
@model ViewModels.OrganizationCampusRoomCourseScheduleView

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'HR'</span>! [Login ID: <span class="text-warning" title="@GlobalVariables.CheckNULLValidation(GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@GlobalVariables.CheckNULLValidation(GlobalVariables.GV_EmployeeName)</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Student Portal</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="mdi mdi-file-document"></i> Schedule By Room Management </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    @using (Html.BeginForm("ManageOrganizationSchedule", "OrganizationsManagement", FormMethod.Post, new { id = "organization-schedule-form" }))
                    {
                        <div class="row">

                            <div class="col-4">


                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">Campus <span class="text-danger font-14">*</span></label>
                                        <select id="campus_id" name="campus_id" class="form-control" required>
                                            @if (Model.list_campus != null)
                                            {
                                                foreach (ViewModels.OrganizationCampusView item in Model.list_campus)
                                                {
                                                    <option value="@item.Id">@item.CampusCode</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>


                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Room <span class="text-danger font-14">*</span></label>
                                        <select id="room_id" name="room_id" class="form-control" required>
                                            @if (Model.list_room != null)
                                            {
                                                foreach (ViewModels.OrganizationCampusBuildingRoomView item in Model.list_room)
                                                {
                                                    <option value="@item.Id">@item.RoomCode</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>


                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Program (to Enrolled In) <span class="text-danger font-14">*</span></label>
                                        <select id="program_id" name="program_id" class="form-control" required>
                                            @if (Model.list_program != null)
                                            {
                                                foreach (ViewModels.OrganizationProgramView item in Model.list_program)
                                                {
                                                    <option value="@item.Id">@item.ProgramCode</option>
                                                }
                                            }
                                        
                                        </select>
                                    </div>
                                </div>


                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Shift (Morning/Evening) <span class="text-danger font-14">*</span></label>
                                        <select id="shift_id" name="shift_id" class="form-control" required>
                                            @if (Model.list_shift != null)
                                            {
                                                foreach (ViewModels.OrganizationProgramShiftView item in Model.list_shift)
                                                {
                                                    <option value="@item.Id">@item.ProgramShiftName</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>






                            </div>



                            <div class="col-4">


                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">Lecture Group (-/A/B) <span class="text-danger font-14">*</span></label>
                                        <select id="lecture_group_id" name="lecture_group_id" class="form-control" required>
                                            @if (Model.list_lecture_group != null)
                                            {
                                                foreach (ViewModels.LGRegionView item in Model.list_lecture_group)
                                                {
                                                    <option value="@item.Id">@item.Name</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>



                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Course (Code/OFF/Break) <span class="text-danger font-14">*</span></label>
                                        <select id="course_id" name="course_id" class="form-control" required>
                                            @if (Model.list_course != null)
                                            {
                                                foreach (ViewModels.OrganizationProgramCourseView item in Model.list_course)
                                                {
                                                    <option value="@item.Id">@item.CourseCode - @item.CourseTitle</option>
                                                }

                                                <!--<option value="0">OFF</option>
                                                <option value="-1">BREAK</option>-->
                                            }
                                        </select>
                                    </div>
                                </div>


                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Study Title <span class="text-danger font-14">&nbsp;*</span></label>
                                        <input id="study_title" name="study_title" type="text" class="form-control" required />
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">Lecturer <span class="text-danger font-14">*</span></label>
                                        <select id="employee_teacher_id" name="employee_teacher_id" class="form-control" required>
                                            @if (Model.list_teacher != null)
                                            {
                                                foreach (ViewModels.EmployeeView item in Model.list_teacher)
                                                {
                                                    <option value="@item.Id">@item.EmployeeCode</option>
                                                }

                                                <option value="1">000000</option>
                                            }
                                        </select>
                                    </div>
                                </div>




                            </div>


                            <div class="col-4">

                                <div class="row">

                                    <div class="col-04">
                                        <label class="control-label">Lecture Start Date & Time<span class="text-danger font-14">&nbsp;*</span></label>
                                        <input id="start_date" name="start_date" type="text" class="form-control datepicker" autocomplete="off" required />

                                    </div>

                                    <div class="col-04">
                                        <select id="start_hr" name="start_hr" class="form-control">
                                            <option value="08">08</option>
                                            <option value="09">09</option>
                                            <option value="10">10</option>
                                            <option value="11">11</option>
                                            <option value="12">12</option>
                                            <option value="01">01</option>
                                            <option value="02">02</option>
                                            <option value="03">03</option>
                                            <option value="04">04</option>
                                            <option value="05">05</option>
                                        </select>
                                        <select id="start_mn" name="start_mn" class="form-control">
                                            <option value="00">00</option>
                                            <option value="10">10</option>
                                            <option value="15">15</option>
                                            <option value="20">20</option>
                                            <option value="25">25</option>
                                            <option value="30">30</option>
                                            <option value="35">35</option>
                                            <option value="40">40</option>
                                            <option value="45">45</option>
                                            <option value="50">50</option>
                                        </select>
                                        <select id="start_ap" name="start_ap" class="form-control">
                                            <option value="am">AM</option>
                                            <option value="pm">PM</option>
                                        </select>
                                    </div>
                                </div>


                                <div class="row m-t-10">
                                    <div class="col-04">
                                        <label class="control-label">Lecture End Date & Time<span class="text-danger font-14">&nbsp;*</span></label>
                                        <input id="end_date" name="end_date" type="text" class="form-control datepicker" autocomplete="off" required />
                                    </div>
                                    <div class="col-04">
                                        <select id="end_hr" name="end_hr" class="form-control">
                                            <option value="08">08</option>
                                            <option value="09">09</option>
                                            <option value="10">10</option>
                                            <option value="11">11</option>
                                            <option value="12">12</option>
                                            <option value="01">01</option>
                                            <option value="02">02</option>
                                            <option value="03">03</option>
                                            <option value="04">04</option>
                                            <option value="05">05</option>
                                        </select>
                                        <select id="end_mn" name="end_mn" class="form-control">
                                            <option value="00">00</option>
                                            <option value="10">10</option>
                                            <option value="15">15</option>
                                            <option value="20">20</option>
                                            <option value="25">25</option>
                                            <option value="30">30</option>
                                            <option value="35">35</option>
                                            <option value="40">40</option>
                                            <option value="45">45</option>
                                            <option value="55">50</option>
                                        </select>
                                        <select id="end_ap" name="end_ap" class="form-control">
                                            <option value="am">AM</option>
                                            <option value="pm">PM</option>
                                        </select>
                                    </div>
                                </div>


                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12">
                                <label><span class="text-danger font-14">&nbsp;*</span> <span class="small">indicates required fields</span></label>
                            </div>
                        </div>

                        <div class="row m-t-10">
                            <div class="col-12 text-danger span_message">
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary()
                                @ViewBag.Message
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12">
                                <button type="submit" id="organization_schedule" class="btn btn-primary waves-effect waves-light m-t-10">Submit</button>
                                <button type="button" class="btn btn-primary waves-effect waves-light m-t-10" onclick="redirectToPage();">Reset</button>
                                @*<button type="submit" id="btn-excel-download" onclick="HideBarr();" class="btn btn-primary waves-effect waves-light m-t-10">Download Excel</button>
                                    <span id="export_wait" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></span>*@
                            </div>
                        </div>
                    }


                    <hr />




                </div>
            </div>
        </div>
    </div>



    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="panel-body">

                    <h3>List of Lecture-Schedule in Rooms </h3>

                    <div class="row m-t-30">
                        <div class="col-12">
                            <table id="organization_schedule_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Room Code</th>
                                        <th>Program Code</th>
                                        <th>Shift</th>
                                        <th>Group</th>
                                        <th>Course Code</th>
                                        <th>Action</th>
                                        <th>Lecture Start</th>
                                        <th>Lecture End</th>
                                        <th>Campus Code</th>
                                        <th>Study Title</th>
                                        <th>Create Date</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" onclick="CheckData();" class="btn btn-primary waves-effect waves-light">Export Grid Data</button>
                            <span id="demo" class="text-danger"></span>
                            <p id="export_wait2" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="panel-body">

                    <div class="row m-t-10">
                        <div class="col-12">
                            <h3>Upload Schedule using 'CSV File'</h3>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-3">
                            <a href="~/Uploads/SampleSchedule.csv">Download Sample Schedule File</a>
                        </div>

                        <div class="col-6">
                            &nbsp;
                        </div>

                        <div class="col-3 text-right d-none">
                            @using (Html.BeginForm("DownloadScheduleCSVFile", "OrganizationsManagement", FormMethod.Post, new { id = "download-form" }))
                            {
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary()

                                <button id="btnDownload" type="submit" value="Submit" class="btn btn-sm btn-default waves-effect waves-light">Download existing schedule (CSV) of 3 days</button>

                            }
                        </div>

                    </div>

                    @using (Html.BeginForm("UploadScheduleCSVFile", "OrganizationsManagement", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary()

                        <div class="row">
                            <div class="col-6">
                                <label class="btn btn-primary" for="my-file-selector">
                                    <input id="my-file-selector" onchange="alertFilename()" type="file" name="file" value="alert" accept=".csv" style="display:none; ">
                                    Click to select file
                                </label>
                                <h3 class="label" id="file-name"></h3>
                            </div>

                            <div class="col-6">
                                <button id="btnUpload" type="submit" value="Submit" class="btn btn-danger waves-effect waves-light">Upload File</button>
                                @if (ViewBag.UpMessage != null && ViewBag.UpMessage.ToString().Contains("Success"))
                                {
                                    <label class="label msg" style="font-size:medium;  color:green;">@ViewBag.UpMessage</label>
                                }
                                else
                                {
                                    <label class="label msg" style="font-size:medium;  color:red;">@ViewBag.UpMessage</label>
                                }
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12">
                                Critical Required Fields:
                                <ul>
                                    <li>Schedule of Past Dates are NOT Allowed to Upload</li>
                                    <li>Need to update TIME then first FIND and DELETE that record from List</li>
                                    <li>Proper Building Code of that Campus</li>
                                    <li>Proper Student Code of that Campus</li>
                                    <li>Proper Lecturer Code of that Campus</li>
                                    <li>Proper Course (Code/Break/OFF) Marked</li>
                                </ul>
                            </div>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>



</div>
<!-- End content -->
