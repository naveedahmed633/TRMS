@{
    ViewBag.Title = "TRMS - Employee Peformance Report";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

<style>
    .monthPicker {
        z-index: 1000;
    }
</style>

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.welcome")  <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span></h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">HR</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.epr") </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-7">
                            @using (Html.BeginForm("PerformanceReport", "Reports", FormMethod.Post, new { id = "monthly-time-sheet-form" }))
                            {
                                

                                <div class="row m-t-10">
                                    <div class="col-6">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.empcode") <span class="text-danger font-14">*</span></label>
                                        <select id="monthly-time-sheet-employees" class="form-control" name="employee_id" required></select>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-12 text-danger">
                                        @Html.AntiForgeryToken()
                                        @Html.ValidationSummary()
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12">
                                        <a id="search-consolidated-report" onclick="clearr();" class="btn btn-primary waves-effect waves-light m-t-10" style="color: white;">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.search")</a>
                                        <button type="button" class="btn btn-primary waves-effect waves-light m-t-10" onclick="redirectToPage();">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.reset")</button>
                                       
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="col-1">
                            <div class="row" style="margin-left: -232px;">
                                <div>
                                    <p class="text-danger"><b>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.tmarksallotted")</b> : 65</p>
                                    <p class="text-danger"><b>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.tmarksobtain")</b> :</p><p class="text-danger" id="_total" style=" margin-top: -39px; margin-left: 155px; ">-</p>
                                    <p class="text-danger"><b>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.presult")</b> :</p><p class="text-danger" id="_result" style=" margin-top: -38px; margin-left: 157px; ">-</p>
                                </div>
                            </div>
                            </div>
                        <div class="form-group col-4" style="font-style: italic;">
                            <h4>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.legend")</h4>
                            <table style="line-height: 16px; width: 70%;">
                                <tr><td style="width: 20%"></td><td style="width: 10%"></td><td style="width: 70%"></td></tr>
                                <tr><td>PD</td><td>:</td><td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.personality")</td></tr>
                                <tr><td>CS</td><td>:</td><td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.communication")</td></tr>
                                <tr><td>AP</td><td>:</td><td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.attendance")</td></tr>
                                <tr><td>I</td><td>:</td><td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.imitative")</td></tr>
                                <tr><td>OTA</td><td>:</td><td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.orgtime")</td></tr>
                                <tr><td>SC</td><td>:</td><td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.selfcontrol")</td></tr>
                                <tr><td>P</td><td>:</td><td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.proficiency")</td></tr>
                                <tr><td>PM</td><td>:</td><td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.pmanagement")</td></tr>
                                <tr><td>AD</td><td>:</td><td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.attentiontd")</td></tr>
                                <tr><td>CI</td><td>:</td><td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.cinteraction")</td></tr>
                                <tr><td>C</td><td>:</td><td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.creativity")</td></tr>
                                <tr><td>BS</td><td>:</td><td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.business")</td></tr>
                                <tr><td>A</td><td>:</td><td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.achievements")</td></tr>
                            </table>
                        </div>


                    </div>

              

                        </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <div class="card-box">

                <div class="panel-body">
                    <div class="row">
                        <div class="col-12">
                            <table id="attendance_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("emp.review")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.empcode")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.name")</th>
                                        <th>PD</th>
                                        <th>CS</th>
                                        <th>AP</th>
                                        <th>I</th>
                                        <th>OTA</th>
                                        <th>SC</th>
                                        <th>P</th>
                                        <th>PM</th>
                                        <th>AD</th>
                                        <th>CI</th>
                                        <th>C</th>
                                        <th>BS</th>
                                        <th>A</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>



                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" onclick="ExortExcleBar();" class="btn btn-primary waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exportgrid")</button>
                            <button type="submit" id="generate-monthly-time-sheet" form="monthly-time-sheet-form" class="btn btn-primary waves-effect waves-light" style="display: @ViewData["PDFDownloadEnabled"];" onclick="return validateFormInfo();">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exportpdf")</button>
                            <span id="export_wait" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></span><span id="pdf-no-data-found" class="text-danger">@ViewData["PDFNoDataFound"]</span>
                            <span id="demo" class="text-danger"></span>
                            <p id="export_wait2" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- End content -->
<!-- Custom Modal -->
<div class="modal fade bs-example-modal-sm" tabindex="-1" role="dialog" aria-labelledby="mySmallModalLabel" aria-hidden="true" style="display: none;">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                <h4 class="modal-title" id="mySmallModalLabel">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.msgalert")</h4>
            </div>
            <div class="modal-body">
                <span id="alert_message"></span>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->

@section JS {

    <script type="text/javascript" src="@Href("~/Scripts/chosen.ajaxaddition.jquery.js")"></script>
    @*<script type="text/javascript" src="@Href("~/Scripts/GenerateReports.js")"></script>*@
    <script type="text/javascript" src="@Href("~/Scripts/monthpicker.js")"></script>


    <script>

        function redirectToPage() {
            window.location.reload();
        }

        // -------------------- added by IR ---------------------

        //$("#btnShow").click(function () {
        //    if ($("#from").val().length == 0 || $("#to").val().length == 0) {
        //        alert('All fields are required');
        //    }
        //    else {
        //        alert('Selected Month Range :' + $("#from").val() + ' to ' + $("#to").val());
        //    }
        //});


        function validateFormInfo() {

            if ($('#monthly-time-sheet-employees').val() == null || $('#monthly-time-sheet-employees').val() == "") {

                $('#alert_message').text("Please select an Employee Code");
                $('.bs-example-modal-sm').modal('show');
                return false;
            }

            $('#pdf-no-data-found').val("");
            $('#pdf-no-data-found').text("");

            $('#export_wait').show();
            myFunction();

        }

        $("#monthly-time-sheet-form").submit(function (e) {
            document.getElementById("generate-monthly-time-sheet").disabled = true;
            return true;
        });

        function clearr() {
            $('input[type="search"]').focus();
            $('input[type="search"]').val("");

            if ($('#monthly-time-sheet-employees').val() != null) {
                $('#attendance_table').DataTable().search("");
                $('#attendance_table').DataTable().draw();
            }

            $('input[type="search"]').blur();

        }

        function HideMessage() { setTimeout(function () { $('#pdf-no-data-found').hide(); }, 5000); }


        function myFunction() {
            setTimeout(function () { $('#export_wait').hide(); document.getElementById("generate-monthly-time-sheet").disabled = false; }, 1500);
        }

        function ExortExcleBar() {
            $('#export_wait2').show();
            document.getElementById("btnExport").disabled = true;
            HideBarExcle();
            var ss = $("tr").children("td:first").text();
            if (ss == "No data available in table" || ss == "" || ss == " ") { document.getElementById("demo").innerHTML = "No Data Found."; }
            else { DownloadExcleCsv(); }
        }

        function DownloadExcleCsv() { setupTableExportButton('#attendance_table', 'MonthlyTimesheetReport'); }

        function HideBarExcle() {
            setTimeout(function () { $('#export_wait2').hide(); document.getElementById("btnExport").disabled = false; document.getElementById("demo").innerHTML = ""; }, 1500);
        }

        function submitcheck() {

            searchReport();
            fetchCounter();
            return true;

        }


        function fetchCounter() {

           

            var post_data2 = {
                "employee_id": $('#monthly-time-sheet-employees').val(),
              
            };

            $.ajax({
                cache: false,
                type: "POST",
                url: "/HR/Reports/CalculatePerfomance",
                //"contentType": 'application/json; charset=utf-8',
                dataType: 'json',
                data: post_data2,
                success: function (r) {
                    //console.log(r);
                    //console.log(r.total);
                    $('#_total').text(r[0].total);
                    $('#_result').text(r[0].result);

                  
                }
            });
        }

        function GetLastDayOfMonth(m, y) {

            var lastDay = 28;

            if (m == "04" || m == "06" || m == "09" || m == "11") {
                lastDay = 30;
            }
            else if (m == "02") {
                if ((y % 4) == 0) {
                    lastDay = 29;
                }
                else {
                    lastDay = 28;
                }
            }
            else {
                lastDay = 31;
            }

            return lastDay;
        }

        function searchReport() {
            // get the entered string
          
            var toSearch = $('attendance_table_filter input').val();
            $('#attendance_table').DataTable().search(toSearch);
            $('#attendance_table').DataTable().draw();
        }

        function initReportDataTable(identifier, url, columns) {
            var oTable = $(identifier).DataTable({
                "searchDelay": 2000,
                "scrollY": "1020px",
                "serverSide": true,
                "ajax": {
                    "type": "POST",
                    "url": url,
                    "contentType": 'application/json; charset=utf-8',
                    'data': function (data) {

                        data.employee_id = $('#monthly-time-sheet-employees').val();
                        return data = JSON.stringify(data);
                    }
                },
                "scrollX": true,
                "scrollCollapse": true,
                "processing": true,
                "paging": false,
                "deferRender": true,
                "columns": columns,
                "order": [0, "desc"],
                "iDisplayLength": 31,
                "aLengthMenu": [[10, 20, 31], [10, 20, 31]],
                "responsive": true,
                "info":     false

            });


            oTable.on("draw", function () {
                var keyword = $(identifier + '_filter > label:eq(0) > input').val();
                $(identifier).unmark();
                $(identifier).mark(keyword, {});

                $(identifier + ' tbody tr').click(function (e) {
                    $('tr.row_selected').removeClass('row_selected');
                    $(this).addClass('row_selected');
                });
            });


            // set the z-index of the 'processing...' overlay
            // to a great number, so that it may always display
            // on top of the table. Also set the text color
            // to black as it is white by default.
            $(identifier + '_processing').css({
                "z-index": "1000",
                "color": "rgb(0, 0, 0)"
            });


            // initiate search one second after the user
            // stops typing.
            function setSearchDelayOnDataTable(idSelector) {
                // remove all events from the search box
                $(idSelector + '_filter input').off();


                function customDataTableSearch() {

                    // get the entered string
                    var toSearch = $(idSelector + '_filter input').val();

                    // do nothing if the string is null.
                    // I've not tested this, it is just
                    // in case.
                    if (toSearch == null) {
                        return;
                    }

                    // initiate search programatically.
                    $(idSelector).DataTable().search(toSearch).draw();
                }

                // this variable holds the timer
                var timeout;

                // register a keypress on the search box
                $(idSelector + '_filter input').keypress(function () {
                    if (timeout != null) {
                        clearTimeout(timeout);
                        timeout = null;
                    }

                    // timeout set to 1 second.
                    timeout = setTimeout(customDataTableSearch, 1000);
                });

            }

            setSearchDelayOnDataTable(identifier);
        }

        function setTypeOfReportDropDown() {
            $('#type-of-report').chosen();
            $('#type-of-report').on("change", function () {
                switch ($('#type-of-report').val()) {
                    case "monthly-time-sheet":

                        $('#monthly-time-sheet').show();
                        $('#summary-report').hide();
                        $('#monthly-attendance-register').hide();

                        break;
                    case "summary-report":

                        $('#monthly-time-sheet').hide();
                        $('#summary-report').show();
                        $('#monthly-attendance-register').hide();

                        break;
                    case "monthly-attendance-register":

                        $('#monthly-time-sheet').hide();
                        $('#summary-report').hide();
                        $('#monthly-attendance-register').show();

                        break;
                }
            });
        }


        function setEmployeeDropDowns() {
            $('#monthly-time-sheet-employees').ajaxChosen({
                dataType: 'json',
                type: 'POST',
                url: '@Url.Action("ChangeEmployeePasswordDataHandler", "EmployeeManagement", null, Request.Url.Scheme)'
            }, {
                loadingImg: '@Href("~/Content/ChosenAutoComplete/loading.gif")'
            });
        }

        $(document).ready(function () {

            var empCode2= @Html.Raw(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId);

            $.ajax({
                url: '/HR/HR/VerfiyDataHandler',
                type: "POST",
                data: { empId: empCode2 },
                dataType: "json",

                success: function (data) {
                    if (data.HRExportGridData == false) {
                        $("#btnExport").hide();
                    }
                    if (data.HRExportPDF == false) {
                        $("#generate-monthly-time-sheet").hide();
                    }
                 
                },
                error: function () {
                    alert("error");
                }
            });
          

            //$('#accordion').accordion("option", "active", 5);
            //$("input[type=submit], button").button();
            $(".chzn-select").chosen();
            $(".datepicker").datepicker();
            //setActiveLink("Monthly Time Sheet");
            HideMessage();
            setEmployeeDropDowns();

            $('.hasDatepicker').keydown(function (e) {
                var unicode = e.keyCode ? e.keyCode : e.charCode;
                if (unicode != 13 && unicode != 8 && unicode != 9) { e.preventDefault(); }
            });

            $('.hasDatepicker').keydown(function (e) {
                var unicode = e.keyCode ? e.keyCode : e.charCode;
                if (unicode == 8) { e.preventDefault(); e.stopPropagation(); }
            });

            setTypeOfReportDropDown();



           
            $("#search-consolidated-report").click(function (e) {

                submitcheck();
                e.preventDefault();

            });

            var url = '@Url.Action("EmpPerformanceReportDataHandler", "Reports", null, Request.Url.Scheme)';

            var columns = [
                  { "data": "reviewPeriod" },
                   { "data": "empCode" },
                   { "data": "EmpName" },
                   { "data": "personality" },
                   { "data": "communicationSkills" },
                   { "data": "attendancePromptness" },
                   { "data": "imitative" },
                   { "data": "organizationAwareness" },
                   { "data": "selfControl" },
                   { "data": "proficiency" },
                   { "data": "projectManagement" },
                   { "data": "attentionDetail" },
                   { "data": "clientInteraction" },
                   { "data": "creativity" },
                   { "data": "businessSkill" },
                   { "data": "achievement" }
            ];

            initReportDataTable('#attendance_table', url, columns);

        });

    </script>
}