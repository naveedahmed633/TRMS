@{
    ViewBag.Title = "TRMS - Leaves List Report";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'HR'</span>! [Login ID: <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Leaves</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="mdi mdi-file-document"></i> Leaves List Report</h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>



                    <div class="d-none row">
                        <div class="col-4">

                            <form id="consolidate-form">
                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">Employee Code <span class="text-danger font-14">*</span></label>
                                        <select id="consolidated-employees" class="form-control" name="employee_id" required></select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Date From <span class="text-danger font-14">*</span></label>
                                        <input id="date_from" type="text" class="form-control datepicker" name="from_date" autocomplete="off" required>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Date To</label>
                                        <input id="date_to" type="text" class="form-control datepicker" name="to_date" autocomplete="off" required>
                                        <input id="users_type" type="hidden" value="0" />
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12">
                                        <button type="submit" id="search-consolidated-report" onclick="clearr();" class="btn btn-primary waves-effect waves-light m-t-10">Search</button>&nbsp;
                                        <input type="button" value="Reset" class="btn btn-default m-t-10" onclick="redirectToPage();" />
                                        @*<button type="submit" id="btn-excel-download" onclick="ExcleHide();" class="btn btn-primary waves-effect waves-light m-t-10">Download Excel</button>*@
                                        <span id="export_wait" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></span>
                                    </div>
                                </div>
                            </form>

                        </div>

                        <div class="form-group col-4">
                        </div>
                        <div class="form-group col-4">
                            <div class="row m-t-20">
                                <div class="col-12">
                                    <h4>User's whole Session Info</h4>
                                </div>
                            </div>
                            <div class="row m-t-20">
                                <div class="col-12 text-success">
                                    <label class="control-label"><b><u>Session Start Date:</u></b> <span id="strSessionStartDate">-</span></label>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-12 text-success">
                                    <label class="control-label"><b><u>Session End Date:</u></b> <span id="strSessionEndDate">-</span></label>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-12 text-danger">
                                    <label class="control-label"><b><u>Sick Leaves Availed:</u></b> <span id="AvailedSickLeaves">0</span> out of total <span id="AvailableSickLeaves">0</span></label>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-12 text-danger">
                                    <label class="control-label"><b><u>Casual Leaves Availed:</u></b> <span id="AvailedCasualLeaves">0</span> out of total <span id="AvailableCasualLeaves">0</span></label>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-12 text-danger">
                                    <label class="control-label"><b><u>Annual Leaves Availed:</u></b> <span id="AvailedAnnualLeaves">0</span> out of total <span id="AvailableAnnualLeaves">0</span></label>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-12 text-danger">
                                    <label class="control-label"><b><u>Other Leaves Availed:</u></b> <span id="AvailedOtherLeaves">0</span> out of total <span id="AvailableOtherLeaves">0</span></label>
                                </div>
                            </div>

                        </div>
                    </div>



                </div>


                <div class="row">
                    <div class="col-12">
                        <table id="attendance_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 160%;">
                            <thead>
                                <tr>
                                    <th>Emp-Code</th>
                                    <th>First Name</th>
                                    <th>Last Name</th>
                                    <th>Action</th>
                                    <th>Sick</th>
                                    <th>Casual</th>
                                    <th>Annual</th>
                                    <th>Other</th>
                                    <th>Tour</th>
                                    <th>Visit</th>
                                    <th>Meeting</th>
                                    <th>Maternity</th>
                                    <th>Total Sick</th>
                                    <th>Total Casual</th>
                                    <th>Total Annual</th>
                                    <th>Total Other</th>
                                    <th>Total Tour</th>
                                    <th>Total Visit</th>
                                    <th>Total Meeting</th>
                                    <th>Total Maternity</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>

                <div class="row m-t-10">
                    <div class="col-12">
                        <button type="submit" id="btnExport" onclick="ExortExcleBar();" class="btn btn-primary waves-effect waves-light">Export Grid Data</button>
                        <span id="demo" class="text-danger"></span>
                        <p id="export_wait2" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></p>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
</div>
<!-- End content -->
<!-- Custom Modal -->
<div class="modal fade bs-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="mySmallModalLabel" aria-hidden="true" style="display: none;">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                <h4 class="modal-title" id="mySmallModalLabel">Message Alert</h4>
            </div>
            <div class="modal-body">
                <span id="alert_message"></span>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->

<div id="MidTermModal" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="MidTermModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                <h4 class="modal-title" id="CenterModalLabel">Leaves Report</h4>
            </div>
            <div class="modal-body text-center">
                <img id="image_source" src="~/Images/no-image.png" width="300" />

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary waves-effect" data-dismiss="modal">Close</button>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div>

@section JS {
    @*<script src="~/Scripts/zingchart.min.js"></script>*@
    <script type="text/javascript" src="@Href("~/Scripts/chosen.ajaxaddition.jquery.js")"></script>
    @*<script type="text/javascript" src="@Href("~/Scripts/monthpicker.js")"></script>*@

    <script type="text/javascript">
        function ExcleHide() {
            HideMessage();
        }
        function ExortExcleBar() {
            $('#export_wait2').show();
            document.getElementById("btnExport").disabled = true;
            HideBarExcle();
            var ss = $("#attendance_table tr").children("td:first").text();
            if (ss == "No data available in table" || ss == "" || ss == " ") { document.getElementById("demo").innerHTML = "No Data Found."; }
            else { DownloadExcleCsv(); }
        }
        function DownloadExcleCsv() { setupTableExportButton('#attendance_table', 'ConsolidatedAttendance'); }

        function HideBarExcle() {
            setTimeout(function () { $('#export_wait2').hide(); document.getElementById("btnExport").disabled = false; document.getElementById("demo").innerHTML = ""; }, 1500);
        }

        function redirectToPage() {
            window.location = '/HR/Reports/LeavesReportByUser';
        }

        function ValidateDate(dtValue) {
            var dtRegex = new RegExp(/\b\d{1,2}[\/-]\d{1,2}[\/-]\d{4}\b/);
            return dtRegex.test(dtValue);
        }
        function searchReport() {
            // get the entered string
            var toSearch = $('attendance_table_filter input').val();

            $('#attendance_table').DataTable().search(toSearch);
            $('#attendance_table').DataTable().draw();
        }

        popup = function viewImage(image_name) {
            $('#image_source').attr("src", "/Content/LeaveApps/" + image_name);
            $('#MidTermModal').modal('show');
        }

        function initReportDataTable(identifier, url, columns) {
            var oTable = $(identifier).DataTable({
                "searchDelay": 2000,
                "scrollY": "300px",
                "serverSide": true,
                "ajax": {
                    "type": "POST",
                    "url": url,
                    "contentType": 'application/json; charset=utf-8',
                    'data': function (data) {
                        if ($('#consolidated-employees').val() != "" && $('#date_from').val() != "" && $('#date_to').val() != "") {
                            //var dtVal = $('#date_from').val();
                            //var dtVal2 = $('#date_to').val();
                            //if (ValidateDate(dtVal) && ValidateDate(dtVal2)) {
                            data.employee_id = $('#consolidated-employees').val();
                            data.from_date = $('#date_from').val();
                            data.to_date = $('#date_to').val();
                            //data.to_date = $('#date_to').val();
                            //}
                        }
                        return data = JSON.stringify(data);
                    }
                },
                "scrollX": true,
                "scrollCollapse": true,
                "processing": true,
                "paging": true,
                "deferRender": true,
                "columns": columns,
                "order": [0, "desc"],
                "iDisplayLength": 100,
                "aLengthMenu": [[10, 25, 50, 100, 500], [10, 25, 50, 100, 500]]

            });

            oTable.on("draw", function () {
                var keyword = $(identifier + '_filter > label:eq(0) > input').val();
                $(identifier).unmark();
                $(identifier).mark(keyword, {});



                $(identifier + ' tbody tr').click(function (e) {
                    $('tr.row_selected').removeClass('row_selected');
                    $(this).addClass('row_selected');
                });
            });


            // set the z-index of the 'processing...' overlay
            // to a great number, so that it may always display
            // on top of the table. Also set the text color
            // to black as it is white by default.
            $(identifier + '_processing').css({
                "z-index": "1000",
                "color": "rgb(0, 0, 0)"
            });


            // initiate search one second after the user
            // stops typing.
            function setSearchDelayOnDataTable(idSelector) {
                // remove all events from the search box
                $(idSelector + '_filter input').off();


                function customDataTableSearch() {

                    // get the entered string
                    var toSearch = $(idSelector + '_filter input').val();

                    // do nothing if the string is null.
                    // I've not tested this, it is just
                    // in case.
                    if (toSearch == null) {
                        return;
                    }

                    // initiate search programatically.
                    $(idSelector).DataTable().search(toSearch).draw();
                }

                // this variable holds the timer
                var timeout;

                // register a keypress on the search box
                $(idSelector + '_filter input').keypress(function () {
                    if (timeout != null) {
                        clearTimeout(timeout);
                        timeout = null;
                    }

                    // timeout set to 1 second.
                    timeout = setTimeout(customDataTableSearch, 1000);
                });

            }

            setSearchDelayOnDataTable(identifier);

        }

        function fetchCounter() {

            fDate = $('#consolidate-form').find('[name*="from_date"]').val().split("-").reverse();
            tDate = $('#consolidate-form').find('[name*="to_date"]').val().split("-").reverse();

            //console.log('1>> ' + fDate + ' - ' + tDate);

            fDate = new Date(fDate[0] + "-" + fDate[1] + "-" + fDate[2]);
            tDate = new Date(tDate[0] + "-" + tDate[1] + "-" + tDate[2]);

            //console.log('2>> ' + fDate + ' - ' + tDate);



            if (tDate < fDate) {

                $('#alert_message').text("The 'To Date' should be greater than 'From Date'.");
                $('.bs-example-modal-lg').modal('show');

                //alert("To Date should be greater than From Date.");
                return false;
            }

            var post_data2 = {
                "employee_id": $('#consolidated-employees').val(),
                "from_date": $('#date_from').val(),
                "to_date": $('#date_to').val(),
                "users_type": $('#consolidated_employees_chosen span').text().indexOf("*") > 0 ? 1 : 0
                //"users_type": $('#consolidated-employees').text().includes("*") == true ? 1 : 0
            };

            $.ajax({
                cache: false,
                type: "POST",
                url: "/HR/Reports/LeavesReportByUserCounter",
                //"contentType": 'application/json; charset=utf-8',
                dataType: 'json',
                data: post_data2,
                success: function (r) {
                    //alert(r);
                    //var info = JSON.stringify(r);

                    //alert('xyz => ' + r.AvailableSickLeaves);

                    $('#strSessionStartDate').text(r.strSessionStartDate);
                    $('#strSessionEndDate').text(r.strSessionEndDate);

                    $('#AvailedSickLeaves').text(r.AvailedSickLeaves);
                    $('#AvailedCasualLeaves').text(r.AvailedCasualLeaves);
                    $('#AvailedAnnualLeaves').text(r.AvailedAnnualLeaves);
                    $('#AvailedOtherLeaves').text(r.AvailedOtherLeaves);

                    $('#AvailableSickLeaves').text(r.AvailableSickLeaves);
                    $('#AvailableCasualLeaves').text(r.AvailableCasualLeaves);
                    $('#AvailableAnnualLeaves').text(r.AvailableAnnualLeaves);
                    $('#AvailableOtherLeaves').text(r.AvailableOtherLeaves);
                }
            });
        }


        function clearr() {

            $('#strSessionStartDate').text("-");
            $('#strSessionEndDate').text("-");

            $('#AvailedSickLeaves').text("0");
            $('#AvailedCasualLeaves').text("0");
            $('#AvailedAnnualLeaves').text("0");
            $('#AvailedOtherLeaves').text("0");

            $('#AvailableSickLeaves').text("0");
            $('#AvailableCasualLeaves').text("0");
            $('#AvailableAnnualLeaves').text("0");
            $('#AvailableOtherLeaves').text("0");

            $('input[type="search"]').focus();
            $('input[type="search"]').val("");
            $('#attendance_table').DataTable().search("");
            $('#attendance_table').DataTable().draw();
            $('input[type="search"]').blur();

            //document.getElementById("btn-excel-download").disabled = false;
            $('#export_wait').hide();
        }


        function HideMessage() { setTimeout(function () { $('#export_wait').hide(); document.getElementById("btn-excel-download").disabled = false; }, 5000); }



        function submitcheck() {

            //$('input[type="search"]').focus();
            //$('input[type="search"]').val(null);

            //return false;
            //console.log("search value = " + $('input[type="search"]').val());

            fDate = $('#consolidate-form').find('[name*="from_date"]').val().split("-").reverse();
            tDate = $('#consolidate-form').find('[name*="to_date"]').val().split("-").reverse();

            //console.log('1>> ' + fDate + ' - ' + tDate);

            fDate = new Date(fDate[0] + "-" + fDate[1] + "-" + fDate[2]);
            tDate = new Date(tDate[0] + "-" + tDate[1] + "-" + tDate[2]);

            //console.log('2>> ' + fDate + ' - ' + tDate);



            if (tDate < fDate) {

                $('#alert_message').text("The 'To Date' should be greater than 'From Date'.");
                $('.bs-example-modal-lg').modal('show');

                //alert("To Date should be greater than From Date.");
                return false;
            }

            searchReport();

            fetchCounter();

            //$('input[type="search"]').blur();

            return true;

        }

        $(document).ready(function () {

            var empCode2= @Html.Raw(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId);

            $.ajax({
                url: '/HR/HR/VerfiyDataHandler',
                type: "POST",
                data: { empId: empCode2 },
                dataType: "json",

                success: function (data) {
                    if (data.HRExportGridData == false) {
                        $("#btnExport").hide();
                    }



                },
                error: function () {
                    alert("error");
                }
            });

            //$('#accordion').accordion("option", "active", 5);

            $(".datepicker").datepicker({ dateFormat: 'dd-mm-yy' });

            $('.hasDatepicker').keydown(function (e) {
                var unicode = e.keyCode ? e.keyCode : e.charCode;
                if (unicode != 13 && unicode != 8 && unicode != 9) { e.preventDefault(); }
            });

            $('.hasDatepicker').keydown(function (e) {
                var unicode = e.keyCode ? e.keyCode : e.charCode;
                if (unicode == 8) { e.preventDefault(); e.stopPropagation(); }
            });
            //setActiveLink("Consolidated Report");
            var present = 0;
            var absent = 0;
            var late = 0;
            var onTime = 0;
            var earlyGone = 0;
            //    serializeAndSend();
            //function serializeAndSend() {
            //    var obj = {
            //        employee_id: $('#consolidated-employees').val(),
            //        from_date: $('#date_from').val(),
            //        to_date: $('#date_to').val()
            //    };
            //    $.ajax({
            //        url: "graphForConsolidated",
            //        type: 'POST',
            //        contentType: 'application/json',
            //        data: JSON.stringify(obj),
            //        success: function (data) {
            //            present = data.dashboardElement.present;
            //            absent = data.dashboardElement.absent;
            //            late = data.dashboardElement.late;
            //            onTime = data.dashboardElement.onTime;
            //            earlyGone = data.dashboardElement.earlyGone;
            //            console.log(present + " " + absent + " " + late + " " + earlyGone + " " + onTime);
            //            loadGraph(present, absent, late, earlyGone, onTime);
            //        }
            //    });

            //};
            var check = false;

            //$("#consolidated-employees").change(function () {
            //    var status = this.value;


            //});

            //
            //$('#search-consolidated-report').button();
            $("#search-consolidated-report").click(function (e) {

                if ($('#consolidated-employees').val() == "") {

                    $('#alert_message').text("Please select 'User Code'.");
                    $('.bs-example-modal-lg').modal('show');

                    //alert("Please select 'From Date'");
                    //$('#consolidated-employees').focus();
                    return false;
                }

                if ($('#date_from').val() == "") {

                    $('#alert_message').text("Please select 'From Date'.");
                    $('.bs-example-modal-lg').modal('show');

                    //alert("Please select 'From Date'");
                    $('#date_from').focus();
                    return false;
                }

                if ($('#date_to').val() == "") {

                    $('#alert_message').text("Please select 'To Date'.");
                    $('.bs-example-modal-lg').modal('show');

                    //alert("Please select 'To Date'");
                    $('#date_to').focus();
                    return false;
                }

                submitcheck();
                //  serializeAndSend();
                e.preventDefault();
            });


            //download excel
            $("#btn-excel-download").click(function (e) {

                if ($('#date_from').val() == "") {
                    alert("Please select 'From Date'");
                    $('#date_from').focus();
                    return false;
                }

                if ($('#date_to').val() == "") {
