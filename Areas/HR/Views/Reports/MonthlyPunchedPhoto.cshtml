                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.empcode")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.fname")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.lname")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.timeinout")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.photo")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.terminal")</th>
                                    </tr>
                                </thead>
