<div id="MidTermModal" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="MidTermModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                <h4 class="modal-title" id="CenterModalLabel">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.view")</h4>
            </div>
            <div class="modal-body text-center">
                <span>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.original")</span>
                <img id="image_original" title="Original" src="~/Images/no-image.png" alt="Missing" width="160" />
            </div>
            <div class="modal-body text-center">
                <span>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.punched")</span>
                <img id="image_punched" title="Punched" src="~/Images/no-image.png" alt="Missing" width="160" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary waves-effect" data-dismiss="modal">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.close")</button>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div>

