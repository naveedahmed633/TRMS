        function GetLastDayOfMonth(m, y) {

            var lastDay = 28;

            if (m == "04" || m == "06" || m == "09" || m == "11") {
                lastDay = 30;
            }
            else if (m == "02") {
                if ((y % 4) == 0) {
                    lastDay = 29;
                }
                else {
                    lastDay = 28;
                }
            }
            else {
                lastDay = 31;
            }

            return lastDay;
        }

        function searchReport() {
