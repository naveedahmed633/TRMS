@{
    ViewBag.Title = "TRMS - Loan Report By Month";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

<style>
    .monthPicker {
        z-index: 1000;
    }
</style>

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'HR'</span>! [Login ID: <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Reports</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="mdi mdi-desktop-classic"></i> Loan Report By Month </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-12">
                            @using (Html.BeginForm("LoanReportByMonthDataHandler", "Reports", FormMethod.Post, new { id = "loan-report-form" }))
                            {
                                <div class="row">
                                    <div class="col-4">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.selectmonth")</label>
                                        <input id="month_year" type="text" name="month_year" class="form-control monthPicker" autocomplete="off" required />
                                    </div>
                                </div>


                                <div class="row">
                                    <div class="col-12 text-danger">
                                        @Html.AntiForgeryToken()
                                        @Html.ValidationSummary()
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12">
                                        <button type="submit" id="search-loan-report" onclick="clearr();" class="btn btn-primary waves-effect waves-light m-t-10">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("btnSearch")</button>
                                        <input type="button" value="@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("btnReset")" class="btn btn-default m-t-10" onclick="redirectToPage();" />
                                    </div>
                                </div>
                            }

                            <div class="row">
                                <div class="col-12">
                                    @using (Html.BeginForm("GenerateLoanReport", "Reports", FormMethod.Post, new { id = "loan-report-form" }))
                                    {
                                        <input id="lmonth_year" type="hidden" name="lmonth_year" />
                                        <button type="submit" id="generate-loan-report" class="btn btn-primary waves-effect waves-light m-t-10" onclick="return generateLoanStatement();">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("btnDownloadStatement")</button>
                                        <span id="export_wait" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></span><span id="pdf-no-data-found" class="text-danger">@ViewData["PDFNoDataFound"]</span>
                                    }
                                </div>
                            </div>
                        </div>




                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-12">
                            <table id="loan_report_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("lblID")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("monthly.epcode")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("lblLoanMonth")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("lblBalanceAmount")</th>
                                        <th>Deductable Amount <div class="small text-danger">(applicable in case greater than 0)</div></th>
                                        <th>Installment Amount <div class="small text-danger">(fixed for per month)</div></th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("lblLoanAmount")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("lblInstallmentCount")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.Name")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("lblLoanType")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("lblLoanStatus")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("lblRemarks")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("lblAttachment")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("lblCreateDate")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("lblUpdateDate")</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" onclick="ExortExcleBar();" class="btn btn-primary waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("btnExportGridData")</button>
                            <span id="demo" class="text-danger"></span>
                            <p id="export_wait2" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- End content -->
<!-- Custom Modal -->
<div class="modal fade bs-example-modal-sm" tabindex="-1" role="dialog" aria-labelledby="mySmallModalLabel" aria-hidden="true" style="display: none;">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                <h4 class="modal-title" id="mySmallModalLabel">Message Alert</h4>
            </div>
            <div class="modal-body">
                <span id="alert_message"></span>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->

