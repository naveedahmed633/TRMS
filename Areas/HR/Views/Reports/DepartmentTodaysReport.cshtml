@inherits System.Web.Mvc.WebViewPage<dynamic>
@using System.Web.Mvc
@using System.Web.Mvc.Html
@{
    ViewBag.Title = "TRMS - Organization Today's Report";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

<style>
    .monthPicker {
        z-index: 1000;
    }
</style>
@{
    //Present - Leave - Absent
    string pr_chart_color_a = "#66bb6a ", pr_chart_color_b = "#7266ba", pr_chart_color_c = "#ee6e73";
    //Ontime - Late - Earlyout
    string pn_chart_color_d = "#29b6f6", pn_chart_color_e = "#ffc107", pn_chart_color_f = "#f76397";
}

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.welcome")  <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span></h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Reports</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="mdi mdi-chart-bar"></i> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.otap") </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-3 d-none">
                            @using (Html.BeginForm("DepartmentTodaysReport", "Reports", FormMethod.Post, new { id = "department-performance-form" }))
                            {
                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.selectperiod") <span class="text-danger font-14">*</span></label>
                                        <select id="_reviewPeriod" class="form-control" name="reviewPeriod" required>
                                            <option value="none">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.none")</option>
                                            <option value="Today">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.today")</option>
                                        </select>
                                    </div>
                                </div>


                                <input type="hidden" id="imgeData" name="imageData" value="" />
                                <div class="row">
                                    <div class="col-12 text-danger">
                                        @{
                                            if (ViewBag.DeptPerfMessage != null && ViewBag.DeptPerfMessage.ToString() == "NO")
                                            {
                                                <text>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.nodata")</text>
                                            }
                                        }
                                        @Html.AntiForgeryToken()
                                        @Html.ValidationSummary()
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12">
                                        <a id="search-consolidated-report" onclick="clearr();" class="btn btn-primary waves-effect waves-light m-t-10" style="color: white; display:none">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.search")</a>
                                    </div>
                                </div>
                                            }
                        </div>

                        <div class="col-12 text-center" id="boundary">

                            <div class="row">
                                <div class="col-12">
                                    <!-- Donut Chart - 1 -->
                                    <div id="chartPresence">
                                        <h2>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.todaystatus")</h2>
                                        <svg id="svgChartPresence" style="height:300px;width:100%"></svg>
                                    </div>

                                </div>

                                @*<div class="col-6">
                                         Donut Chart - 2
                                        <div id="chartPunctuality">
                                            <h4 class="m-t-0 header-title text-center">Punctuality Status</h4>
                                            <svg id="svgChartPunctuality" style="height:300px;width:100%"></svg>
                                        </div>
                                    </div>*@
                            </div>

                        </div>
                        <p id="NoDataMsg" style="margin-top: -245px; margin-left: 437px; color: red;font-weight: 500;">No Data Process Yet</p>

                        @*<p id="NoDataMsg2" style="margin-top: -245px;margin-left: 828px;color: red;font-weight: 500;">No Data Process Yet</p>*@
                        @*<p id="parents"></p>*@


                    </div>

                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="panel-body">
                    <div class="row">
                        <div class="col-12">
                            <table id="attendance_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.depname")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.presentpercent")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.absentpercent")</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" onclick="ExortExcleBar();" class="btn btn-primary waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exportgrid")</button>
                            <button type="submit" id="generate-monthly-time-sheet" form="department-performance-form" class="btn btn-primary waves-effect waves-light" style="display: @ViewData["PDFDownloadEnabled"];" onclick="return validateFormInfo();">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exportpdf")</button>
                            <span id="export_wait" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></span><span id="pdf-no-data-found" class="text-danger">@ViewData["PDFNoDataFound"]</span>
                            <span id="demo" class="text-danger"></span>
                            <p id="export_wait2" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- End content -->
<!-- Custom Modal -->
<div class="modal fade bs-example-modal-sm" tabindex="-1" role="dialog" aria-labelledby="mySmallModalLabel" aria-hidden="true" style="display: none;">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                <h4 class="modal-title" id="mySmallModalLabel">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.msgalert")</h4>
            </div>
            <div class="modal-body">
                <span id="alert_message"></span>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->

@section JS {





    <script type="text/javascript" src="@Href("~/Scripts/chosen.ajaxaddition.jquery.js")"></script>
    @*<script type="text/javascript" src="@Href("~/Scripts/GenerateReports.js")"></script>*@
    <script type="text/javascript" src="@Href("~/Scripts/monthpicker.js")"></script>
    <script src="~/Scripts/html2canvas.js"></script>
    <script>



