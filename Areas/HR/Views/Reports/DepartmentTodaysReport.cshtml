            });


            // initiate search one second after the user
            // stops typing.
            function setSearchDelayOnDataTable(idSelector) {
                // remove all events from the search box
                $(idSelector + '_filter input').off();


                function customDataTableSearch() {

                    // get the entered string
                    var toSearch = $(idSelector + '_filter input').val();

                    // do nothing if the string is null.
                    // I've not tested this, it is just
                    // in case.
                    if (toSearch == null) {
                        return;
                    }

                    // initiate search programatically.
                    $(idSelector).DataTable().search(toSearch).draw();
                }

                // this variable holds the timer
                var timeout;

                // register a keypress on the search box
                $(idSelector + '_filter input').keypress(function () {
                    if (timeout != null) {
                        clearTimeout(timeout);
                        timeout = null;
                    }

                    // timeout set to 1 second.
                    timeout = setTimeout(customDataTableSearch, 1000);
                });

            }

            setSearchDelayOnDataTable(identifier);
        }

        function setTypeOfReportDropDown() {
            $('#type-of-report').chosen();
            $('#type-of-report').on("change", function () {
                switch ($('#type-of-report').val()) {
                    case "monthly-time-sheet":

                        $('#monthly-time-sheet').show();
                        $('#summary-report').hide();
                        $('#monthly-attendance-register').hide();

                        break;
                    case "summary-report":

                        $('#monthly-time-sheet').hide();
                        $('#summary-report').show();
                        $('#monthly-attendance-register').hide();

                        break;
                    case "monthly-attendance-register":

                        $('#monthly-time-sheet').hide();
                        $('#summary-report').hide();
                        $('#monthly-attendance-register').show();

                        break;
                }
            });
        }


        function setEmployeeDropDowns() {
            $('#monthly-time-sheet-employees').ajaxChosen({
                dataType: 'json',
                type: 'POST',
                url: '@Url.Action("ChangeEmployeePasswordDataHandler", "EmployeeManagement", null, Request.Url.Scheme)'
            }, {
                loadingImg: '@Href("~/Content/ChosenAutoComplete/loading.gif")'
            });
        }

        $(document).ready(function () {

            var empCode= @Html.Raw(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId);

            $.ajax({
                url: '/HR/HR/VerfiyDataHandler',
                type: "POST",
                data: { empId: empCode },
                dataType: "json",

                success: function (data) {
                    if (data.HRExportGridData == false) {
                        $("#btnExport").hide();
                    }
                    if (data.HRExportPDF == false) {
                        $("#generate-monthly-time-sheet").hide();
                    }

                },
                error: function () {
                    alert("error");
                }
            });


            loadChart(0, 0);
            $('#NoDataMsg').hide();
            $('#NoDataMsg2').hide();



            //$('#accordion').accordion("option", "active", 5);
            //$("input[type=submit], button").button();
            $(".chzn-select").chosen();
            $(".datepicker").datepicker();
            //setActiveLink("Monthly Time Sheet");
            $("#_reviewPeriod").chosen();
            HideMessage();
            setEmployeeDropDowns();

            $('.hasDatepicker').keydown(function (e) {
                var unicode = e.keyCode ? e.keyCode : e.charCode;
                if (unicode != 13 && unicode != 8 && unicode != 9) { e.preventDefault(); }
            });

            $('.hasDatepicker').keydown(function (e) {
                var unicode = e.keyCode ? e.keyCode : e.charCode;
                if (unicode == 8) { e.preventDefault(); e.stopPropagation(); }
            });

            setTypeOfReportDropDown();


            //  $("#search-consolidated-report").click(function (e) {
            $("#_reviewPeriod").change(function () {
                console.log($("#_reviewPeriod").val());
                clearr();

                $('#pdf-no-data-found').val("");
                $('#pdf-no-data-found').text("");

                submitcheck();
                //  serializeAndSend();
                //e.preventDefault();

                //$('input[type="search"]').blur();

            });

            var url = '@Url.Action("DeptTodaysReportDataHandler", "Reports", null, Request.Url.Scheme)';

            var columns = [
                   { "data": "DepartmentName" },
                   { "data": "PresentPercent" },
                   { "data": "AbsentPercent" }
                   //{ "data": "AbsentPercent" },
                   //{ "data": "OnTimePercent" },
                   //{ "data": "LatePercent" },
                   //{ "data": "EarlyPercent" }
            ];

            initReportDataTable('#attendance_table', url, columns);

            $('#btnExport').focus();

        });

        function ChartToImage() {
            var data = document.querySelector('#boundary');
            //console.log(data);
            html2canvas(data).then(function (canvas) {

                //console.log(canvas);

                var img = canvas.toDataURL("image/png");
                $("#imgeData").val(img);
                //var pHtml = "<img src=" + img + " />";
                //$("#parents").append(pHtml);

            });

        }

    </script>
}