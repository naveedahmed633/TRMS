@{
    ViewBag.Title = "TRMS - Monthly Working Hours Timesheet";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}
@using System.Globalization

<style>
    .monthPicker {
        z-index: 1000;
    }
    #attendance_table thead th {
        white-space: nowrap;
    }
</style>

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'HR'</span>! [Login ID: <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Reports</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.monworkhrstimesheet") </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-12">
                            @using (Html.BeginForm("WorkHoursTimeSheetNew", "Reports", FormMethod.Post, new { id = "monthly-time-sheet-form" }))
                            {
                            <div class="row">
                                <div class="col-4">
                                    <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.fromdate") <span class="text-danger font-14">*</span></label>
                                    <input id="from-date" name="fromDate" type="date" class="form-control" />
                                    @*<input id="monthly-time-sheet-month" type="text" name="month" class="form-control monthPicker" autocomplete="off" required />*@
                                </div>
                                <div class="col-4">
                                    <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.todate") <span class="text-danger font-14">*</span></label>
                                    <input id="to-date" name="toDate" type="date" class="form-control" />
                                    @*<input id="monthly-time-sheet-month" type="text" name="month" class="form-control monthPicker" autocomplete="off" required />*@
                                </div>
                            </div>

                                <div class="row m-t-10">
                                    <div class="col-4">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.empcode") <span class="text-danger font-14">*</span></label>
                                        <select id="monthly-time-sheet-employees" class="form-control" name="employee_id" required>
                                            <!--<option value="28317">002369</option>-->
                                        </select>
                                    </div>
                                </div>



                                <div class="row">
                                    <div class="col-12 text-danger">
                                        @Html.AntiForgeryToken()
                                        @Html.ValidationSummary()
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12">
                                        <button type="submit" id="search-consolidated-report" onclick="clearr();" class="btn btn-primary waves-effect waves-light m-t-10">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.search")</button>
                                        <button type="button" class="btn btn-primary waves-effect waves-light m-t-10" onclick="redirectToPage();">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.reset")</button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="panel-body">
                    <div class="row">
                        <div class="col-12">
                            <table id="attendance_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>



                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.date")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.day")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.empcode")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.name")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.timein")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.terminalin")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.statusin")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.timeout")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.terminalout")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.statusout")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.remarks")</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="button" id="btnExport" onclick="exportAsExcel();" class="btn btn-primary waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exportgrid")</button>
                            <button type="submit" id="generate-monthly-time-sheet" form="monthly-time-sheet-form" class="btn btn-primary waves-effect waves-light" style="display: @ViewData["PDFDownloadEnabled"];" onclick="return validateFormInfo();">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("exportPDF")</button>
                            <span id="export_wait" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></span><span id="pdf-no-data-found" class="text-danger">@ViewData["PDFNoDataFound"]</span>
                            <span id="demo" class="text-danger"></span>
                            <p id="export_wait2" style="display: none;" class="text-danger"><img src='/images/loader.gif' alt='processing' /></p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- End content -->
<!-- Custom Modal -->
<div class="modal fade bs-example-modal-sm" tabindex="-1" role="dialog" aria-labelledby="mySmallModalLabel" aria-hidden="true" style="display: none;">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                <h4 class="modal-title" id="mySmallModalLabel">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.msgalert")</h4>
            </div>
            <div class="modal-body">
                <span id="alert_message"></span>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->





@section JS {

    <script type="text/javascript" src="@Href("~/Scripts/chosen.ajaxaddition.jquery.js")"></script>
    @*<script type="text/javascript" src="@Href("~/Scripts/GenerateReports.js")"></script>*@
    <script type="text/javascript" src="@Href("~/Scripts/monthpicker.js")"></script>


    <script>

        function redirectToPage() {
            window.location.reload();
        }


        function validateFormInfo() {

            if ($('#monthly-time-sheet-employees').val() == null || $('#monthly-time-sheet-employees').val() == "") {

                $('#alert_message').text("Please select an Employee Id");
                $('.bs-example-modal-sm').modal('show');

                //alert('Please select an Employee Id');
                //$('#monthly-time-sheet-employees').focus();

                return false;
            }
           if ($('#to-date').val() == "" || $('#to-date').val() == null || $('#from-date').val() == "" || $('#from-date').val() == null) {

                $('#alert_message').text("Please select a date range");
                $('.bs-example-modal-sm').modal('show');

                //alert('Please select a Month.');
                return false;
            }

            $('#pdf-no-data-found').val("");
            $('#pdf-no-data-found').text("");

            $('#export_wait').show();
            myFunction();

        }

        $("#monthly-time-sheet-form").submit(function (e) {
            document.getElementById("generate-monthly-time-sheet").disabled = true;
            return true;
        });

        function clearr() {
            $('input[type="search"]').focus();
            $('input[type="search"]').val("");

            if ($('#monthly-time-sheet-employees').val() != null) {
                $('#attendance_table').DataTable().search("");
                $('#attendance_table').DataTable().draw();
            }

            $('input[type="search"]').blur();

        }

        function HideMessage() { setTimeout(function () { $('#pdf-no-data-found').hide(); }, 5000); }


        function myFunction() {
            setTimeout(function () { $('#export_wait').hide(); document.getElementById("generate-monthly-time-sheet").disabled = false; }, 1500);
        }

        function ExortExcleBar() {
            $('#export_wait2').show();
            document.getElementById("btnExport").disabled = true;
            HideBarExcle();
            var ss = $("tr").children("td:first").text();
            if (ss == "No data available in table" || ss == "" || ss == " ") { document.getElementById("demo").innerHTML = "No Data Found."; }
            else { DownloadExcleCsv(); }
        }

        function DownloadExcleCsv() {
            setupTableExportButton('#attendance_table', 'MonthlyTimesheetReport');
        }

        function HideBarExcle() {
            setTimeout(function () { $('#export_wait2').hide(); document.getElementById("btnExport").disabled = false; document.getElementById("demo").innerHTML = ""; }, 1500);
        }

        function submitcheck() {

            var fDate = $('[name="month"]').val();
            var tDate = $('[name="month"]').val();

            var lastDay = GetLastDayOfMonth(fDate.split("-")[1], fDate.split("-")[0]);

            fDate = fDate.replace("-", "-01-");
            tDate = tDate.replace("-", "-" + lastDay + "-");

            //console.log('1>> ' + fDate + ' - ' + tDate);

            fDate = fDate.split("-").reverse()
            tDate = tDate.split("-").reverse();

            //console.log('2>> ' + fDate + ' - ' + tDate);

            fDate = new Date(fDate[0] + "-" + fDate[1] + "-" + fDate[2]);
            tDate = new Date(tDate[0] + "-" + tDate[1] + "-" + tDate[2]);

            //console.log('3>> ' + fDate + ' - ' + tDate);

            //return false;

            if (tDate < fDate) {

                $('#alert_message').text("The 'To Date' should be greater than 'From Date'.");
                $('.bs-example-modal-sm').modal('show');

                //alert("The 'To Date' should be greater than 'From Date'.");
                return false;
            }

            searchReport();
            return true;

        }

        function GetLastDayOfMonth(m, y) {

            var lastDay = 28;

            if (m == "04" || m == "06" || m == "09" || m == "11") {
                lastDay = 30;
            }
            else if (m == "02") {
                if ((y % 4) == 0) {
                    lastDay = 29;
                }
                else {
                    lastDay = 28;
                }
            }
            else {
                lastDay = 31;
            }

            return lastDay;
        }

        function searchReport() {
            // get the entered string
            var toSearch = $('attendance_table_filter input').val();

            $('#attendance_table').DataTable().search(toSearch);
            $('#attendance_table').DataTable().draw();
        }

        function initReportDataTable(identifier, url, columns) {
            var oTable = $(identifier).DataTable({
                "searchDelay": 2000,
                "scrollY": "1020px",
                "serverSide": true,
                "ajax": {
                    "type": "POST",
                    "url": url,
                    "contentType": 'application/json; charset=utf-8',
                    'data': function (data) {

                        // ---------------------------------------------

                        var fDate = $('[name="fromDate"]').val().split("-").reverse().join("-")
                        var tDate = $('[name="toDate"]').val().split("-").reverse().join("-")

                        //var lastDay = GetLastDayOfMonth(fDate.split("-")[1], fDate.split("-")[0]);

                       //fDate = fDate.replace("-", "-01-");
                       //tDate = tDate.replace("-", "-" + lastDay + "-");

                        //console.log('1>> ' + fDate + ' - ' + tDate);

                        //fDate = fDate.split("-").reverse()
                        //tDate = tDate.split("-").reverse();

                        //console.log('2>> ' + fDate[0] + "-" + fDate[1] + "-" + fDate[2]);
                        //console.log('3>> ' + tDate[0] + "-" + tDate[1] + "-" + tDate[2]);

                        //fDate = fDate[1] + "-" + fDate[0] + "-" + fDate[2];
                        //tDate = tDate[1] + "-" + tDate[0] + "-" + tDate[2];
                        //console.log('4>> ' + fDate + ' - ' + tDate);

                        // ---------------------------------------------

                        //var dtVal = $('#monthly-time-sheet-month').val();

                        //if ($('#monthly-time-sheet-employees').val() != "") {
                        //    if (dtVal.length == 7) {
                        //        data.employee_id = $('#monthly-time-sheet-employees').val();
                        //        data.from_date = fDate;
                        //        data.to_date = tDate;
                        //    }
                        //}
                            
                        data.employee_id = $('#monthly-time-sheet-employees').val();
                        data.from_date = fDate;
                        data.to_date = tDate;
                        console.log(data);

                        return data = JSON.stringify(data);

                    }
                },
                "scrollX": true,
                "scrollCollapse": true,
                "processing": true,
                "paging": true,
                "deferRender": true,
                "columns": columns,
                "order": [0, "asc"],
                //"ordering": false,
                "iDisplayLength": 31,
                "aLengthMenu": [[10, 20, 31], [10, 20, 31]],
                "responsive": true,
                dom: 'frtip',
                buttons: [
                    'excel',
                ],
                customize: function (win) {
                    win.buttons().container().appendTo('#hidden-export-container'); // Hide the button
                }

            });

            oTable.on("draw", function () {
                var keyword = $(identifier + '_filter > label:eq(0) > input').val();
                $(identifier).unmark();
                $(identifier).mark(keyword, {});

                $(identifier + ' tbody tr').click(function (e) {
                    $('tr.row_selected').removeClass('row_selected');
                    $(this).addClass('row_selected');
                });
            });


            // set the z-index of the 'processing...' overlay
            // to a great number, so that it may always display
            // on top of the table. Also set the text color
            // to black as it is white by default.
            $(identifier + '_processing').css({
                "z-index": "1000",
                "color": "rgb(0, 0, 0)"
            });


            // initiate search one second after the user
            // stops typing.
            function setSearchDelayOnDataTable(idSelector) {
                // remove all events from the search box
                $(idSelector + '_filter input').off();


                function customDataTableSearch() {

                    // get the entered string
                    var toSearch = $(idSelector + '_filter input').val();

                    // do nothing if the string is null.
                    // I've not tested this, it is just
                    // in case.
                    if (toSearch == null) {
                        return;
                    }

                    // initiate search programatically.
                    $(idSelector).DataTable().search(toSearch).draw();
                }

                // this variable holds the timer
                var timeout;

                // register a keypress on the search box
                $(idSelector + '_filter input').keypress(function () {
                    if (timeout != null) {
                        clearTimeout(timeout);
                        timeout = null;
                    }

                    // timeout set to 1 second.
                    timeout = setTimeout(customDataTableSearch, 1000);
                });

            }

            setSearchDelayOnDataTable(identifier);
        }

        function setTypeOfReportDropDown() {
            $('#type-of-report').chosen();
            $('#type-of-report').on("change", function () {
                switch ($('#type-of-report').val()) {
                    case "monthly-time-sheet":

                        $('#monthly-time-sheet').show();
                        $('#summary-report').hide();
                        $('#monthly-attendance-register').hide();

                        break;
                    case "summary-report":

                        $('#monthly-time-sheet').hide();
                        $('#summary-report').show();
                        $('#monthly-attendance-register').hide();

                        break;
                    case "monthly-attendance-register":

                        $('#monthly-time-sheet').hide();
                        $('#summary-report').hide();
                        $('#monthly-attendance-register').show();

                        break;
                }
            });
        }


        function setEmployeeDropDowns() {
            $('#monthly-time-sheet-employees').ajaxChosen({
                dataType: 'json',
                type: 'POST',
                url: '@Url.Action("ChangeEmployeePasswordDataHandler", "EmployeeManagement", null, Request.Url.Scheme)'
            }, {
                loadingImg: '@Href("~/Content/ChosenAutoComplete/loading.gif")'
            });
        }

        $(document).ready(function () {
            var empCode= @Html.Raw(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId);

            $.ajax({
                url: '/HR/HR/VerfiyDataHandler',
                type: "POST",
                data: { empId: empCode },
                dataType: "json",

                success: function (data) {

                    if (data.HRExportGridData == false) {
                        $("#btnExport").hide();
                    }
                    if (data.HRExportPDF == false) {
                        $("#generate-monthly-time-sheet").hide();
                    }

                },
                error: function () {
                    alert("error");
                }
            });


            //$('#accordion').accordion("option", "active", 5);
            //$("input[type=submit], button").button();
            $(".chzn-select").chosen();
            $(".datepicker").datepicker();
            //setActiveLink("Monthly Time Sheet");
            HideMessage();
            setEmployeeDropDowns();

            $('.hasDatepicker').keydown(function (e) {
                var unicode = e.keyCode ? e.keyCode : e.charCode;
                if (unicode != 13 && unicode != 8 && unicode != 9) { e.preventDefault(); }
            });

            $('.hasDatepicker').keydown(function (e) {
                var unicode = e.keyCode ? e.keyCode : e.charCode;
                if (unicode == 8) { e.preventDefault(); e.stopPropagation(); }
            });

            setTypeOfReportDropDown();

            $("#search-consolidated-report").click(function (e) {
                  e.preventDefault();
                if ($('#to-date').val() == "" || $('#to-date').val() == null || $('#from-date').val() == "" || $('#from-date').val() == null) {

                   $('#alert_message').text("Please select a date range");
                    $('.bs-example-modal-sm').modal('show');

                    //alert('Please select a Month.');
                    return false;
                }

                if ($('#monthly-time-sheet-employees').val() == "" || $('#monthly-time-sheet-employees').val() == null) {

                    $('#alert_message').text("Please select an Employee Id");
                    $('.bs-example-modal-sm').modal('show');

                    //alert('Please select an Employee Id.');
                    return false;
                }

                $('#pdf-no-data-found').val("");
                $('#pdf-no-data-found').text("");

                //submitcheck();
                //  serializeAndSend();
                //e.preventDefault();

                //$('input[type="search"]').blur();

            });


            var url = '@Url.Action("MonthlyWokringHourTimeSheetDataHandlerNew", "Reports", null, Request.Url.Scheme)';

            var columns = [
                { "data": "date" },
                { "data": "day" },
                { "data": "employee_code" },
                { "data": "employee_first_name" },
                { "data": "time_in" },
                { "data": "terminal_in" },
                { "data": "status_in" },
                { "data": "time_out" },
                { "data": "terminal_out" },
                { "data": "status_out" },
                { "data": "status" }
            ];

            initReportDataTable('#attendance_table', url, columns);

            $('#btnExport').focus();
            $('#monthly-time-sheet-month').focus();

        });

        function exportAsExcel() {
            $('#attendance_table').DataTable().buttons().container().find('a.buttons-excel').click();
        }

    </script>
}