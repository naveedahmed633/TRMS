@{
    ViewBag.Title = "TRMS - Employee Types Management";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

@model List<ViewModels.TypeOfEmployment>

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.welcome")  <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span></h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Employee Portal</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.emptoeman") </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-4">

                            @using (Html.BeginForm("AddTypeOfEmployment", "EmployeeManagement"))
                            {
                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.typename")</label>
                                        <input type="text" pattern=".{2,}" title="2 characters minimum" class="form-control" id="fname" name="name"
                                               oninput="setCustomValidity('');" oninvalid="setCustomValidity('@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.nameerr")');" required />
                                    </div>
                                </div>


                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.description")</label>
                                        <textarea class="form-control" name="description"></textarea>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12 text-danger">
                                        @Html.AntiForgeryToken()
                                        @Html.ValidationSummary()
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12">
                                        <button type="submit" class="btn btn-primary waves-effect waves-light m-t-10">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.addtype")</button>
                                        <button type="reset" value="Reset" class="btn btn-primary waves-effect waves-light m-t-10">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.reset")</button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="panel-body">
                    <div class="row">
                        <div class="col-12 m-b-10">
                            <h3>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.currenttoelist")</h3>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <table id="typeofemployment_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.id")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.typename")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.description")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.actions")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (ViewModels.TypeOfEmployment typeofemployment in Model)
                                    {
                                        <tr data-row="@typeofemployment.id">
                                            <td>@typeofemployment.id</td>
                                            <td>@typeofemployment.name</td>
                                            <td>@typeofemployment.description</td>
                                            <td class="dt-center">
                                                <div>
                                                    <a href="javascript:void(editTypeOfEmployment(@typeofemployment.id,'@typeofemployment.name','@typeofemployment.description'));">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.edit")</a>
                                                    <span>/</span>
                                                    <a href="javascript:void(deleteTypeOfEmployment(@typeofemployment.id));">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.del")</a>
                                                </div>

                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" class="btn btn-primary waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exportgrid")</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>
<!-- End content -->



@section JS {
    <script>
        $(document).ready(function () {
            //$('#accordion').accordion("option", "active", 1);
            //$("input[type=submit], button").button();
            //setActiveLink("Type of Employment");

            initDataTable("#typeofemployment_table", 10);

            //$('#btnExport').button();
            $("#btnExport").click(function (e) {
                setupTableExportButton('#typeofemployment_table', 'TypeOfEmployees');
                e.preventDefault();
            });

            /*
            $('#btnExport').button();
            $("#btnExport").click(function (e) {
                $('#typeofemployment_table').tableExport({ type: 'excel', escape: 'false' });
                e.preventDefault();
            });
            */

            editTypeOfEmployment = initEditModal("#modals", '@Url.Action("UpdateTypeOfEmployment", "EmployeeManagement", null, Request.Url.Scheme)', "TypeOfEmployment");
            deleteTypeOfEmployment = initDeleteModal("#modals", '@Url.Action("RemoveTypeOfEmployment", "EmployeeManagement", null, Request.Url.Scheme)', "TypeOfEmployment");
        });
    </script>
}
