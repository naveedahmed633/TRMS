        function setChosenSelectList(selector, URL) {
            if (!URL) {
                return;
            }

            var $elements = $(selector);
            $elements.ajaxChosen({
                dataType: 'json',
                type: 'POST',
                url: URL
            }, {
                loadingImg: '@Href("~/Content/ChosenAutoComplete/loading.gif")',
                minLength: 0,
                throttleMs: 400
            });

            // ajaxChosen defaults to minLength 1, so nothing loaded until the user typed.
            // With minLength 0 + empty query, the server returns the first page of matches (capped server-side).
            $elements.on('chosen:showing_dropdown', function () {
                var $container = $(this).next('.chosen-container');
                var $searchInput = $container.find('.chosen-search > input, .chosen-choices .search-field input');
                if ($searchInput.length && $.trim($searchInput.val()) === '') {
                    $searchInput.val('');
                    $searchInput.trigger($.Event('keyup'));
                }
            });
        }

