                        <label class="control-label">Date of Birth</label>
                        <input type='text'
                               name='date_of_birth'
                               id='modal_date_of_birth'
                               class="form-control datepicker">
                    </div>
                </div>

                <div class="row m-t-10">
                    <div class="col-12">
                        <label class="control-label">Function</label>
                        <select class="employee-function-select" name="function_id" id="modal_function" style="min-width: 350px">
                            <option value="0">none</option>
                        </select>
                        @*<select name="function_id" id="modal_function" style="width:100%">
                                <option selected="selected" disabled="disabled" value="0">Select Function</option>
                                @foreach (ViewModels.Function item in Model.functions)
                                {
                                    <option value="@item.id">@item.name</option>
                                }
                            </select>*@
                    </div>
                </div>

                <div class="row m-t-10">
                    <div class="col-12">
                        <label class="control-label">Designation</label>
                        <select class="employee-designation-select" name="designation_id" id="modal_designation" style="min-width: 350px">
                            <option value="0">none</option>
                        </select>
                        @*<select name="designation_id" id="modal_designation" style="width:100%">
                                <option selected="selected" disabled="disabled" value="0">Select Designation</option>
                                @foreach (ViewModels.Designation item in Model.designations)
                                {
                                    <option value="@item.id">@item.name</option>
                                }
                            </select>*@
                    </div>
                </div>

                <div class="row m-t-10">
