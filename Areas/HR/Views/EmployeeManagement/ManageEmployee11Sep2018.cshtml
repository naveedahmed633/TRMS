@{
    ViewBag.Title = "TRMS - Employee Management";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

@model ViewModels.CreateEmployee

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'HR'</span> User! Username: @User.Identity.Name</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Employee Management</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> Employee Management </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-12">
                            @if (Request.QueryString["message"] != null && Request.QueryString["message"].ToString() == "success")
            {
                                <div class="form-group row">
                                    <div class="text-danger h4 msg">
                                        The user has been added successfully!!!
                                    </div>
                                </div>
                            }

                        </div>
                    </div>

                    @using (Html.BeginForm("AddEmployee", "EmployeeManagement", FormMethod.Post, new { id = "employee-form", enctype = "multipart/form-data" }))
                    {
                        <!-- Row - 1 -->
                        <!-- Column - 1 -->
                        <div class="row">
                            <div class="col-4">

                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">First Name <span class="text-danger font-14">*</span></label>
                                        <input type="text" class="form-control" name="first_name" id="fname" required />
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Last Name <span class="text-danger font-14">*</span></label>
                                        <input type="text" class="form-control" name="last_name" id="lname" required />
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Employee Code <span class="text-danger font-14">*</span></label>
                                        <input type="text" pattern="+[0-9]" class="form-control" name="employee_code" id="empid" required>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Email Address</label>
                                        <input type="email" class="form-control" name="email" id="email">
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Address</label>
                                        <input type="text" class="form-control" name="address" id="email">
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Mobile No</label>
                                        <input type="text" class="form-control" name="mobile_no" id="email">
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Date of Joining <span class="text-danger font-14">*</span></label>
                                        <input type="text" class="form-control datepicker" name="date_of_joining" autocomplete="off" required />
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Date of Leaving</label>
                                        <input type="text" class="form-control datepicker" name="date_of_leaving" autocomplete="off" />
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Type of Employment (Perm/Prob) <span class="text-danger font-14">*</span></label>
                                        <select id="employee-toe-select" class="form-control " name="type_of_employment_id" required>
                                            <option value="0">none</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Access Group <span class="text-danger font-14">*</span></label>
                                        <select class="form-control" id="access_group_drop_down" name="access_group_id" required>
                                            <option selected="selected" disabled="disabled" value="0">Select Access Group</option>
                                            @foreach (ViewModels.AccessGroup item in Model.accessGroups)
                                            {
                                                <option value="@item.id">@item.name</option>
                                            }
                                        </select>
                                    </div>
                                </div>


                            </div>

                            <!-- Column - 2 -->
                            <div class="col-4">


                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">Function</label>
                                        <select id="employee-function-select" class="form-control " name="function_id">
                                            <option value="0">none</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Department</label>
                                        <select id="employee-department-select" class="form-control " name="department_id">
                                            <option value="0">none</option>-
                                        </select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Designation <span class="text-danger font-14">(used for Salary Calc) *</span></label>
                                        <select id="employee-designation-select" class="form-control " name="designation_id" required>
                                            <!--<option value="0">none</option>-->
                                        </select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Grade <span class="text-danger font-14">(used for Salary Calc) *</span></label>
                                        <select id="employee-grade-select" class="form-control " name="grade_id" required>
                                            <!--<option value="0">none</option>-->
                                        </select>
                                    </div>
                                </div>


                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Region</label>

                                        <select id="employee-region-select" class="form-control" name="region_id">
                                            <option value="0">none</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Location</label>

                                        <select id="employee-location-select" class="form-control" name="location_id">
                                            <option value="0">none</option>
                                        </select>
                                    </div>
                                </div>


                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Login Status <span class="text-danger font-14">*</span></label>
                                        <select class="form-control" id="time_tune_status_drop_down" name="time_tune_status" required>
                                            <option selected="selected" disabled="disabled" value="0">Select Status</option>

                                            <option value="0">Deactive</option>
                                            <option value="1">Active</option>

                                        </select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Photo</label>
                                        <input type="file" class="form-control" name="photograph" accept=".jpg" />
                                    </div>
                                </div>


                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Emergency Contact 01 <span class="text-danger font-14">*</span></label>
                                        <input type="text" class="form-control" name="emergency_contact_01" id="emergency_contact_01" placeholder="M Ali-03xxyyyzzzz-Brother" required />
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Emergency Contact 02</label>
                                        <input type="text" class="form-control" name="emergency_contact_02" id="emergency_contact_02" placeholder="Saad Ahmed-03xxyyyzzzz-Cousin" />
                                    </div>
                                </div>


                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Skills Set <span class="text-danger font-14">*</span></label>
                                        <select class="form-control" id="skillSets" name="modal_skills_set" multiple required>
                                            @foreach (ViewModels.SkillsSet item in Model.skillSets)
                                            {
                                                <option value="@item.id">@item.skillname</option>
                                            }
                                        </select>
                                    </div>
                                </div>



                            </div>



                            <!-- Column - 3 -->
                            <div class="col-4">

                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">Sick Leaves <span class="text-danger font-14">*</span> <small>(for whole year)</small></label>
                                        <select class="form-control" id="sick_leaves" name="sick_leaves" required>
                                            <option value="0">00</option>
                                            <option value="1">01</option>
                                            <option value="2">02</option>
                                            <option value="3">03</option>
                                            <option value="4">04</option>
                                            <option value="5">05</option>
                                            <option value="6">06</option>
                                            <option value="7" selected>07</option>
                                            <option value="8">08</option>
                                            <option value="9">09</option>
                                            <option value="10">10</option>
                                            <option value="11">11</option>
                                            <option value="12">12</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Casual Leaves <span class="text-danger font-14">*</span> <small>(for whole year)</small></label>
                                        <select class="form-control" id="casual_leaves" name="casual_leaves" required>
                                            <option value="0">00</option>
                                            <option value="1">01</option>
                                            <option value="2">02</option>
                                            <option value="3">03</option>
                                            <option value="4">04</option>
                                            <option value="5">05</option>
                                            <option value="6">06</option>
                                            <option value="7">07</option>
                                            <option value="8" selected>08</option>
                                            <option value="9">09</option>
                                            <option value="10">10</option>
                                            <option value="11">11</option>
                                            <option value="12">12</option>
                                            <option value="13">13</option>
                                            <option value="14">14</option>
                                            <option value="15">15</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Annual Leaves <span class="text-danger font-14">*</span> <small>(for whole year)</small></label>
                                        <select class="form-control" id="annual_leaves" name="annual_leaves" required>
                                            <option value="0">00</option>
                                            <option value="1">01</option>
                                            <option value="2">02</option>
                                            <option value="3">03</option>
                                            <option value="4">04</option>
                                            <option value="5">05</option>
                                            <option value="6">06</option>
                                            <option value="7">07</option>
                                            <option value="8">08</option>
                                            <option value="9">09</option>
                                            <option value="10" selected>10</option>
                                            <option value="11">11</option>
                                            <option value="12">12</option>
                                            <option value="13">13</option>
                                            <option value="14">14</option>
                                            <option value="15">15</option>
                                            <option value="16">16</option>
                                            <option value="17">17</option>
                                            <option value="18">18</option>
                                            <option value="19">19</option>
                                            <option value="20">20</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label id="lupload_file_01" class="control-label">CNIC</label>
                                        <input type="file" class="form-control" name="file_01" accept=".jpg" />
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label id="lupload_file_02" class="control-label">Qualification/Degree</label>
                                        <input type="file" class="form-control" name="file_02" accept=".jpg" />
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label id="lupload_file_03" class="control-label">Experience Certificate</label>
                                        <input type="file" class="form-control" name="file_03" accept=".jpg" />
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label id="lupload_file_04" class="control-label">Other Doc</label>
                                        <input type="file" class="form-control" name="file_04" accept=".jpg" />
                                    </div>
                                </div>
                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Date of Birth <span class="text-danger font-14">*</span></label>
                                        <input type="text" class="form-control datepicker" name="date_of_birth" required />
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label id="ldescription" class="control-label">Description</label>
                                        <textarea id="description" name="description" rows="7" cols="10" class="form-control"></textarea>
                                    </div>
                                </div>


                            </div>
                        </div>



                        <!-- Row - 2 -->
                        <div class="row">
                            <div class="col-12 text-danger">
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary()
                            </div>
                        </div>

                        <!-- Row - 3 -->
                        <div class="row">
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary waves-effect waves-light m-t-10">Add Employee</button>
                                <button type="reset" value="Reset" class="btn btn-primary waves-effect waves-light m-t-10">Reset</button>
                            </div>
                        </div>
                    }

                    <hr>

                    <div class="row">
                        <div class="col-12 m-b-10">
                            <h3>Current Employees List</h3>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <table id="emp_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>First Name</th>
                                        <th>Last Name</th>
                                        <th>Employee Code</th>
                                        <th>Department</th>
                                        <th>Designation</th>
                                        <th>Grade</th>
                                        <th>User Profile</th>
                                        <th>User Payroll</th>
                                        <th>Action</th>
                                        <th>Date Of Birth</th>
                                        <th>Function</th>
                                        <th>Region</th>
                                        <th>Location</th>
                                        <th>Line Manager</th>
                                        <th>Super Line Manager</th>
                                        <th>Status</th>
                                        <th>Sick Leaves</th>
                                        <th>Casual Leaves</th>
                                        <th>Annual Leaves</th>
                                        <th>Emrg.Contact-1</th>
                                        <th>Emrg.Contact-2</th>
                                        <th>View Docs</th>
                                        <th>Skills Set</th>
                                        <th>Description</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" class="btn btn-primary waves-effect waves-light">Export to Excel</button>
                        </div>
                    </div>

                    <hr />


                    <div class="row m-t-10">
                        <div class="col-12">
                            <h3>Update using 'Upload File'</h3>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-3">
                            <a href="~/Uploads/SampleEmployees.csv">Download Sample File</a>
                        </div>

                        <div class="col-6">
                            &nbsp;
                        </div>

                        <div class="col-3 text-right d-none">
                            @using (Html.BeginForm("DownloadCSVFile", "EmployeeManagement", FormMethod.Post, new { id = "download-form" }))
                            {
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary()

                                <button id="btnDownload" type="submit" value="Submit" class="btn btn-sm btn-default waves-effect waves-light">Download ALL Employees (CSV)</button>

                            }
                        </div>

                    </div>

                    @using (Html.BeginForm("UploadFile", "EmployeeManagement", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary()

                        <div class="row">
                            <div class="col-4">
                                <label class="btn btn-primary" for="my-file-selector">
                                    <input id="my-file-selector" onchange="alertFilename()" type="file" name="file" value="alert" accept=".csv" style="display:none; ">
                                    Click to select file
                                </label>
                                <h3 class="label" id="file-name"></h3>
                            </div>

                            <div class="col-4">
                                <button id="btnUpload" type="submit" value="Submit" class="btn btn-danger waves-effect waves-light">Upload File</button>
                                @if (ViewBag.Message != null && ViewBag.Message.ToString().Contains("Success"))
                                {
                                    <label class="label msg" style="font-size:medium;  color:green;">@ViewBag.Message</label>
                                }
                                else
                                {
                                    <label class="label msg" style="font-size:medium;  color:red;">@ViewBag.Message</label>
                                }
                            </div>
                        </div>
                    }


                </div>
            </div>
        </div>
    </div>
</div>

<div id="employee_modals">

    <div id='employee-edit-form' class='jqUI-modal' title='Edit Employee'>
        <p class='validationTips'><span class="text-danger font-14">*</span> indicates required fields.</p>
        <form id='employee-modal-form' enctype="multipart/form-data">
            <fieldset>
                <div class="row">
