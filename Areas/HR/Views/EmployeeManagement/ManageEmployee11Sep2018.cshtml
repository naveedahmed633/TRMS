                        <select class="employee-department-select" name="department_id" id="modal_department" style="min-width: 350px">
                            <option value="0">none</option>
                        </select>
                        @*<select name="department_id" id="modal_department" style="width:100%">
                                <option selected="selected" disabled="disabled" value="0">Select Department</option>
                                @foreach (ViewModels.Department item in Model.departments)
                                {
                                    <option value="@item.id">@item.name</option>
                                }
                            </select>*@
                    </div>
                </div>

                <div class="row m-t-10">
                    <div class="col-12">
                        <label class="control-label">Type of Employment <span class="text-danger font-14">*</span></label>
                        <select class="employee-toe-select" name="modal_type_of_employment" id="modal_type_of_employment" style="min-width: 350px">
                            <option value="0">none</option>
                        </select>
                        @*<select name="type_of_employment_id" id="modal_type_of_employment" style="width:100%">
                                <option selected="selected" disabled="disabled" value="0">Select TOE</option>
                                @foreach (ViewModels.TypeOfEmployment item in Model.typeOfEmployments)
                                {
                                    <option value="@item.id">@item.name</option>
                                }
