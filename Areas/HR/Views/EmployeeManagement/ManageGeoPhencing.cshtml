@{
    ViewBag.Title = "TRMS - Geo Phencing Management";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

@model List<ViewModels.TerminalView>

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.welcome")  <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span></h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Management</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.geo") </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    @using (Html.BeginForm("ManageGeoPhencing", "EmployeeManagement", FormMethod.Post, new { id = "employee-form" }))
                    {
                        <div class="row">

                            <div class="col-6">
                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.empcode")</label>
                                        <select id="users-select" class="form-control" name="EmployeeId" required></select>
                                    </div>
                                </div>

                                <div class="row m-t-20">
                                    <div class="col-12">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.branches")</label>
                                        <select id="branches" name="lstBranches" class="form-control" multiple>
                                            <option value=""></option>
                                        </select>
                                    </div>
                                </div>

                                @*<div class="row m-t-20">
                                        <div class="col-12">
                                            <label class="control-label">Terminal(s)</label>
                                            <select id="terminals" name="lstTerminals" class="form-control" multiple>
                                                <option value=""></option>
                                            </select>
                                        </div>
                                    </div>*@

                            </div>

                            <div class="col-6">
                            </div>

                        </div>

                        <div class="row m-t-10">
                            <div class="col-12 text-danger">
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary()
                                @if (Request.QueryString["Message"] != null && Request.QueryString["Message"].ToString() == "success")
                                {
                                    <div class="row">
                                        <div class="col-12">
                                            <span class="span_message"><b>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.recordsuccess")</b></span>
                                        </div>
                                    </div>
                                }
                                @if (Request.QueryString["Message"] != null && Request.QueryString["Message"].ToString() == "already")
                                {
                                    <div class="row">
                                        <div class="col-12">
                                            <span class="span_message"><b>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.recorderr")</b></span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12">
                                <button type="submit" onclick="return submitcheck();" class="btn btn-primary waves-effect waves-light m-t-10">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.add")</button>
                                <button type="button" class="btn btn-primary waves-effect waves-light m-t-10" onclick="redirectToPage();">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.reset")</button>
                                @*<button type="reset" value="Reset" class="btn btn-primary waves-effect waves-light m-t-10">Reset</button>*@
                            </div>
                        </div>
                    }

                </div>
            </div>
        </div>

    </div>
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">


                    <div class="row">
                        <div class="col-12 m-b-10">
                            <h3>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.currentlist")</h3>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <table id="geoPhencing_table" class="table table-striped table-bordered dataTable dt-responsive no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.id")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.empcode")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.fullname")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.createdate")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.actions")</th>
                                    </tr>
                                </thead>

                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" class="btn btn-primary waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exportgrid")</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>

    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <div class="panel-body">

                    <div class="row m-t-10">
                        <div class="col-12">
                            <h3>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.uploadusingcsvfile")</h3>
                        </div>
                    </div>

                    <div class="row">

                        <div class="col-3">
                            <a href="~/Uploads/SampleGeoPhencing.csv">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.downloadsf")</a>
                        </div>



                        <div class="col-6">
                            <div class="d-none">
                                @using (Html.BeginForm("DownloadGeoPhencingCSVFile", "EmployeeManagement", FormMethod.Post, new { id = "download-form" }))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.ValidationSummary()

                                <button id="btnDownload" type="submit" value="Submit" class="btn btn-sm btn-default waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.downloadecsv")</button>

                                }
                            </div>
                        </div>


                        <div class="col-3 text-right">
                            <a class="text-right text-primary" style="cursor: pointer" onclick="viewBranches()">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.viewbcodes")</a>
                        </div>
                    </div>

                    @using (Html.BeginForm("UploadGeoPhencingCSVFile", "EmployeeManagement", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary()


                        <div class="row">
                            <div class="col-6">
                                <label class="btn btn-primary" for="my-file-selector">
                                    <input id="my-file-selector" onchange="alertFilename()" type="file" name="file" value="alert" accept=".csv" style="display:none; ">
                                    @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.click")
                                </label>
                                <h3 class="label" id="file-name"></h3>
                            </div>

                            <div class="col-6">
                                <button id="btnUpload" type="submit" value="Submit" class="btn btn-danger waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.uploadfile")</button>
                                @if (ViewBag.UpMessage != null && ViewBag.UpMessage.ToString().Contains("Success"))
                                {
                                    <label class="label msg" style="font-size:medium;  color:green;">@ViewBag.UpMessage</label>
                                }
                                else
                                {
                                    <label class="label msg" style="font-size:medium;  color:red;">@ViewBag.UpMessage</label>
                                }
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-6">
                                @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.crf")
                                <ul>
                                    <li>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.empcode")</li>
                                    <li>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.branchcode")</li>
                                </ul>
                            </div>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>

</div>
<!--End content -->


<div id="MidTermModal" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="MidTermModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                <h4 class="modal-title" id="CenterModalLabel">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.branchlist")</h4>
            </div>
            <div class="modal-body text-center">
                <div style="height: 300px; overflow: scroll;">
                    <table>
                        <tr>
                            <td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.branchcode")</td>
                            <td>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.title")</td>
                        </tr>
                        @if (Model.Any())
                        {
                            foreach (var t in Model)
                            {
                                <tr>
                                    <td>@t.Branch_Code</td>
                                    <td>@t.Branch_Name</td>
                                </tr>
                            }

                        }
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary waves-effect" data-dismiss="modal">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.close")</button>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div>

<div id="moll">
</div>
<div id="toast" class="toast-message" style='display:none'>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.msg")</div>


<div style="display: none;">
    <div id='geo-phenced-form' class='jqUI-modal' title='Edit Geo Phencing'>

        <p class='validationTips'>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.reqallfields")</p>
        <form id='geo_phencing_edit_modal'>

            <fieldset>

                @*<label class='control-label m-t-10'>Employee Code</label>\
                    <input type='text' class='form-control' name='emp_code' id='emp_code' readOnly />\
                    <label class='control-label m-t-10'>Employee Name</label>\
                    <input type='text' class='form-control' name='emp_name' id='emp_name' readOnly />\
                    <label class='control-label m-t-10'>Branches List</label>\
                    <ul id='ul_branches'></ul>\
                    <input type='text' class='form-control' name='lst_branches' id='modal-branches' />\
                    <label class='control-label m-t-10'>Terminals List</label>\
                    <ul id='ul_terminals'></ul>\
                    <input type='text' class='form-control d-none' name='lst_terminals' id='lst_terminals' readOnly />\
                    <label class='control-label m-t-10'>Created Date</label>\
                    <input type='text' class='form-control' name='crt_date' id='crt_date' readOnly />\*@


                <div class='row'>
                    <div class='col-12'>
                        <input type='hidden' name='id' id='id'>
                        <input type='hidden' name='employeeid' id='employeeid'>
                        <label class='control-label'>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.empcode")</label><br />
                        <input type='text' class='form-control' name='emp_code' id='emp_code' readOnly />
                    </div>
                </div>

                <div class='row'>
                    <div class='col-12'>
                        <input type='hidden' name='id' id='id'>
                        <input type='hidden' name='employeeid' id='employeeid'>
                        <label class='control-label'>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.empname")</label><br />
                        <input type='text' class='form-control' name='emp_name' id='emp_name' readOnly />
                    </div>
                </div>

                <div class='row m-t-10'>
                    <div class='col-12'>
                        <label class='control-label'>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.branches")</label><br />
                        <select id='modal-branches' name='lstBranches' class="form-control" style="width: 100%;" multiple>
                            <option value=''></option>
                        </select>
                        <ul id='ul_branches'></ul>
                    </div>
                </div>

                <div class='row m-t-10'>
                    <div class='col-12'>
                        <label class='control-label'>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.terminals")</label><br />
                        @*<select id='modal-terminals' name='lstTerminals' class="form-control" style="width: 100%;" multiple>
                                <option value=''></option>
                            </select>*@
                        <ul id='ul_terminals'></ul>
                    </div>
                </div>

                <div class='row m-t-10'>
                    <div class='col-12'>
                        <label class='control-label'>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.createdate")</label><br />
                        <input type='text' class='form-control' name='crt_date' id='crt_date' readOnly />
                    </div>
                </div>


                @*<div class='row m-t-10'>
                        <div class='col-12'>
                            <label class='control-label'>Search Group Shifts</label><br />
                            <select id='modal-group-shifts' name='group_shifts' class="form-control" style="width: 100%;" multiple>
                                <option value=''></option>
                            </select>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <label class="control-label">Follows General Calendar</label>
                            <input type="checkbox" class="checkbox" name="follows_general_calendar" id='modal-group-follows-gc' value="true" checked="checked" />
                        </div>
                    </div>*@

                <input type='submit' tabindex='-1' style='position:absolute; top:-1000px'>
            </fieldset>
        </form>
    </div>
</div>

<!-- Custom Modal -->
<div class="modal fade bs-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="mySmallModalLabel" aria-hidden="true" style="display: none;">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                <h4 class="modal-title" id="mySmallModalLabel">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.msgalert")</h4>
            </div>
            <div class="modal-body">
                <span id="alert_message"></span>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->



@section JS {
    <script type="text/javascript" src="@Href("~/Scripts/chosen.ajaxaddition.jquery.js")"></script>
    <script src="@Url.Content("/Scripts/geoPhencingCRUD.js")" type="text/javascript"></script>
    <script>

        function viewBranches() {
            $('#MidTermModal').modal('show');
        }

        function alertFilename() {
            var thefile = document.getElementById('my-file-selector');
            document.getElementById('file-name').innerHTML = thefile.value;
        }


        $(document).ready(function () {
            var empCode2= @Html.Raw(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId);

            $.ajax({
                url: '/HR/HR/VerfiyDataHandler',
                type: "POST",
                data: { empId: empCode2 },
                dataType: "json",

                success: function (data) {
                    if (data.HRExportGridData == false) {
                        $("#btnExport").hide();
                    }



                },
                error: function () {
                    alert("error");
                }
            });
            $(".datepicker").datepicker({ dateFormat: 'dd-mm-yy' });
            $("#btnExport").click(function (e) {
                setupTableExportButton('#geoPhencing_table', 'Geo-Phencing');
                e.preventDefault();
            });

            HideSpanMessage();

            initializeChosenSelects();


        });

        function redirectToPage() {
            window.location = '/HR/EmployeeManagement/ManageGeoPhencing';
        }

        function HideSpanMessage() {
            setTimeout(function () { $('.span_message').hide(); }, 3000);
        }

        function submitcheck() {

            var fDate = $('[name="str_SessionStartDate"]').val();
            var tDate = $('[name="str_SessionEndDate"]').val();
            if (tDate < fDate) {
                $('#alert_message').text("The 'To Date' should be greater than 'From Date'.");
                $('.bs-example-modal-lg').modal('show');
                return false;
            } else { return true; }
        }


        function initializeChosenSelects() {

            function initializeSelect(identifier, url) {
                $(identifier).ajaxChosen({
                    dataType: 'json',
                    type: 'POST',
                    url: url
                }, {
                    loadingImg: '@Href("~/Content/ChosenAutoComplete/loading.gif")'
                });
            }

            initializeSelect('#users-select', '@Url.Action("GetUsersForGeoPhencing", "EmployeeManagement", null, Request.Url.Scheme)');
            initializeSelect('#branches', '@Url.Action("GetBranchesForGeoPhencing", "EmployeeManagement", null, Request.Url.Scheme)');
            //initializeSelect('#group-shifts', '@Url.Action("shiftsDataHandler", "EmployeeManagement", null, Request.Url.Scheme)');

            // modal
            initializeSelect('#modal-users-select', '@Url.Action("GetUsersForGeoPhencing", "EmployeeManagement", null, Request.Url.Scheme)');
            initializeSelect('#modal-branches', '@Url.Action("GetBranchesForGeoPhencing", "EmployeeManagement", null, Request.Url.Scheme)');
            //initializeSelect('#modal-group-shifts', '@Url.Action("shiftsDataHandler", "EmployeeManagement", null, Request.Url.Scheme)');



        }




        // setChosenSelectList('#users-select', '@Url.Action("GetUsersForGeoPhencing", "EmployeeManagement", null, Request.Url.Scheme)');



        var url = '@Url.Action("GeoPhencingDataHandler", "EmployeeManagement", null, Request.Url.Scheme)';

        var columns = [
                  { "data": "id" },
                  { "data": "EmployeeCode" },
                  { "data": "FullName" },
                  { "data": "strTrmCreateDate" },
                  { "data": "actions" }
        ];
        initServerSideTable('#geoPhencing_table', url, columns, 100);//10, 25, 50, 100, 500, 1000, 1500
        editGeoPhencing = initEditGeoPhencingModal("#moll", '@Url.Action("UpdateGeoPhencing", "EmployeeManagement", null, Request.Url.Scheme)', "GeoPhencing");
        deleteGeoPhencing = initDeleteGeoPhencingModal("#moll", '@Url.Action("RemoveGeoPhencing", "EmployeeManagement", null, Request.Url.Scheme)', "GeoPhencing");

    </script>
}
