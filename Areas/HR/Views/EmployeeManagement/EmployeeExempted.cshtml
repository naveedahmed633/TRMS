@{
    ViewBag.Title = "TRMS - Exempted Employees Management";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

@{
    //Titles - Leave Types
    string TitleLeaves = "", TitleLeave01 = "", TitleLeave02 = "", TitleLeave03 = "", TitleLeave04 = "", TitleLeave05 = "", TitleLeave06 = "", TitleLeave07 = "", TitleLeave08 = "";
    string LTCS = "", TitleLeave09 = "", TitleLeave10 = "", TitleLeave11 = "", TitleLeave12 = "", TitleLeave13 = "", TitleLeave14 = "", TitleLeave15 = "";
    BLL.PdfReports.LeavesTypesTitles leavesTitles = new BLL.PdfReports.LeavesTypesTitles();
    TitleLeaves = leavesTitles.getLeavesTypesTitles();
    if (TitleLeaves != null && TitleLeaves.Contains(','))
    {
        string[] strSplit = TitleLeaves.Split(',');
        if (strSplit != null && strSplit.Length > 0)
        {
            TitleLeave01 = strSplit[0].ToString(); TitleLeave02 = strSplit[1].ToString(); TitleLeave03 = strSplit[2].ToString(); TitleLeave04 = strSplit[3].ToString();
            TitleLeave05 = strSplit[4].ToString(); TitleLeave06 = strSplit[5].ToString(); TitleLeave07 = strSplit[6].ToString(); TitleLeave08 = strSplit[7].ToString();
            TitleLeave09 = strSplit[8].ToString(); TitleLeave10 = strSplit[9].ToString(); TitleLeave11 = strSplit[10].ToString(); TitleLeave12 = strSplit[11].ToString();
            TitleLeave13 = strSplit[12].ToString(); TitleLeave14 = strSplit[13].ToString(); TitleLeave15 = strSplit[14].ToString();
        }
    }
    else
    {
        TitleLeave01 = @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.sick"); TitleLeave02 = @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.casual"); TitleLeave03 = @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.annual"); TitleLeave04 = @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.other");
        TitleLeave05 = @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.tour"); TitleLeave06 = @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.visit"); TitleLeave07 = @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.meeting"); TitleLeave08 = @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("leave.maternity");
        TitleLeave09 = "A"; TitleLeave10 = "B"; TitleLeave11 = "C"; TitleLeave12 = "D";
        TitleLeave13 = "E"; TitleLeave14 = "F"; TitleLeave15 = "G";
    }
}

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.welcome")  <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span></h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Leaves</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.eem") </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    @using (Html.BeginForm("EmployeeExempted", "EmployeeManagement", FormMethod.Post, new { id = "employee-form"}))
                    {
                        <div class="row">

                            <div class="col-4">
                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.empcode")</label>
                                        <select id="users-select" class="form-control" name="EmployeeId" required></select>
                                    </div>
                                </div>

                           
                            </div>
                            
                        </div>

                        <div class="row m-t-10">
                            <div class="col-12 text-danger">
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary()
                                @if (Request.QueryString["Message"] != null && Request.QueryString["Message"].ToString() == "success")
                                {
                                    <div class="row">
                                        <div class="col-12">
                                            <span class="span_message"><b>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.recordsuccess")</b></span>
                                        </div>
                                    </div>
                                }
                                @if (Request.QueryString["Message"] != null && Request.QueryString["Message"].ToString() == "already")
                                {
                                    <div class="row">
                                        <div class="col-12">
                                            <span class="span_message"><b>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.recorderr")</b></span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12">
                                <button type="submit" onclick="return submitcheck();" class="btn btn-primary waves-effect waves-light m-t-10">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.add")</button>
                                <button type="reset" value="Reset" class="btn btn-primary waves-effect waves-light m-t-10">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.reset")</button>
                            </div>
                        </div>
                                                }



                </div>
            </div>
        </div>

    </div>
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">


                    <div class="row">
                        <div class="col-12 m-b-10">
                            <h3>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.currentlist")</h3>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <table id="exemptedEmployee_table" class="table table-striped table-bordered dataTable dt-responsive no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.id")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.empcode")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.name")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.createdate")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.actions")</th>
                                    </tr>
                                </thead>

                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" class="btn btn-primary waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exportgrid")</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>

</div>
<div id="moll">
</div>
<div id="toast" class="toast-message" style='display:none'>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("portal.msg")</div>

<!-- Custom Modal -->
<div class="modal fade bs-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="mySmallModalLabel" aria-hidden="true" style="display: none;">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                <h4 class="modal-title" id="mySmallModalLabel">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.msgalert")</h4>
            </div>
            <div class="modal-body">
                <span id="alert_message"></span>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->



@section JS {
    <script type="text/javascript" src="@Href("~/Scripts/chosen.ajaxaddition.jquery.js")"></script>
    <script src="@Url.Content("/Scripts/employeeExemptedCRUD.js")" type="text/javascript"></script>
    <script>
        $(document).ready(function () {
            var empCode2= @Html.Raw(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId);

            $.ajax({
                url: '/HR/HR/VerfiyDataHandler',
                type: "POST",
                data: { empId: empCode2 },
                dataType: "json",

                success: function (data) {
                    if (data.HRExportGridData == false) {
                        $("#btnExport").hide();
                    }



                },
                error: function () {
                    alert("error");
                }
            });
            $(".datepicker").datepicker({ dateFormat: 'dd-mm-yy' });
            $("#btnExport").click(function (e) {
                setupTableExportButton('#exemptedEmployee_table', 'Exempted-Employees');
                e.preventDefault();
            });

            HideSpanMessage();

        });

        function HideSpanMessage() {
            setTimeout(function () { $('.span_message').hide(); }, 3000);
        }

        function submitcheck() {

            var fDate = $('[name="str_SessionStartDate"]').val();
            var tDate = $('[name="str_SessionEndDate"]').val();
            if (tDate < fDate) {
                $('#alert_message').text("The 'To Date' should be greater than 'From Date'.");
                $('.bs-example-modal-lg').modal('show');

                return false;

            } else { 
                return true; 
            }
        }

        function setChosenSelectList(selector, URL) {


            $(selector).ajaxChosen({
                dataType: 'json',
                type: 'POST',
                url: URL
            }, {
                loadingImg: '@Href("~/Content/ChosenAutoComplete/loading.gif")'
            });
        }

        setChosenSelectList('#users-select', '@Url.Action("dropdown_users", "EmployeeManagement", null, Request.Url.Scheme)');


        var url = '@Url.Action("EmployeeExemptedDataHandler", "EmployeeManagement", null, Request.Url.Scheme)';

        var columns = [
                  { "data": "id" },
                  { "data": "EmployeeCode" },
                  { "data": "FullName" },
                  { "data": "str_CreateDate" },
                  { "data": "actions" }
        ];

        //initServerSideTable('#exemptedEmployee_table', url, columns, 100);//10, 25, 50, 100, 500, 1000, 1500
        initServerSideTableColumnOrderBy('#exemptedEmployee_table', url, columns, 100, 0, "desc");//10, 25, 50, 100, 500, 1000, 1500
        //function initServerSideTableColumnOrderBy(identifier, url, columns, count, col_pos, order_by)

        editEmployeeExempted = initEditEmployeeExempted("#moll", '@Url.Action("UpdateEmployeeExempted", "EmployeeManagement", null, Request.Url.Scheme)', "EmployeeExempted");
        deleteEmployeeExempted = initDeleteModal("#moll", '@Url.Action("RemoveEmployeeExempted", "EmployeeManagement", null, Request.Url.Scheme)', "EmployeeExempted");

    </script>
}
