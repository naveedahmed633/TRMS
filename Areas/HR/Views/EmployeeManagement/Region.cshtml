@{
    ViewBag.Title = "TRMS - Regions Management";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

@model List<ViewModels.Region>

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'HR'</span>! [Login ID: <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Employee Portal</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> Program Groups Management </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-4">

                            @using (Html.BeginForm("AddRegion", "EmployeeManagement"))
                            {
                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">Program Group Name <span class="text-danger font-14">*</span></label>
                                        <input type="text" pattern=".{2,}" title="2 characters minimum" class="form-control" id="fname" name="name"
                                               oninput="setCustomValidity('');" oninvalid="setCustomValidity('Name should contain at least 2 characters.');" required />
                                    </div>
                                </div>


                                <div class="row m-t-10">
                                    <div class="col-12">
                                        <label class="control-label">Description <span class="text-danger font-14">*</span></label>
                                        <textarea class="form-control" name="description"></textarea>
                                    </div>
                                </div>

                                <div class="row m-t-10">
                                    <div class="col-12 text-danger">
                                        @Html.AntiForgeryToken()
                                        @Html.ValidationSummary()
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12">
                                        <button type="submit" class="btn btn-primary waves-effect waves-light m-t-10">Add Program Group</button>
                                        <button type="reset" value="Reset" class="btn btn-primary waves-effect waves-light m-t-10">Reset</button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>

    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
        

                    <div class="row">
                        <div class="col-12 m-b-10">
                            <h3>Current Program-Group List</h3>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <table id="region_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Group Name</th>
                                        <th>Description</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" class="btn btn-primary waves-effect waves-light">Export Grid Data</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>
<!-- End content -->

@section JS {
    <script>
        $(document).ready(function () {
            var empCode2= @Html.Raw(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId);

            $.ajax({
                url: '/HR/HR/VerfiyDataHandler',
                type: "POST",
                data: { empId: empCode2 },
                dataType: "json",

                success: function (data) {
                    if (data.HRExportGridData == false) {
                        $("#btnExport").hide();
                    }
                   
                   
                 
                },
                error: function () {
                    alert("error");
                }
            });
            //$('#btnExport').button();
            $("#btnExport").click(function (e) {
                setupTableExportButton('#region_table', 'PGroup');
                e.preventDefault();
            });

            /*
            $('#btnExport').button();
            $("#btnExport").click(function (e) {
                $('#region_table').tableExport({ type: 'excel', escape: 'false' });
                e.preventDefault();
            });
            */

            var url = '@Url.Action("RegionDataHandler", "EmployeeManagement", null, Request.Url.Scheme)';

            var columns = [
                  { "data": "id" },
                  { "data": "name" },
                  { "data": "description" },
                  { "data": "actions" }
            ];

            initServerSideTable('#region_table', url, columns, 10);//10, 25, 50, 100, 500, 1000, 1500

            editRegion = initEditModal("#modals", '@Url.Action("UpdateRegion", "EmployeeManagement", null, Request.Url.Scheme)', "P-Group");
            deleteRegion = initDeleteModal("#modals", '@Url.Action("RemoveRegion", "EmployeeManagement", null, Request.Url.Scheme)', "P-Group");
        });
    </script>
}
