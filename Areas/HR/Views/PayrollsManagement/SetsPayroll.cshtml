@{
    ViewBag.Title = "TRMS - Set Payroll";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

@model ViewModels.CreateEmployee

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'HR'</span>! [Login ID: <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Payroll</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i>Set Current Employees Payroll</h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-12">
                            @if (Request.QueryString["message"] != null && Request.QueryString["message"].ToString() == "success")
                            {
                                <div class="form-group row">
                                    <div class="text-danger h4 msg">
                                        The user has been added successfully!!!
                                    </div>
                                </div>
                            }

                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12">
                            <table id="emp_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>First Name</th>
                                        <th>Last Name</th>
                                        <th>Employee Code</th>
                                        <th>Department</th>
                                        <th>Designation</th>
                                        <th>Grade</th>
                                        <th>User Payroll</th>
                                        <th>User Profile</th>
                                        <th>Date Of Birth</th>
                                        <th>Function</th>
                                        <th>Region</th>
                                        <th>Location</th>
                                        <th>Line Manager</th>
                                        <th>Super Line Manager</th>
                                        <th>Status</th>
                                        <th>Sick Leaves</th>
                                        <th>Casual Leaves</th>
                                        <th>Annual Leaves</th>
                                        <th>Emrg.Contact-1</th>
                                        <th>Emrg.Contact-2</th>
                                        <th>View Docs</th>
                                        <th>Skills Set</th>
                                        <th>Description</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" class="btn btn-primary waves-effect waves-light">Export Grid Data</button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>





<div id="toast" class="toast-message" style='display:none'>Message!</div>

@section JS {

    <script type="text/javascript">

