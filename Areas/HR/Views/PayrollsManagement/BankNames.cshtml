@{
    ViewBag.Title = "TRMS - Bank Names Management";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

@model List<ViewModels.Function>

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">Welcome <span class="text-danger">'HR'</span>! [Login ID: <span class="text-warning" title="@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId)">@User.Identity.Name</span> & Name: <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span>]</h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Payroll</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="mdi mdi-desktop-classic"></i> Bank Names Management </h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>

                    <div class="row">
                        <div class="col-4">

                            @using (Html.BeginForm("AddBank", "PayrollsManagement"))
                            {
                                <div class="row">
                                    <div class="col-12">
                                        <label class="control-label">Bank Name</label>
                                        <input type="text" pattern=".{2,}" title="2 characters minimum" class="form-control" id="banknametext" name="banknametext"
                                               oninput="setCustomValidity('');" oninvalid="setCustomValidity('Name should contain at least 2 characters.');" required />
                                    </div>
                                </div>
                                <div class="row m-t-10">
                                    <div class="col-12 text-danger">
                                        @Html.AntiForgeryToken()
                                        @Html.ValidationSummary()
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12">
                                        <button type="submit" class="btn btn-primary waves-effect waves-light m-t-10">Add Bank Name</button>
                                        <button type="button" class="btn btn-primary waves-effect waves-light m-t-10" onclick="redirectToPage();">Reset</button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    @if (Request.QueryString["Message"] != null && Request.QueryString["Message"].ToString() == "success")
                    {
                        <div class="row">
                            <div class="col-12">
                                <span class="span_message" style="font-size: 19px; color: red;">The record is added successfully!</span>
                            </div>
                        </div>
                    }
                    @if (Request.QueryString["Message"] != null && Request.QueryString["Message"].ToString() == "already")
                    {
                        <div class="row">
                            <div class="col-12">
                                <span class="span_message" style="font-size: 19px; color: red;">This record already exists.</span>
                            </div>
                        </div>}
                  

                </div>
            </div>
        </div>

    </div>
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    

                    <div class="row">
                        <div class="col-12 m-b-10">
                            <h3>Current Bank List</h3>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <table id="function_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Bank</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" class="btn btn-primary waves-effect waves-light">Export Grid Data</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>
<!-- End content -->

@section JS {

    <script src="@Url.Content("/Scripts/bankNamesCRUD.js")" type="text/javascript"></script>

    <script>
        function redirectToPage() {
            window.location.reload();
        }
        function HideSpanMessage() {
            setTimeout(function () { $('.span_message').hide(); }, 3000);
        }
        $(document).ready(function () {
            //$('#accordion').accordion("option", "active", 1);
            //$("input[type=submit], button").button();
            //setActiveLink("Function");
            HideSpanMessage();
            //$('#btnExport').button();
            $("#btnExport").click(function (e) {
                setupTableExportButton('#function_table', 'BankNames');
                e.preventDefault();
            });


            /*
            $('#btnExport').button();
            $("#btnExport").click(function (e) {
                $('#function_table').tableExport({ type: 'excel', escape: 'false' });
                e.preventDefault();
            });
            */


            var url = '@Url.Action("BankDataHandler", "PayrollsManagement", null, Request.Url.Scheme)';

            var columns = [
                      { "data": "Id" },
                      { "data": "BankNameText" },
                      { "data": "action" }

            ];
            initServerSideTable('#function_table', url, columns, 100);//10, 25, 50, 100, 500, 1000, 1500
            editBank = initEditModalSkill("#modals", '@Url.Action("UpdateBank", "PayrollsManagement", null, Request.Url.Scheme)', "Banks");
            deleteBank = initDeleteModalSkill("#modals", '@Url.Action("RemoveBank", "PayrollsManagement", null, Request.Url.Scheme)', "Banks");
        });
    </script>
}
