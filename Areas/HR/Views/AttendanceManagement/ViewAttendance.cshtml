@{
    ViewBag.Title = "Persistent Attendance Management";
    Layout = "~/Areas/HR/Views/Shared/_Layout.cshtml";
}

@model ViewModels.CreateManualAttendance

<!-- Start content -->
<div class="container-fluid">
    <!-- Page-Title -->
    <div class="row">
        <div class="col-sm-12">
            <div class="page-title-box">
                <h4 class="page-title">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("dashboard.welcome")  <span class="text-success">@MvcApplication1.ViewModel.GlobalVariables.CheckNULLValidation(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeName)</span></h4>
                <ol class="breadcrumb float-right">
                    <li class="breadcrumb-item"><a href="/HR">HR</a></li>
                    <li class="breadcrumb-item active">Today's Attendance Logs</li>
                </ol>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

    <!-- Page-Content -->
    <div class="row">
        <div class="col-12">
            <div class="card-box">
                <!-- <div class="panel-heading">
                    <h4>Invoice</h4>
                </div> -->
                <div class="panel-body">
                    <div class="clearfix">
                        <div class="pull-left">
                            <h3 class="text-right"><i class="ti-files"></i> @MvcApplication1.ViewModel.GlobalVariables.GetStringResource("attendance.tal")</h3>
                        </div>
                        <div class="pull-right small text-muted">
                            @DateTime.Now.ToString("f")
                        </div>
                    </div>

                    <hr>


                    <div class="row">
                        <div class="col-12">

                            @using (Html.BeginForm("TodaysAttendanceDataHandler", "AttendanceManagement", FormMethod.Post, new { id = "todays-attendance-form" }))
                            {
                                <button type="submit" id="generate-todays-attendance-report" form="todays-attendance-form" class="btn btn-primary waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("attendance.exportpdf")</button>
                            }
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <hr>
                        </div>
                    </div>


                    <div class="row">
                        <div class="col-12">
                            <h3>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("attendance.clist")</h3>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            &nbsp;
                        </div>
                    </div>


                    <div class="row">
                        <div class="col-12">
                            <table id="attendance_table" class="table table-striped table-bordered dataTable dt-responsive nowrap no-footer small" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.date")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.empcode")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.fname")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.lname")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.timein")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.timeout")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.devicein")</th>
                                        <th>@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.deviceout")</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row m-t-10">
                        <div class="col-12">
                            <button type="submit" id="btnExport" class="btn btn-primary waves-effect waves-light">@MvcApplication1.ViewModel.GlobalVariables.GetStringResource("report.exportgrid")</button>

                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- End content -->

@section JS {
    <script type="text/javascript">

        $(document).ready(function () {
            var empCode2= @Html.Raw(MvcApplication1.ViewModel.GlobalVariables.GV_EmployeeId);

            $.ajax({
                url: '/HR/HR/VerfiyDataHandler',
                type: "POST",
                data: { empId: empCode2 },
                dataType: "json",

                success: function (data) {
                    if (data.HRExportGridData == false) {
                        $("#btnExport").hide();
                    }



                },
                error: function () {
                    alert("error");
                }
            });
            $(".datepicker").datepicker({ dateFormat: 'dd-mm-yy' });
            //setActiveLink("Today's Attendance");

            //$('#btnExport').button();
            $("#btnExport").click(function (e) {

                setupTableExportButton('#attendance_table', 'ViewAttendance');
                e.preventDefault();
            });
            /*
            $('#btnExport').button();
            $("#btnExport").click(function (e) {
                $('#attendance_table').tableExport({ type: 'excel', escape: 'false' });
                e.preventDefault();
            });
            */

            var url = '@Url.Action("PersistentDataHandler", "AttendanceManagement", null, Request.Url.Scheme)';

            var columns = [
                   { "data": "date" },
                   { "data": "employee_code" },
                   { "data": "employee_first_name" },
                   { "data": "employee_last_name" },
                   { "data": "time_in" },
                   { "data": "time_out" },
                   { "data": "terminal_in" },
                   { "data": "terminal_out" }
            ];

            @*
               I did this so that like initDataTables the JS
        for serverside processing can be used for other tables.
            NOTE: The names of the columns correspond to the View Model.
        For example in this example the column names, first_name, last_name
        etc are taken from ViewModels.Employee
    *@

            initServerSideTable('#attendance_table', url, columns, 100);

        });
    </script>
}