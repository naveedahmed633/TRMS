@{
    ViewBag.Title = "ReprocessAttendance";
}

<style>
    .validation-summary-errors > ul {
        padding-left: 0px;
        color: red;
    }

        .validation-summary-errors > ul > li {
            list-style: none;
        }
</style>
<h4 style="font-weight: bold;">Reprocess Attendance</h4>

<div class="row">
    <div class="form-group col-md-3">
        
        @using (Html.BeginForm("RequestAttendanceReprocess", "AttendanceManagement", FormMethod.Post, new { id = "attendance-form" }))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary()

            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">Employee Code</label>

                    <select id="employees" class="form-control" name="employee_code" required></select>


                    @*<select class="chzn-select" name="employee_code" style="width:100%;">
                            <option selected="selected" disabled="disabled" value="0">Select EmployeeCode</option>
                            @foreach (ViewModels.Employee item in Model.employee)
                            {
                                <option value="@item.employee_code">@item.employee_code</option>
                            }
                        </select>*@
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">Form Date</label>
                    <input type="text" class="form-control datepicker" name="from_date" required>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <label class="control-label">To Date</label>
                    <input type="text" class="form-control datepicker" name="to_date" required>
                </div>
            </div>
            @*<div class="row">
                <div class="col-md-12">
                    <label class="control-label">Result</label>
                    <select class="chzn-select" name="remarks" style="width:100%;">
                        <option disabled="disabled" selected="selected">Select an option</option>
                        <option value="AB">Absent - AB</option>
                        <option value="PLO">Present Late - PL</option>
                        <option value="PO">Present On Time - PO</option>
                    </select>
                </div>
            </div>*@
            <div class="row">
                <div class="col-md-12" style="margin-top:5px">
                    <button type="submit" value="Submit">Reprocess Attendance</button>
                </div>
            </div>

        }
    </div>
    @using (Html.BeginForm("UploadFile", "AttendanceManagement", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary()

        <div class="row">
            <div class="col-md-4">
                <label class="btn btn-primary" for="my-file-selector" style="margin-left: 15px">
                    <input id="my-file-selector" onchange="alertFilename()" type="file" name="file" value="alert" accept=".csv" style="display:none; ">
                    Click to select file
                </label>
                <h3 class="label" style="font-size:medium; color:black" id="file-name"></h3>
            </div>

            <div class="col-md-4" style="margin-top:5px">
                <button id="btnUpload" type="submit" value="Submit">Upload File</button>
                <label class="label" style="font-size:medium; color:black"> @ViewBag.Message</label>
            </div>
        </div>
    }
    <br><br><br><br><br>

</div>

<div class="row" style="margin-bottom:5px">
    <table id="attendance_table" class="display cell-border" width="100%">
        <thead>

            <tr>
                <th>Date</th>
                <th>Employee Code</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Time In</th>
                <th>Remarks</th>
                <th>Time Out</th>
                <th>Remarks</th>
                <th>Final Remarks</th>

            </tr>

        </thead>
        <tbody></tbody>
    </table>

  
</div>








@section JS {

    <script type="text/javascript" src="@Href("~/Scripts/chosen.ajaxaddition.jquery.js")"></script>
    <script>
        $(document).ready(function () {
            $('#accordion').accordion("option", "active", 4);
            setActiveLink("Reprocess Attendance");
            $(".chzn-select").chosen();
            $("input[type=submit], button").button();
            $(".datepicker").datepicker({ dateFormat: 'dd-mm-yy' });

            //initDataTable("#leavebalance_table");


            $('#employees').ajaxChosen({
                dataType: 'json',
                type: 'POST',
                url: '@Url.Action("ChangeEmployeePasswordDataHandler", "EmployeeManagement", null, Request.Url.Scheme)'
            }, {
                loadingImg: '@Href("~/Content/ChosenAutoComplete/loading.gif")'
            });






            var url = '@Url.Action("DataHandler", "AttendanceManagement", null, Request.Url.Scheme)';

            var columns = [
                  { "data": "date" },
                   { "data": "employee_code" },
                   { "data": "employee_first_name" },
                   { "data": "employee_last_name" },
                   { "data": "time_in" },
                   { "data": "status_in" },
                   { "data": "time_out" },
                   { "data": "status_out" },
                   { "data": "final_remarks" }

            ];

        @*
               I did this so that like initDataTables the JS
            for serverside processing can be used for other tables.
                NOTE: The names of the columns correspond to the View Model.
            For example in this example the column names, first_name, last_name
            etc are taken from ViewModels.Employee
        *@

            initServerSideTable('#attendance_table', url, columns);
        });
        $('#attendance-form').on("submit", function (e) {

            alert("max");
            fDate = $('#attendance-form').find('[name*="from_date"]').val().split("-").reverse();
            tDate = $('#attendance-form').find('[name*="to_date"]').val().split("-").reverse();

            fDate = new Date(fDate[0] + "-" + fDate[1] + "-" + fDate[2]);
            tDate = new Date(tDate[0] + "-" + tDate[1] + "-" + tDate[2]);


            if (tDate < fDate) {
                alert("To Date should be greater than From Date.");
                return false;
            }

            var r = confirm("Are you sure you want to Reprocess?");
            if (r == false) {
                return false;
            }

            return true;

        });


    </script>
}
