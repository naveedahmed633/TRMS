

<h4 style="font-weight: bold;">Roster Management</h4>
<div class="row">
    <div class="form-group col-md-6">
        <h5 style="font-weight: bold;">Manage Roster</h5>
        <form>
            <div class="row">

                <div class="col-md-6">
                    <label class="control-label">Group</label>
                    <select class="form-control">
                        <option selected="selected" disabled="disabled">Select Group</option>
                        <option>1</option>
                        <option>2</option>
                        <option>3</option>
                        <option>4</option>
                        <option>5</option>
                    </select>
                    <button type="submit" style="margin-top: 5px; width: 100%;">Submit Group Roster</button>
                    <button type="submit" style="margin-top: 5px; width: 100%;">Copy & Submit Group Roster</button>
                </div>

                <div class="col-md-6">
                    <label class="control-label">Month</label>
                    <input type="date" class="form-control datepicker" style="width:100%" name="Month">
                    <button type="submit" style="margin-top: 5px; width: 100%;">View Group Roster</button>
                    <button type="submit" style="margin-top: 5px; width: 100%;">View Self Roster</button>
                    <button type="submit" style="margin-top: 5px; width: 100%;">View Employees Roster</button>

                </div>
            </div>
            
            <div class="row">
                 <div class="col-md-6">
                     <label class="control-label">Employee</label>
                     <select class="form-control">
                         <option selected="selected" disabled="disabled">Select Employee</option>
                         <option>1</option>
                         <option>2</option>
                         <option>3</option>
                         <option>4</option>
                         <option>5</option>
                     </select>  
                 </div>
                <div class="col-md-6">
                    <button type="submit" style="margin-top: 18px; width: 100%;">Manage Employee Roster</button>
                 </div>
            </div>
            
                


</form>
    </div>

</div>


@section JS {
    <script>
        $(document).ready(function () {
            $('#accordion').accordion("option", "active", 3);
            $("input[type=submit], button").button();
            setActiveLink("Manage Roster");

            $('.datepicker').datepicker({
                changeMonth: true,
                changeYear: true,
                showButtonPanel: true,
                dateFormat:"mm-yy",
                onClose: function (dateText, inst) {
                    $(this).datepicker('setDate', new Date(inst.selectedYear, inst.selectedMonth, 1));
                }
            });
        });


        
    </script>
}
<style>
    .ui-datepicker-calendar {
        display: none;
    }
    .ui-datepicker-prev {
        display: none;
    }
    .ui-datepicker-next {
        display: none;
    }
</style>
